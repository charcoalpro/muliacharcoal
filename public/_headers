# CSP note: script-src keeps 'unsafe-inline' because the GA4 + Meta Pixel
# bootstraps in Analytics.astro are inline <script> snippets. Deliberate
# trade-off on a static, no-user-content site — revisit with hashed/nonce
# scripts (or routing analytics through GTM) to drop 'unsafe-inline'.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.google-analytics.com https://*.googletagmanager.com https://www.facebook.com; connect-src 'self' https://api.web3forms.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://www.facebook.com; frame-src https://www.google.com https://www.youtube-nocookie.com; form-action 'self' https://api.web3forms.com; frame-ancestors 'none'; base-uri 'self'; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

# Sveltia CMS admin UI. Loosened CSP only on this path so the editor
# can pull its bundle from unpkg, talk to the GitHub API for commits,
# and run web workers / WASM. The public site at every other path
# stays under the strict CSP defined above.
#
# IMPORTANT TRAILING-SLASH TRAP: Cloudflare's html_handling
# "drop-trailing-slash" redirects /admin/ → /admin. The final canonical
# URL is /admin (no slash), which does NOT match the pattern /admin/* —
# that pattern requires a trailing slash. Use /admin* (splat) so both
# /admin AND /admin/anything pick up the rules below.
#
# Cloudflare _headers COMBINES values from every matching rule rather
# than overriding, so without the `!` negation below the response
# would carry BOTH the strict /* CSP and the loose /admin* CSP.
# Browsers apply the intersection (most restrictive), which blocks
# Sveltia's CDN script. The `! Content-Security-Policy` line strips
# the inherited /* CSP from /admin* responses; the next line sets the
# loose one. The /* CSP still applies to every other path.
/admin*
  ! Content-Security-Policy
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https://avatars.githubusercontent.com https://*.githubusercontent.com; font-src 'self' data: https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https://api.github.com https://unpkg.com https://cdn.jsdelivr.net https://*.workers.dev; worker-src 'self' blob:; frame-src 'self' https://github.com; form-action 'self'; base-uri 'self'; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
