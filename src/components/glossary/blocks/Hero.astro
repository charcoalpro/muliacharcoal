---
/**
 * Glossary Hero — H1, kicker, intro paragraph, and the GEO authorship
 * block (author / reviewer / fact-checker / last-updated / time-to-read).
 *
 * The top-anchor id (#top by default) is set on the outer <header> so
 * every "Back to top" link in the page jumps here.
 *
 * Authorship row pulls from company.governance; the fact-checker cell
 * is omitted when the name is still a TODO placeholder so the structured
 * authorship signal never advertises an unconfirmed role.
 */
import en from '~/i18n/en';
import { fill } from '~/lib/interpolate';
import { company, hasFact } from '~/config/company';

const t = en.glossary.hero;
const tToc = en.glossary.toc;
const gov = company.governance;
const termCount = en.glossary.terms.length;

const intro = fill(t.introTemplate, {
  brand: company.brand,
  termCount,
});

const showFactChecker = hasFact(gov.factChecker.name);
const lastUpdated = gov.author.lastReviewed;
---
<header id={tToc.topAnchorId} class="border-b border-neutral-200 bg-neutral-50">
  <div class="mx-auto max-w-4xl px-4 py-10 md:px-8 md:py-14">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-primary">{t.kicker}</p>
    <h1 class="mt-2 text-3xl font-bold text-neutral-900 md:text-4xl">{t.heading}</h1>
    <p class="mt-4 max-w-prose text-lg leading-relaxed text-neutral-700">{intro}</p>

    <dl class="mt-6 grid gap-x-6 gap-y-4 border-t border-neutral-200 pt-5 text-sm sm:grid-cols-2 md:grid-cols-5">
      <div>
        <dt class="text-neutral-600">{t.authoredByLabel}</dt>
        <dd class="mt-0.5 font-medium text-neutral-900">{gov.author.name}</dd>
        <dd class="text-neutral-600">{gov.author.role}</dd>
      </div>
      <div>
        <dt class="text-neutral-600">{t.reviewedByLabel}</dt>
        <dd class="mt-0.5 font-medium text-neutral-900">{gov.reviewer.name}</dd>
        <dd class="text-neutral-600">{gov.reviewer.role}</dd>
      </div>
      {showFactChecker && (
        <div>
          <dt class="text-neutral-600">{t.factCheckedByLabel}</dt>
          <dd class="mt-0.5 font-medium text-neutral-900">{gov.factChecker.name}</dd>
          <dd class="text-neutral-600">{gov.factChecker.role}</dd>
        </div>
      )}
      <div>
        <dt class="text-neutral-600">{t.lastUpdatedLabel}</dt>
        <dd class="mt-0.5 font-medium text-neutral-900">
          <time datetime={lastUpdated}>{lastUpdated}</time>
        </dd>
      </div>
      <div>
        <dt class="text-neutral-600">{t.readTimeLabel}</dt>
        <dd class="mt-0.5 font-medium text-neutral-900">{t.readTimeValue}</dd>
      </div>
    </dl>
  </div>
</header>
