---
import en from '~/i18n/en.json';

const year = new Date().getFullYear();
---
<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-12 md:px-8">
    <div class="grid gap-8 md:grid-cols-4">
      <div>
        <p class="font-semibold text-brand-primary">{en.site.name}</p>
        <p class="mt-2 text-sm text-neutral-600">{en.footer.legalName}</p>
        <p class="mt-1 text-sm text-neutral-600">{en.footer.address}</p>
      </div>

      <nav aria-label={en.footer.resources}>
        <h2 class="text-sm font-semibold text-neutral-900">{en.footer.resources}</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/faq" class="text-neutral-600 hover:text-brand-primary">{en.footer.faq}</a></li>
          <li><a href="/samples" class="text-neutral-600 hover:text-brand-primary">{en.footer.samples}</a></li>
          <li><a href="/blog" class="text-neutral-600 hover:text-brand-primary">{en.footer.blog}</a></li>
          <li><a href="/glossary" class="text-neutral-600 hover:text-brand-primary">{en.footer.glossary}</a></li>
        </ul>
      </nav>

      <nav aria-label={en.footer.company}>
        <h2 class="text-sm font-semibold text-neutral-900">{en.footer.company}</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/about" class="text-neutral-600 hover:text-brand-primary">{en.footer.about}</a></li>
          <li><a href="/contact" class="text-neutral-600 hover:text-brand-primary">{en.nav.contact}</a></li>
        </ul>
      </nav>

      <nav aria-label={en.footer.legal}>
        <h2 class="text-sm font-semibold text-neutral-900">{en.footer.legal}</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/privacy" class="text-neutral-600 hover:text-brand-primary">{en.footer.privacy}</a></li>
          <li><a href="/terms" class="text-neutral-600 hover:text-brand-primary">{en.footer.terms}</a></li>
        </ul>
      </nav>
    </div>

    <p class="mt-10 text-xs text-neutral-500">
      &copy; {year} {en.footer.legalName}. {en.footer.copyright}
    </p>
  </div>
</footer>
