---
import en from '~/i18n/en.json';
import Logo from '~/components/layout/Logo.astro';
import OnlineIndicator from '~/components/layout/OnlineIndicator.astro';
import { company, mailto, weeklyHoursLabel } from '~/config/company';
import { footerCompanyLinks as companyLinks, footerOperationsLinks as operationsLinks } from '~/config/navigation';
import { fill, companyTokens } from '~/lib/interpolate';

const year = new Date().getFullYear();

// tel: expects E.164 with no spaces; mailto() is the shared helper.
const phoneHref = `tel:${company.phone.e164}`;
const emailHref = mailto();

// Canonical token dictionary. Every {{name}} placeholder in the footer
// copy binds through this map back to /src/config/company.ts so facts
// never live in i18n JSON.
const tokens = companyTokens(company);

const logoTagline = fill(en.footer.logoTaglineTemplate, tokens);
const descriptionLabel = fill(en.footer.description.labelTemplate, tokens);
const p1Prefix = fill(en.footer.description.p1Prefix, tokens);
const p1Suffix = en.footer.description.p1Suffix;
const p2 = fill(en.footer.description.p2Template, tokens);
const p3 = fill(en.footer.description.p3Template, tokens);
const p4 = fill(en.footer.description.p4Template, tokens);

const linkCls =
  'rounded-sm text-neutral-600 transition-colors hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary';
const listLinkCls = linkCls + ' inline-block min-h-11 py-2.5 md:min-h-0';

// `companyLinks` and `operationsLinks` come from `~/config/navigation`.
// TODO(jobs, glossary): create /jobs and /glossary pages before launch.
---
<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-12 md:px-8 md:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <Logo />
        <p class="mt-4 text-sm font-medium text-neutral-800">{company.legalName}</p>
        <p class="mt-1 text-sm text-neutral-600">{logoTagline}</p>
      </div>

      <div class="space-y-4 text-sm">
        <div>
          <h2 class="text-sm font-semibold text-neutral-900">{en.footer.addressHeading}</h2>
          <address class="mt-2 not-italic text-neutral-600">
            <p class="font-medium text-neutral-800">{company.legalName}</p>
            <p>{company.address.street}</p>
            <p>{company.address.district}, {company.address.city} {company.address.postalCode}</p>
            <p>{company.address.region}, {company.address.country}</p>
          </address>
          <a
            href={company.googleMapsUrl}
            target="_blank"
            rel="noopener"
            data-event="outbound_click"
            class:list={[linkCls, 'mt-2 inline-flex items-center gap-1']}
          >
            <span>{en.footer.googleMaps}</span>
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <dl class="space-y-1">
          <div class="flex gap-2">
            <dt class="text-neutral-500">{en.footer.emailLabel}:</dt>
            <dd><a href={emailHref} class={linkCls}>{company.email}</a></dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-neutral-500">{en.footer.phoneLabel}:</dt>
            <dd><a href={phoneHref} class={linkCls}>{company.phone.display}</a></dd>
          </div>
        </dl>

        <div>
          <h2 class="text-sm font-semibold text-neutral-900">{en.footer.hoursHeading}</h2>
          <p class="mt-2 text-neutral-600">{weeklyHoursLabel()}</p>
          <p class="text-neutral-600">{en.footer.hoursSundayClosed}</p>
        </div>

        <OnlineIndicator label={en.footer.online} class="pt-1" />
      </div>

      <nav aria-label={en.footer.companyHeading}>
        <h2 class="text-sm font-semibold text-neutral-900">{en.footer.companyHeading}</h2>
        <ul class="mt-3 flex flex-col text-sm md:space-y-1">
          {companyLinks.map((link) => (
            <li><a href={link.href} class={listLinkCls}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label={en.footer.operationsHeading}>
        <h2 class="text-sm font-semibold text-neutral-900">{en.footer.operationsHeading}</h2>
        <ul class="mt-3 flex flex-col text-sm md:space-y-1">
          {operationsLinks.map((link) => (
            <li><a href={link.href} class={listLinkCls}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="mt-12 border-t border-neutral-200 pt-8">
      <nav aria-label={en.footer.legalHeading}>
        <ul class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-neutral-600">
          <li><a href="/privacy-policy" class={linkCls}>{en.footer.legal.privacy}</a></li>
          <li aria-hidden="true" class="text-neutral-400">·</li>
          <li><a href="/terms" class={linkCls}>{en.footer.legal.terms}</a></li>
          <li aria-hidden="true" class="text-neutral-400">·</li>
          <li><a href="/cookies" class={linkCls}>{en.footer.legal.cookies}</a></li>
        </ul>
      </nav>
      <p class="mt-3 text-xs">
        <a href="/llm.txt" class={linkCls}>{en.footer.llmTxt}</a>
      </p>
    </div>

    <section aria-labelledby="company-description-heading" class="mt-8 space-y-3 text-xs leading-relaxed text-neutral-500">
      <h2 id="company-description-heading" class="sr-only">{descriptionLabel}</h2>
      <p>
        {p1Prefix}<strong class="font-semibold text-neutral-700">{company.domain}</strong>{p1Suffix}
      </p>
      <p>{p2}</p>
      <p>{p3}</p>
      <p>{p4}</p>
    </section>

    <p class="mt-8 border-t border-neutral-200 pt-6 text-xs text-neutral-500">
      &copy; {year} {company.legalName}. {en.footer.copyright}
    </p>
  </div>
</footer>
