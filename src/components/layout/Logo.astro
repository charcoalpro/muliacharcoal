---
/**
 * Logo — SVG M-mark + wordmark placeholder. The mark geometry is built
 * by `logoSvgInner()` so the `<Logo>` component, the favicon route, and
 * any future Open Graph image all stay in lockstep on colors and shape.
 *
 * Replace `logoSvgInner()` once the real brand mark is finalised.
 */
import { company } from '~/config/company';
import { logoSvgInner } from '~/lib/branding';

interface Props {
  showWordmark?: boolean;
  class?: string;
}

const { showWordmark = true, class: className } = Astro.props;

const inner = logoSvgInner();
---
<span
  class:list={['inline-flex items-center gap-2', className]}
  aria-label={company.brand}
>
  <svg
    aria-hidden="true"
    viewBox="0 0 64 64"
    class="h-8 w-8 flex-none"
    role="img"
    set:html={inner}
  ></svg>
  {showWordmark && (
    <span class="text-lg font-semibold text-brand-primary">{company.brand}</span>
  )}
</span>
