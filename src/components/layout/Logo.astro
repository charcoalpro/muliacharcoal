---
/**
 * Logo — SVG M-mark + wordmark placeholder. Replace the SVG inline
 * with the real brand mark once finalized. Keep the outer structure
 * so the swap is a one-file change.
 *
 * Colors bind to `company.brandAssets.colors` so the logo mark, the
 * favicon, and Tailwind utilities all track the same source values.
 */
import { company } from '~/config/company';

interface Props {
  showWordmark?: boolean;
  class?: string;
}

const { showWordmark = true, class: className } = Astro.props;
const brand = company.brandAssets.colors;
---
<span
  class:list={['inline-flex items-center gap-2', className]}
  aria-label={company.brand}
>
  <svg
    aria-hidden="true"
    viewBox="0 0 64 64"
    class="h-8 w-8 flex-none"
    role="img"
  >
    <rect width="64" height="64" rx="12" fill={brand.primary} />
    <text
      x="32"
      y="42"
      font-family="system-ui, -apple-system, sans-serif"
      font-size="32"
      font-weight="700"
      text-anchor="middle"
      fill={brand.accent}
    >M</text>
  </svg>
  {showWordmark && (
    <span class="text-lg font-semibold text-brand-primary">{company.brand}</span>
  )}
</span>
