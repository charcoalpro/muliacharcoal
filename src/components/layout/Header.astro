---
import en from '~/i18n/en.json';
import Button from '~/components/cta/Button.astro';

const links = [
  { href: '/products', label: en.nav.products },
  { href: '/factory', label: en.nav.factory },
  { href: '/logistics', label: en.nav.logistics },
  { href: '/quality', label: en.nav.quality },
  { href: '/guide', label: en.nav.guide },
  { href: '/markets', label: en.nav.markets },
  { href: '/packaging', label: en.nav.packaging },
  { href: '/contact', label: en.nav.contact },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-30 border-b border-neutral-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 md:px-8">
    <a href="/" class="flex items-center gap-2 text-brand-primary" aria-label={en.site.name}>
      <span class="text-lg font-semibold">{en.site.name}</span>
    </a>

    <nav aria-label={en.nav.mainNav} class="hidden lg:block">
      <ul class="flex items-center gap-5 text-sm">
        {links.map((link) => {
          const isCurrent = pathname === link.href || pathname.startsWith(link.href + '/');
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  'inline-block py-2 transition-colors hover:text-brand-primary',
                  isCurrent ? 'font-semibold text-brand-primary' : 'text-neutral-700',
                ]}
                aria-current={isCurrent ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <Button
        variant="secondary"
        size="sm"
        disabled
        aria-label={en.nav.languageSwitcher}
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.75">
          <circle cx="12" cy="12" r="9" />
          <path d="M3 12h18" stroke-linecap="round" />
          <path d="M12 3a14 14 0 0 1 0 18" stroke-linecap="round" />
          <path d="M12 3a14 14 0 0 0 0 18" stroke-linecap="round" />
        </svg>
        <span>{en.nav.currentLanguage}</span>
      </Button>
    </div>
  </div>
</header>
