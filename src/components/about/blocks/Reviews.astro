---
/**
 * About Block 9 — Reviews / social-proof placeholder cards.
 *
 * The two cards are intentionally outlined dashed-border placeholders
 * pending real Google Business and Trustpilot widgets. Each TODO comment
 * documents the eventual swap-in markup.
 */
import en from '~/i18n/en.json';

const t = en.about.block9;
---
<section class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
    <h2 class="text-2xl font-bold text-neutral-900 md:text-3xl">{t.heading}</h2>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <!-- TODO: replace with the Google Business reviews embed when the profile is verified. -->
      <div class="grid min-h-[200px] place-items-center rounded-xl border-2 border-dashed border-neutral-300 bg-white p-8 text-center">
        <div>
          <span
            aria-hidden="true"
            class="inline-grid h-12 w-12 place-items-center rounded-full bg-neutral-100 text-2xl font-bold text-neutral-700"
          >G</span>
          <h3 class="mt-3 text-lg font-semibold text-neutral-900">{t.google.heading}</h3>
          <p class="mt-2 text-sm text-neutral-600">{t.google.subtitle}</p>
        </div>
      </div>

      <!-- TODO: replace with the Trustpilot widget script when the company profile is published. -->
      <div class="grid min-h-[200px] place-items-center rounded-xl border-2 border-dashed border-neutral-300 bg-white p-8 text-center">
        <div>
          <span aria-hidden="true" class="inline-block text-3xl text-success">★</span>
          <h3 class="mt-3 text-lg font-semibold text-neutral-900">{t.trustpilot.heading}</h3>
          <p class="mt-2 text-sm text-neutral-600">{t.trustpilot.subtitle}</p>
        </div>
      </div>
    </div>
  </div>
</section>
