---
/**
 * About Block 7 — Brands & export markets.
 * Markets tag cloud falls back to a placeholder note when the
 * `commercial.exportMarkets` array is still empty.
 */
import en from '~/i18n/en.json';
import { fill } from '~/lib/interpolate';
import { company, hasFact, portOfLoadingLabel } from '~/config/company';
import ImagePlaceholder from '~/components/content/ImagePlaceholder.astro';
import Button from '~/components/cta/Button.astro';

const t = en.about.block7;
const hasExportMarkets = hasFact(company.commercial.exportMarkets);
const portNotice = fill(t.portNoticeTemplate, {
  portLabel: portOfLoadingLabel(),
});
const brandPhotoAlts = [1, 2, 3, 4, 5, 6].map((n) =>
  fill(t.photos.altTemplate, { n: String(n) }),
);
---
<section class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
    <h2 class="text-2xl font-bold text-neutral-900 md:text-3xl">{t.heading}</h2>
    <p class="mt-3 max-w-3xl text-neutral-700">{t.intro}</p>

    <div class="mt-6">
      {hasExportMarkets ? (
        <ul class="flex flex-wrap gap-2">
          {company.commercial.exportMarkets.map((country) => (
            <li class="inline-flex items-center rounded-full bg-white px-3 py-1 text-sm text-neutral-800 ring-1 ring-neutral-300">
              {country}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-neutral-500">{t.marketsFallback}</p>
      )}
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold text-neutral-900">{t.photos.heading}</h3>
      <div class="mt-4 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {brandPhotoAlts.map((alt) => (
          <ImagePlaceholder label={alt} ratio="3/2" />
        ))}
      </div>
    </div>

    <p class="mt-8 text-base text-neutral-700">{portNotice}</p>

    <div class="mt-6 flex flex-wrap gap-3">
      <Button href={t.ctaPrimaryHref} variant="primary" size="md">
        {t.ctaPrimary} →
      </Button>
      <Button href={t.ctaSecondaryHref} variant="secondary" size="md">
        {t.ctaSecondary} →
      </Button>
    </div>
  </div>
</section>
