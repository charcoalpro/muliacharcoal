---
import en from '~/i18n/en.json';

interface Props {
  phone?: string;
  message?: string;
  floating?: boolean;
}

const {
  phone = '6281234567890',
  message = 'Hello, I am interested in your coconut charcoal briquettes.',
  floating = false,
} = Astro.props;

const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---
<a
  href={href}
  target="_blank"
  rel="noopener"
  aria-label={en.cta.whatsappAria}
  data-event="whatsapp_click"
  data-source-component={floating ? 'floating' : 'inline'}
  class:list={[
    'inline-flex items-center gap-2 rounded-md bg-green-600 font-medium text-white shadow-sm transition-colors hover:bg-green-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-700',
    floating
      ? 'fixed bottom-4 end-4 z-40 h-14 w-14 items-center justify-center rounded-full p-0 text-base shadow-lg md:h-auto md:w-auto md:gap-2 md:rounded-full md:px-5 md:py-3'
      : 'px-4 py-2.5 text-sm',
  ]}
>
  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 2.1.55 4.15 1.6 5.95L2 22l4.25-1.7a9.9 9.9 0 0 0 5.79 1.56h.01c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.76 14.11c-.24.68-1.4 1.29-1.95 1.33-.52.04-1.16.21-3.92-.82-3.3-1.23-5.39-4.57-5.55-4.79-.16-.21-1.29-1.71-1.29-3.27 0-1.56.81-2.32 1.1-2.64.28-.32.61-.4.81-.4.2 0 .4.01.57.02.18.01.43-.07.67.51.24.59.81 2.03.88 2.18.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.18-.32.39-.46.53-.15.15-.31.31-.13.61.18.29.79 1.3 1.7 2.11 1.17 1.04 2.16 1.36 2.46 1.51.29.15.46.13.63-.08.17-.21.73-.85.93-1.14.2-.29.4-.24.67-.15.27.1 1.72.81 2.01.96.29.15.49.22.56.35.07.12.07.73-.17 1.42z" />
  </svg>
  <span class:list={[floating && 'sr-only md:not-sr-only']}>{en.cta.whatsapp}</span>
</a>
