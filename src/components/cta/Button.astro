---
/**
 * Button — the only button on the site. No ad-hoc button styling anywhere else.
 * Polymorphic: renders <a> when `href` is provided, otherwise <button>.
 * See DESIGN.md § Buttons for the canonical spec.
 */

import WhatsAppIcon from '~/components/cta/WhatsAppIcon.astro';

type Variant = 'primary' | 'secondary' | 'ghost' | 'danger' | 'whatsapp';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  target?: string;
  rel?: string;
  'aria-label'?: string;
  class?: string;
  id?: string;
  /** Analytics event name forwarded as `data-event` (see CLAUDE.md events). */
  'data-event'?: string;
  /** Source component identifier forwarded as `data-source-component`. */
  'data-source-component'?: string;
  /**
   * Per-event payload forwarded as `data-param-role`. Picked up by the
   * sitewide click dispatcher in `components/seo/Analytics.astro` and
   * dispatched as `role: '...'` on the GA4 event. Used by /careers
   * Apply buttons; add sibling `data-param-*` props here when new
   * events need parameters.
   */
  'data-param-role'?: string;
  /**
   * Per-event payload forwarded as `data-param-product-sku` → dispatched as
   * `product_sku: '...'`. Used by grade-page `sample_request` CTAs so the
   * event carries the SKU (CLAUDE.md § Conversion Tracking).
   */
  'data-param-product-sku'?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  target,
  rel,
  'aria-label': ariaLabel,
  class: className,
  id,
  'data-event': dataEvent,
  'data-source-component': dataSourceComponent,
  'data-param-role': dataParamRole,
  'data-param-product-sku': dataParamProductSku,
} = Astro.props;

const base =
  'inline-flex min-h-11 items-center justify-center gap-2 rounded-md font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none md:min-h-0';

const variants: Record<Variant, string> = {
  primary:
    'bg-brand-primary text-white hover:bg-brand-primary-hover focus-visible:ring-brand-primary',
  secondary:
    'border border-neutral-300 bg-white text-neutral-800 hover:bg-neutral-100 focus-visible:ring-brand-primary',
  ghost:
    'border border-current text-brand-primary hover:bg-brand-primary/5 focus-visible:ring-brand-primary',
  danger: 'bg-error text-white hover:opacity-90 focus-visible:ring-error',
  whatsapp:
    'bg-[#075E54] text-white hover:brightness-110 focus-visible:ring-[#075E54]',
};

const sizes: Record<Size, string> = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = [base, variants[variant], sizes[size], className]
  .filter(Boolean)
  .join(' ');

const isLink = Boolean(href);
const externalRel =
  target === '_blank' ? (rel ?? 'noopener') : rel;
---
{isLink ? (
  <a
    href={href}
    target={target}
    rel={externalRel}
    aria-label={ariaLabel}
    aria-disabled={disabled ? 'true' : undefined}
    id={id}
    class={classes}
    data-event={dataEvent}
    data-source-component={dataSourceComponent}
    data-param-role={dataParamRole}
    data-param-product-sku={dataParamProductSku}
  >
    {variant === 'whatsapp' && (
      <WhatsAppIcon class="h-5 w-5 shrink-0" />
    )}
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={disabled}
    aria-label={ariaLabel}
    id={id}
    class={classes}
    data-event={dataEvent}
    data-source-component={dataSourceComponent}
    data-param-role={dataParamRole}
    data-param-product-sku={dataParamProductSku}
  >
    {variant === 'whatsapp' && (
      <WhatsAppIcon class="h-5 w-5 shrink-0" />
    )}
    <slot />
  </button>
)}
