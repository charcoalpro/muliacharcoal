---
/**
 * WhatsAppIcon — the single WhatsApp glyph for every WhatsApp CTA on the site.
 *
 * The same path used to be copy-pasted four times (WhatsAppButton's fab +
 * solid/inline branches and Button's `whatsapp` variant for the <a> + <button>
 * branches). It now lives here; `class` controls the size.
 */
interface Props {
  class?: string;
}
const { class: className = 'h-5 w-5' } = Astro.props;
