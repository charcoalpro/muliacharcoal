---
/**
 * SpecsTable — semantic specification table + mirrored mobile cards.
 *
 * Same data feeds two presentations:
 *   - On `md+`, a real `<table>` with `<caption>`, scoped column headers,
 *     and row headers in the first column.
 *   - On `<md`, the same data is transposed into one card per column
 *     (one card per grade in the homepage Specifications use case),
 *     each card carrying a `<dl>` of property -> value pairs.
 *
 * Both views share the same source of truth and stay in lockstep — pass
 * `columns` (one per grade / variant) and `rows` (one per property).
 * `propertyHeader` is the label for the table's row-header column;
 * `cardEyebrow` is the small caps label rendered above each card title.
 */

interface Column {
  /** Maps to the `row[col.key]` field. */
  key: string;
  /** Display name (e.g. "Premium"). */
  label: string;
  /** Optional unit suffix in the column header (e.g. "%", "°C"). */
  unit?: string;
}

interface Props {
  columns: Column[];
  /** First-column row header is the row's `name`; remaining cells are keyed by column. */
  rows: Array<{ name: string } & Record<string, string | number>>;
  caption?: string;
  /** Column 1 header text (e.g. "Property"). */
  propertyHeader?: string;
  /** Eyebrow text shown above each mobile card's H3 (e.g. "Grade"). */
  cardEyebrow?: string;
  /** Optional id for `aria-describedby` from a section heading. */
  id?: string;
  class?: string;
}

const {
  columns,
  rows,
  caption,
  propertyHeader,
  cardEyebrow,
  id,
  class: className,
} = Astro.props;
---
<div class:list={[className]}>
  {/* Desktop table. Visible on `md+` only; mobile cards below carry the
      same data in a transposed layout. */}
  <div class="hidden overflow-x-auto md:block">
    <table id={id} class="w-full min-w-[36rem] border-collapse text-sm md:text-base">
      {caption && (
        <caption class="caption-top pb-3 text-start text-sm text-neutral-600">
          {caption}
        </caption>
      )}
      <thead>
        <tr class="border-b-2 border-brand-primary text-start">
          <th scope="col" class="px-3 py-3 text-start font-semibold text-neutral-900">
            {propertyHeader ?? ''}
          </th>
          {columns.map((col) => (
            <th scope="col" class="px-3 py-3 text-start font-semibold text-neutral-900">
              {col.label}{col.unit ? <span class="ms-1 text-neutral-500">({col.unit})</span> : null}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr class:list={[i % 2 === 1 && 'bg-neutral-50', 'border-b border-neutral-200']}>
            <th scope="row" class="px-3 py-3 text-start font-semibold text-neutral-900">
              {row.name}
            </th>
            {columns.map((col) => (
              <td class="px-3 py-3 text-neutral-700">{row[col.key]}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* Mobile cards. Hidden on `md+` to avoid duplicate readout. */}
  <div class="grid grid-cols-1 gap-4 md:hidden" role="list">
    {columns.map((col) => (
      <article role="listitem" class="rounded-2xl border border-neutral-200 bg-white p-5">
        {cardEyebrow && (
          <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">
            {cardEyebrow}
          </p>
        )}
        <h3 class="mt-1 text-lg font-semibold text-neutral-900">
          {col.label}{col.unit ? <span class="ms-1 text-neutral-500">({col.unit})</span> : null}
        </h3>
        <dl class="mt-4 grid grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm">
          {rows.map((row) => (
            <>
              <dt class="font-medium text-neutral-700">{row.name}</dt>
              <dd class="text-neutral-900">{row[col.key]}</dd>
            </>
          ))}
        </dl>
      </article>
    ))}
  </div>

  {caption && (
    <p class="mt-3 text-sm text-neutral-600 md:hidden">{caption}</p>
  )}
</div>
