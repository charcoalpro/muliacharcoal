---
/**
 * FAQSection — accessible Q&A list using native `<details>/<summary>`.
 *
 * Zero JavaScript. Open by default for the first item so AI/SEO crawlers
 * always see at least one expanded answer (some crawlers don't render
 * collapsed `<details>` content).
 *
 * FAQPage JSON-LD is NOT emitted from here — every page composes its FAQPage
 * node into its own `@graph` via `~/lib/schema/faqPage.ts`. This component is
 * purely presentational.
 */

interface Props {
  heading?: string;
  items: { q: string; a: string }[];
  id?: string;
  class?: string;
}

const {
  heading,
  items,
  id,
  class: className,
} = Astro.props;
---
<section id={id} class:list={['mx-auto max-w-3xl', className]}>
  {heading && (
    <h2 class="text-2xl font-bold text-neutral-900 md:text-3xl">{heading}</h2>
  )}
  <div class:list={[heading && 'mt-8', 'divide-y divide-neutral-200 border-y border-neutral-200']}>
    {items.map((item, i) => (
      <details class="group" open={i === 0}>
        <summary class="flex min-h-11 cursor-pointer list-none items-start justify-between gap-4 py-4 text-base font-semibold text-neutral-900 marker:hidden hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2">
          <span class="flex-1 text-start">{item.q}</span>
          <span aria-hidden="true" class="mt-1 flex-shrink-0 text-brand-primary transition-transform duration-200 group-open:rotate-180">
            <svg viewBox="0 0 20 20" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.24 4.38a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06z" />
            </svg>
          </span>
        </summary>
        <div class="pb-5 pe-9 text-base leading-relaxed text-neutral-700">
          {item.a}
        </div>
      </details>
    ))}
  </div>
</section>
