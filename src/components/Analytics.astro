---
import { company } from '~/config/company';

const GA_ID = import.meta.env.PUBLIC_GA_ID;
const GSC = import.meta.env.PUBLIC_GSC_VERIFICATION;
const isProd = import.meta.env.PROD;
---
{GSC && <meta name="google-site-verification" content={GSC} />}

{isProd && GA_ID && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script
      is:inline
      define:vars={{
        GA_ID,
        targetMarkets: company.priorityMarkets,
        businessType: company.b2bProfile.businessType,
        productTypes: company.b2bProfile.productTypes,
        exportReady: company.b2bProfile.exportReady,
      }}
    >
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID, {
        send_page_view: true,
        anonymize_ip: true,
        allow_google_signals: true,
        allow_ad_personalization_signals: true,
        business_type: businessType,
        target_markets: targetMarkets,
        product_types: productTypes,
        export_ready: exportReady
      });
    </script>
  </>
)}
