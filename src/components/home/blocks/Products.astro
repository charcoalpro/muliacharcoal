---
/**
 * Products — six-card grid section.
 *
 * Wraps the six ProductCard tiles in a `<form>` so a buyer can tick
 * the shapes they want a sample for and submit once. The form's
 * default action falls back to /#contact?intent=samples (no JS); a
 * tiny inline submit handler intercepts and routes to the WhatsApp
 * pre-fill containing the selected shape names.
 *
 * The card grid: 1 col on `<sm`, 2 cols on `sm`, 3 cols on `lg`+.
 * Each card carries its own checkbox under `name="shapes"` so the
 * submit handler can read them with `FormData`.
 *
 * Section H2 is wrapped in a link to the future `/products` pillar
 * page per spec.
 */

import en from '~/i18n/en';
import { company } from '~/config/company';
import SectionHeading from '~/components/content/SectionHeading.astro';
import ProductCard from '~/components/product/ProductCard.astro';
import Button from '~/components/cta/Button.astro';
import { productShapes } from '~/config/products';
import { fill, companyTokens } from '~/lib/interpolate';

const t = en.home.products;
const tokens = companyTokens(company);
const formId = 'home-products-samples';
const waNumber = company.whatsapp.e164Digits;
const brand = company.brand;
---
<section aria-labelledby="home-products-h2" class="bg-white">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <SectionHeading
      eyebrow={t.eyebrow}
      title={fill(t.h2, tokens)}
      subtitle={t.intro}
      id="home-products-h2"
    />
    <p class="mt-3">
      <a
        href="/products"
        class="text-sm font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
        data-source-component="products-h2-link"
      >
        {t.h2LinkLabel} <span aria-hidden="true">→</span>
      </a>
    </p>

    <form
      id={formId}
      action="/#contact?intent=samples"
      method="get"
      data-products-samples
      data-wa-number={waNumber}
      data-brand={brand}
      class="mt-10"
      novalidate
    >
      <input type="hidden" name="intent" value="samples" />

      <ul class="grid grid-cols-1 items-start gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {productShapes.map((shape) => (
          <li>
            <ProductCard shape={shape} />
          </li>
        ))}
      </ul>

      <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="max-w-2xl text-sm text-neutral-600">{t.ctaSamplesSubtext}</p>
        <Button
          type="submit"
          variant="whatsapp"
          size="lg"
          data-event="samples_request_click_products,sample_request,whatsapp_click"
          data-source-component="products-cta"
          aria-label={t.ctaSamples}
        >
          {t.ctaSamples}
        </Button>
      </div>
    </form>
  </div>
</section>

<script
  is:inline
  define:vars={{ formId }}
>
  (function () {
    var form = document.getElementById(formId);
    if (!form) return;

    var waNumber = form.dataset.waNumber;
    if (!waNumber) return;
    var brand = form.dataset.brand || '';

    form.addEventListener('submit', function (e) {
      var fd = new FormData(form);
      var shapes = fd.getAll('shapes').filter(function (s) { return typeof s === 'string' && s.length > 0; });
      var summary = shapes.length > 0 ? shapes.join(', ') : 'all shapes';
      var text = "Hello " + brand + " — please send free samples of: " + summary + ". Sent from " + location.pathname + ".";
      var url = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(text);

      e.preventDefault();
      try {
        window.open(url, '_blank', 'noopener');
      } catch (_) {
        location.href = url;
      }
    });
  })();
</script>
