---
/**
 * OEM Packaging — two-card private-label section.
 *
 * Card 1 surfaces the box-layout request flow ("get layouts and sizes");
 * card 2 surfaces the designer flow ("discuss your brand"). Both are
 * WhatsApp CTAs with distinct contexts so we can see in analytics
 * which entry point converts. Links to the future /packaging pillar.
 */

import en from '~/i18n/en.json';
import SectionHeading from '~/components/content/SectionHeading.astro';
import Card from '~/components/content/Card.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';

const t = en.home.oem;
---
<section aria-labelledby="home-oem-title" class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <SectionHeading
      eyebrow={t.eyebrow}
      title={t.title}
      subtitle={t.subtitle}
      id="home-oem-title"
    />

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <Card padding="p-6 md:p-8" class="h-full">
        <h3 class="text-lg font-semibold text-neutral-900">{t.cards.layout.heading}</h3>
        <p class="mt-3 text-sm leading-relaxed text-neutral-600">{t.cards.layout.body}</p>
        <Fragment slot="footer">
          <WhatsAppButton
            context="oemLayout"
            size="md"
            messageContext="OEM packaging layouts and master-box / inner-box sizes"
            label={t.ctaLayout}
          />
        </Fragment>
      </Card>

      <Card padding="p-6 md:p-8" class="h-full">
        <h3 class="text-lg font-semibold text-neutral-900">{t.cards.designer.heading}</h3>
        <p class="mt-3 text-sm leading-relaxed text-neutral-600">{t.cards.designer.body}</p>
        <Fragment slot="footer">
          <WhatsAppButton
            context="oemDesigner"
            size="md"
            messageContext="a private-label brand with your designer"
            label={t.ctaDesigner}
          />
        </Fragment>
      </Card>
    </div>

    <div class="mt-8">
      <a
        href="/packaging"
        class="text-sm font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
      >
        Browse all packaging options →
      </a>
    </div>
  </div>
</section>
