---
/**
 * Trust Strip — five quick-glance trust facts buyers verify.
 *
 * Surfaces the items spec calls out: REACH alignment, independent lab
 * audits, shipping lines we book direct with from Semarang, languages
 * the team speaks, and the priority country list. Each card is a small
 * label + value pair; no CTAs (the conversion comes from the surrounding
 * sections).
 */

import en from '~/i18n/en.json';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';

const t = en.home.trustStrip;
const tokens = companyTokens(company);

const items: { label: string; value: string }[] = [
  { label: t.items.reach.label, value: fill(t.items.reach.value, tokens) },
  { label: t.items.audits.label, value: t.items.audits.value },
  { label: t.items.shipping.label, value: t.items.shipping.value },
  { label: t.items.languages.label, value: t.items.languages.value },
  { label: t.items.countries.label, value: t.items.countries.value },
];
---
<section
  aria-label={t.eyebrow}
  class="border-b border-neutral-200 bg-neutral-50"
>
  <div class="mx-auto max-w-7xl px-4 py-8 md:px-8 md:py-10">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">
      {t.eyebrow}
    </p>
    <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {items.map((item) => (
        <li class="rounded-lg border border-neutral-200 bg-white px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-primary">
            {item.label}
          </p>
          <p class="mt-1 text-sm font-medium text-neutral-800">{item.value}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
