---
/**
 * HomeContactForm — slim wholesale-inquiry form for the homepage.
 *
 * Five fields (name + email + country + WhatsApp + message), honeypot,
 * no attachments, no hCaptcha. POSTs to the same Web3Forms endpoint as
 * the full /contact form but with subject "Homepage inquiry". Inline
 * success state replaces the form node — no redirect.
 *
 * Accessibility: every input has a programmatically associated label
 * and inline error region. Submit button is disabled while submitting.
 * `<noscript>` fallback uses Web3Forms' default redirect flow so the
 * form keeps working with JavaScript disabled.
 */

import en from '~/i18n/en.json';
import { company } from '~/config/company';
import { inquiryCountries } from '~/lib/data/countries';
import { EMAIL_REGEX, WHATSAPP_E164_REGEX } from '~/lib/forms/inquiryValidation';

const t = en.home.contact;
const formId = 'home-contact-form';
---
<form
  id={formId}
  method="post"
  action={company.form.web3formsEndpoint}
  data-home-contact
  class="grid gap-4"
  novalidate
>
  <input type="hidden" name="access_key" value={company.form.web3formsKey} />
  <input type="hidden" name="subject" value="Homepage inquiry — muliacharcoal.com" />
  <input type="hidden" name="from_name" value="Mulia Charcoal — homepage form" />
  <input type="hidden" name="redirect" value="false" />
  {/* Web3Forms honeypot field. Real users leave it blank. */}
  <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label for={`${formId}-name`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.name}
      </label>
      <input
        id={`${formId}-name`}
        name="name"
        type="text"
        required
        autocomplete="name"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
      <p data-error="name" hidden class="mt-1 text-sm text-error">{t.errors.name}</p>
    </div>

    <div>
      <label for={`${formId}-email`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.email}
      </label>
      <input
        id={`${formId}-email`}
        name="email"
        type="email"
        required
        autocomplete="email"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
      <p data-error="email" hidden class="mt-1 text-sm text-error">{t.errors.email}</p>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label for={`${formId}-country`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.country}
      </label>
      <select
        id={`${formId}-country`}
        name="country"
        required
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      >
        <option value="">{t.fields.countryPlaceholder}</option>
        {inquiryCountries.map((c) => <option value={c}>{c}</option>)}
      </select>
      <p data-error="country" hidden class="mt-1 text-sm text-error">{t.errors.country}</p>
    </div>

    <div>
      <label for={`${formId}-whatsapp`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.whatsapp}
      </label>
      <input
        id={`${formId}-whatsapp`}
        name="whatsapp"
        type="tel"
        autocomplete="tel"
        placeholder="+1 555 123 4567"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
      <p data-error="whatsapp" hidden class="mt-1 text-sm text-error">{t.errors.whatsapp}</p>
    </div>
  </div>

  <div>
    <label for={`${formId}-message`} class="block text-sm font-semibold text-neutral-800">
      {t.fields.message}
    </label>
    <textarea
      id={`${formId}-message`}
      name="message"
      required
      rows="4"
      placeholder={t.fields.messagePlaceholder}
      class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
    ></textarea>
    <p data-error="message" hidden class="mt-1 text-sm text-error">{t.errors.message}</p>
  </div>

  <div class="flex items-center gap-3">
    <button
      type="submit"
      data-submit
      class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-brand-primary px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 disabled:opacity-60 disabled:pointer-events-none"
      data-event="contact_form_submit"
      data-source-component="home-contact-form"
    >
      <span data-submit-label>{t.fields.submit}</span>
      <span data-submitting-label hidden>{t.fields.submitting}</span>
    </button>
  </div>

  <p data-form-error hidden role="alert" class="text-sm font-medium text-error">{t.errors.generic}</p>
</form>

<div data-home-contact-success hidden role="status" class="rounded-xl border border-success bg-success/5 p-6 text-base text-neutral-800">
  {t.success}
</div>

<script
  is:inline
  define:vars={{
    formId,
    emailRegex: EMAIL_REGEX.source,
    waRegex: WHATSAPP_E164_REGEX.source,
  }}
>
  (function () {
    var form = document.getElementById(formId);
    if (!form) return;
    var success = form.parentElement && form.parentElement.querySelector('[data-home-contact-success]');
    var submitBtn = form.querySelector('[data-submit]');
    var submitLabel = form.querySelector('[data-submit-label]');
    var submittingLabel = form.querySelector('[data-submitting-label]');
    var formError = form.querySelector('[data-form-error]');
    var emailRe = new RegExp(emailRegex);
    var waRe = new RegExp(waRegex);

    function setError(name, show) {
      var el = form.querySelector('[data-error="' + name + '"]');
      if (el) el.hidden = !show;
    }

    function validate(fd) {
      var ok = true;
      if (!fd.get('name')) { setError('name', true); ok = false; } else { setError('name', false); }
      if (!emailRe.test(String(fd.get('email') || ''))) { setError('email', true); ok = false; } else { setError('email', false); }
      if (!fd.get('country')) { setError('country', true); ok = false; } else { setError('country', false); }
      var wa = String(fd.get('whatsapp') || '');
      if (wa && !waRe.test(wa)) { setError('whatsapp', true); ok = false; } else { setError('whatsapp', false); }
      if (!fd.get('message')) { setError('message', true); ok = false; } else { setError('message', false); }
      return ok;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (formError) formError.hidden = true;
      var fd = new FormData(form);
      if (!validate(fd)) return;
      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel) submitLabel.hidden = true;
      if (submittingLabel) submittingLabel.hidden = false;

      fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r); })
        .then(function () {
          form.hidden = true;
          if (success) success.hidden = false;
          try {
            var country = String(fd.get('country') || '');
            window.gtag && window.gtag('event', 'contact_form_submit', { source: 'home-contact-form', section: 'home', country: country });
            window.fbq && window.fbq('trackCustom', 'contact_form_submit', { source: 'home-contact-form', country: country });
          } catch (_) {}
        })
        .catch(function () {
          if (formError) formError.hidden = false;
        })
        .finally(function () {
          if (submitBtn) submitBtn.disabled = false;
          if (submitLabel) submitLabel.hidden = false;
          if (submittingLabel) submittingLabel.hidden = true;
        });
    });
  })();
</script>
