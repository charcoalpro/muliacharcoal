---
/**
 * Homepage Hero — first block.
 *
 * Dark background, three trust facts (IMDG / ISO / capacity-since-year),
 * a green WhatsApp primary CTA and a brand-green "Request free samples"
 * secondary CTA that also opens WhatsApp with a samples-prefilled
 * message. The samples button fires both samples_request_click_hero
 * AND whatsapp_click_hero per spec.
 */

import en from '~/i18n/en.json';
import { company, waLinkFor } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import Button from '~/components/cta/Button.astro';

const t = en.home.hero;
const tokens = companyTokens(company);
const eyebrow = fill(t.eyebrow, tokens);
const subtitle = fill(t.subtitleTemplate, tokens);
const un1361Value = fill(t.trust.un1361Value, tokens);
const capacityValue = fill(t.trust.capacityValue, tokens);
const emailLabel = fill(t.emailLabelTemplate, tokens);

const samplesHref = waLinkFor('samplesHero');
---
<section
  aria-labelledby="home-hero-title"
  class="relative isolate overflow-hidden bg-brand-dark text-white"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-brand-dark via-brand-primary/30 to-brand-dark"
  ></div>

  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 md:grid-cols-12 md:gap-12 md:px-8 md:py-20 lg:py-24">
    <div class="md:col-span-7 lg:col-span-7">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-accent">
        {eyebrow}
      </p>
      <h1
        id="home-hero-title"
        class="mt-3 text-3xl font-bold leading-tight md:text-4xl lg:text-5xl"
      >
        {t.title}
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/80 md:text-lg">
        {subtitle}
      </p>

      <ul class="mt-8 grid max-w-2xl gap-3 sm:grid-cols-3">
        <li class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
          <p class="text-xs uppercase tracking-wider text-brand-accent">{t.trust.un1361Label}</p>
          <p class="mt-1 text-sm font-semibold text-white">{un1361Value}</p>
        </li>
        <li class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
          <p class="text-xs uppercase tracking-wider text-brand-accent">{t.trust.isoLabel}</p>
          <p class="mt-1 text-sm font-semibold text-white">{tokens.iso9001Short} certified</p>
        </li>
        <li class="rounded-lg border border-white/10 bg-white/5 px-4 py-3">
          <p class="text-xs uppercase tracking-wider text-brand-accent">{t.trust.capacityLabel}</p>
          <p class="mt-1 text-sm font-semibold text-white">{capacityValue}</p>
        </li>
      </ul>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <WhatsAppButton
          context="hero"
          size="lg"
          messageContext="a wholesale quote"
          label={t.ctaWhatsapp}
        />
        <Button
          href={samplesHref}
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener"
          data-event="samples_request_click_hero,whatsapp_click_hero"
          data-source-component="hero-samples"
        >
          {t.ctaSamples}
        </Button>
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/80">
        <span class="inline-flex items-center gap-2">
          <span class="relative inline-flex h-2.5 w-2.5" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-success opacity-75 motion-safe:animate-ping"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-success"></span>
          </span>
          <span>{t.onlineLabel}</span>
        </span>
        <a
          href={`mailto:${company.email}`}
          class="underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-2 focus-visible:ring-offset-brand-dark"
        >
          {emailLabel}
        </a>
      </div>
    </div>
  </div>
</section>
