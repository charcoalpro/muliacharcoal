---
/**
 * Contact — homepage Block 9.
 *
 * Slim form (HomeContactForm) on the left, MapsLite + direct WhatsApp
 * CTA on the right. Anchor `id="contact"` so other CTAs on the page
 * (or external links) can deep-link to this section.
 */

import en from '~/i18n/en.json';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import SectionHeading from '~/components/content/SectionHeading.astro';
import HomeContactForm from '~/components/home/blocks/HomeContactForm.astro';
import MapsLite from '~/components/contact/MapsLite.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';

const t = en.home.contact;
const tokens = companyTokens(company);
const subtitle = fill(t.subtitle, tokens);
---
<section id="contact" aria-labelledby="home-contact-title" class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <SectionHeading
      eyebrow={t.eyebrow}
      title={t.title}
      subtitle={subtitle}
      id="home-contact-title"
    />

    <div class="mt-10 grid gap-10 lg:grid-cols-2">
      <div>
        <h3 class="text-lg font-semibold text-neutral-900">{t.formHeading}</h3>
        <div class="mt-4">
          <HomeContactForm />
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-lg font-semibold text-neutral-900">{t.mapHeading}</h3>
          <div class="mt-4">
            <MapsLite />
          </div>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-neutral-900">{t.whatsappHeading}</h3>
          <div class="mt-4">
            <WhatsAppButton
              context="contact"
              size="lg"
              messageContext="a wholesale order from my country"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
