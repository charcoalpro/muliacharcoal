---
/**
 * Specifications — three-grade ladder (Premium / Super Premium / Platinum).
 *
 * Renders the seven measured properties (ash, moisture, fixed carbon,
 * burn time, burn temp, calorie value, drop test) for each grade as
 * a single source of truth fed through `<SpecsTable>`, which produces
 * a semantic `<table>` on `md+` and three transposed cards on `<md`.
 *
 * Below the table:
 *   - "Last verified" stamp + link to the COA PDF.
 *   - Radio group of 3 grades (default Super Premium) inside a fieldset.
 *   - Dynamic "Get price for {grade}" CTA: an `<a>` whose href and
 *     visible label are updated by a small inline JS handler when the
 *     radio selection changes. The CTA fires
 *     `quote_request_click_specs` via the sitewide [data-event]
 *     dispatcher; the radio change emits `specs_grade_select` directly
 *     to gtag and fbq with `{ grade }` payload.
 *   - Glossary `<details>/<summary>` list (3 Q&A pairs) via the
 *     existing FAQSection. The same Q&A pairs are appended to the
 *     homepage FAQPage `@graph` in `~/lib/schema/homepage.ts`.
 */

import en from '~/i18n/en';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import SectionHeading from '~/components/content/SectionHeading.astro';
import SpecsTable from '~/components/content/SpecsTable.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import { grades, gradePropertyKeys, type Grade, type GradePropertyKey } from '~/config/grades';

const t = en.home.specs;
// platinumFC sourced from grades.ts (SSoT) so the "fixed carbon" glossary
// answer never hardcodes the spec value in i18n.
const platinum = grades.find((g) => g.key === 'platinum')!;
const premium = grades.find((g) => g.key === 'premium')!;
const tokens = {
  ...companyTokens(company),
  platinumFC: platinum.fixedCarbon.display,
  platinumBurnTime: platinum.burnTime.display,
  platinumBurnTemp: platinum.burnTemp.display,
  premiumBurnTime: premium.burnTime.display,
};

const intro = fill(t.intro, tokens);
const lastVerified = fill(t.lastVerifiedTemplate, tokens);

const propertyKeys = gradePropertyKeys;

const columns = grades.map((g) => ({ key: g.key, label: g.name }));

const propertyLabel: Record<GradePropertyKey, string> = {
  ash: t.properties.ash,
  moisture: t.properties.moisture,
  fixedCarbon: t.properties.fixedCarbon,
  burnTime: t.properties.burnTime,
  burnTemp: t.properties.burnTemp,
  calorieValue: t.properties.calorieValue,
  dropTest: t.properties.dropTest,
};

const rows = propertyKeys.map((key) => {
  const row: { name: string } & Record<string, string> = {
    name: propertyLabel[key],
  };
  for (const g of grades) {
    row[g.key] = g[key].display;
  }
  return row;
});

const defaultGrade: Grade = grades.find((g) => g.key === 'super-premium') ?? grades[0];

function buildHref(grade: Grade) {
  const text = fill(t.ctaMessageTemplate, { ...tokens, grade: grade.name });
  return `https://wa.me/${company.whatsapp.e164Digits}?text=${encodeURIComponent(text)}`;
}

const initialCtaLabel = fill(t.ctaLabelTemplate, { grade: defaultGrade.name });
const initialHref = buildHref(defaultGrade);

const glossaryItems = (t.glossary?.items ?? []).map((item) => ({
  q: fill(item.q, tokens),
  a: fill(item.a, tokens),
}));
---
<section aria-labelledby="home-specs-h2" class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <SectionHeading
      eyebrow={t.eyebrow}
      title={fill(t.h2, tokens)}
      subtitle={intro}
      id="home-specs-h2"
    />
    <p class="mt-3">
      <a
        href="/quality/specifications-explained"
        class="text-sm font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
        data-source-component="specs-h2-link"
      >
        {t.h2LinkLabel} <span aria-hidden="true">→</span>
      </a>
    </p>

    <form
      id="home-specs-form"
      data-specs-form
      data-wa-number={company.whatsapp.e164Digits}
      data-cta-label-template={t.ctaLabelTemplate}
      data-cta-message-template={fill(t.ctaMessageTemplate, tokens)}
      class="mt-10"
      novalidate
    >
      <SpecsTable
        columns={columns}
        rows={rows}
        caption={t.caption}
        propertyHeader={t.propertyHeader}
        cardEyebrow={t.cardEyebrow}
      />

      <p class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-600">
        <span>{lastVerified}</span>
        <span aria-hidden="true">·</span>
        <a
          href={t.coaLinkHref}
          download
          class="font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
          data-event="outbound_click"
          data-source-component="specs-coa"
        >
          {t.coaLinkLabel} <span aria-hidden="true">↓</span>
        </a>
      </p>

      <fieldset class="mt-10">
        <legend class="text-sm font-semibold text-neutral-900">{t.gradePickerLegend}</legend>
        <p class="mt-1 text-sm text-neutral-600">{t.gradePickerHelp}</p>
        <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
          {grades.map((g) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="grade"
                value={g.key}
                data-grade-name={g.name}
                checked={g.key === defaultGrade.key}
                class="peer sr-only"
              />
              <span class="flex h-full flex-col gap-1 rounded-xl border border-neutral-300 bg-white px-4 py-3 text-start text-sm transition-colors peer-checked:border-brand-primary peer-checked:bg-brand-primary/5 peer-checked:ring-2 peer-checked:ring-brand-primary peer-focus-visible:outline-none peer-focus-visible:ring-2 peer-focus-visible:ring-brand-primary peer-focus-visible:ring-offset-2">
                <span class="text-base font-semibold text-neutral-900">{g.name}</span>
                <span class="text-xs text-neutral-600">{g.description}</span>
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="mt-8">
        <a
          href={initialHref}
          target="_blank"
          rel="noopener"
          data-specs-cta
          data-event="quote_request_click_specs"
          data-source-component={`specs-cta-${defaultGrade.key}`}
          class="inline-flex min-h-14 items-center justify-center gap-2 rounded-md bg-brand-primary px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-brand-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
        >
          <span data-specs-cta-label>{initialCtaLabel}</span>
          <span class="sr-only"> {en.contact.newTabSr}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </form>

    <FAQSection
      heading={t.glossary.heading}
      items={glossaryItems}
      class="mt-16"
    />
    <p class="mx-auto mt-6 max-w-3xl text-sm">
      <a
        href={en.home.faqTeaser.href}
        class="font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
        data-source-component="home-specs-faq-teaser"
      >
        {en.home.faqTeaser.label} <span aria-hidden="true">→</span>
      </a>
    </p>
  </div>
</section>

<script
  is:inline
>
  (function () {
    var form = document.getElementById('home-specs-form');
    if (!form) return;
    var cta = form.querySelector('[data-specs-cta]');
    var label = form.querySelector('[data-specs-cta-label]');
    if (!cta || !label) return;

    var waNumber = form.dataset.waNumber;
    var labelTemplate = form.dataset.ctaLabelTemplate || '';
    var messageTemplate = form.dataset.ctaMessageTemplate || '';

    function update(gradeKey, gradeName) {
      label.textContent = labelTemplate.replace('{{grade}}', gradeName);
      var text = messageTemplate.replace('{{grade}}', gradeName);
      cta.href = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(text);
      cta.setAttribute('data-source-component', 'specs-cta-' + gradeKey);
      try {
        var payload = {
          grade: gradeKey,
          section: 'specs',
          source: 'specs-radio',
          locale: document.documentElement.lang || 'en',
          viewport: window.innerWidth + 'x' + window.innerHeight,
          url: location.pathname,
        };
        window.gtag && window.gtag('event', 'specs_grade_select', payload);
        window.fbq && window.fbq('trackCustom', 'specs_grade_select', payload);
      } catch (_) {}
    }

    form.querySelectorAll('input[name="grade"]').forEach(function (r) {
      r.addEventListener('change', function () {
        if (!r.checked) return;
        update(r.value, r.dataset.gradeName || r.value);
      });
    });
  })();
</script>
