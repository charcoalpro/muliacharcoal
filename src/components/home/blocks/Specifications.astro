---
/**
 * Specifications — three-grade SpecsTable (Premium / Super Premium /
 * Platinum) plus a "Get a USD price list" WhatsApp CTA.
 *
 * Numeric values come from `src/config/grades.ts`. Grade-name and notes
 * copy comes from i18n so they can be tuned per locale.
 */

import en from '~/i18n/en.json';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import SectionHeading from '~/components/content/SectionHeading.astro';
import SpecsTable from '~/components/content/SpecsTable.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import { grades } from '~/config/grades';

const t = en.home.specs;
const tokens = companyTokens(company);
const subtitle = fill(t.subtitle, tokens);

const columns = [
  { key: 'ash', label: t.columns.ash, unit: '%' },
  { key: 'moisture', label: t.columns.moisture, unit: '%' },
  { key: 'fixedCarbon', label: t.columns.fixedCarbon, unit: '%' },
  { key: 'burnTime', label: t.columns.burnTime, unit: 'min' },
  { key: 'burnTemp', label: t.columns.burnTemp, unit: '°C' },
];

const rows = grades.map((g) => ({
  name: t.grades[g.key]?.name ?? g.name,
  ash: g.ashPct.toString(),
  moisture: g.moisturePct.toString(),
  fixedCarbon: g.fixedCarbonPct.toString(),
  burnTime: g.burnTimeMinutes.toString(),
  burnTemp: g.burnTempC.toString(),
}));
---
<section aria-labelledby="home-specs-title" class="bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
    <SectionHeading
      eyebrow={t.eyebrow}
      title={t.title}
      subtitle={subtitle}
      id="home-specs-title"
    />

    <div class="mt-10">
      <SpecsTable columns={columns} rows={rows} caption={t.caption} />
    </div>

    <ul class="mt-8 grid gap-4 md:grid-cols-3">
      {grades.map((g) => (
        <li class="rounded-xl border border-neutral-200 bg-white p-5">
          <h3 class="text-base font-semibold text-neutral-900">
            {t.grades[g.key]?.name ?? g.name}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">
            {t.grades[g.key]?.notes ?? ''}
          </p>
        </li>
      ))}
    </ul>

    <div class="mt-10 flex justify-start">
      <WhatsAppButton
        context="specs"
        size="lg"
        messageContext="a USD price list for all three grades"
        label={t.ctaQuote}
      />
    </div>
  </div>
</section>
