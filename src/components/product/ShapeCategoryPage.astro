---
/**
 * Shape-category page template (`/products/{shape-plural}`).
 *
 * Mid-tier hub: introduces one shape, enumerates its sizes, and links every
 * size to its three grade pages. Owns the shape head term (e.g. "cube
 * coconut hookah charcoal"). Schema: CollectionPage + ItemList of the
 * shape's grade pages; Breadcrumbs emits its own BreadcrumbList.
 *
 * Facts come from `~/config/{company,products,grades}`; prose from
 * `en.productCategory` (per-shape copy under `shape.{key}`). Down-links use
 * `<MaybeLink>` so unpublished grade pages degrade to text, never 404.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import en from '~/i18n/en';
import { company, waLinkFor } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import { grades } from '~/config/grades';
import { gradeHref, gradesForSize } from '~/config/productRoutes';
import { productMarkets, type ProductShape } from '~/config/products';
import { collectionPageSchema } from '~/lib/schema/collectionPage';

interface Props {
  shape: ProductShape;
}
const { shape } = Astro.props;

const t = en.productCategory;
const st = t.shape[shape.key as keyof typeof t.shape];

const premium = grades.find((g) => g.key === 'premium')!;
const platinum = grades.find((g) => g.key === 'platinum')!;

const tokens = {
  ...companyTokens(company),
  shape: shape.shortName,
  shapeLower: shape.shortName.toLowerCase(),
  sizeCount: shape.sizes.length,
  gradeCount: grades.length,
  gradeNames: grades.map((g) => g.name).join(', '),
  premiumAsh: premium.ash.display,
  platinumAsh: platinum.ash.display,
};

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

const cafe = productMarkets.find((m) => m.key === 'cafe')!;
const shop = productMarkets.find((m) => m.key === 'shop')!;

const atGlance = [
  { label: t.atAGlance.burnLabel, value: st?.burn ?? shape.description },
  { label: t.atAGlance.usersLabel, value: st?.users ?? '' },
  { label: t.atAGlance.sizesLabel, value: fill(t.atAGlance.sizesValueTemplate, tokens) },
  { label: t.atAGlance.gradesLabel, value: fill(t.atAGlance.gradesValueTemplate, tokens) },
  { label: t.atAGlance.moqLabel, value: fill(t.atAGlance.moqValueTemplate, tokens) },
];

// ItemList = every grade page of every size in this shape.
const skus = shape.sizes.flatMap((size) =>
  grades.map((g) => ({ href: gradeHref(size, g), name: `${g.name} ${size.label} ${shape.name}` })),
);
const schema = collectionPageSchema({ pageTitle, pageDescription, path: shape.href, skus });

const sectionH2 = 'text-2xl font-bold text-neutral-900 md:text-3xl';
const proseP = 'mt-4 max-w-prose text-base leading-relaxed text-neutral-700';
const linkP = 'mt-3 text-sm';
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path={shape.href}
  type="website"
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-5xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[{ label: t.breadcrumbProducts, href: '/products' }, { label: shape.shortName }]} />
  </div>

  <HeroSection
    eyebrow={fill(t.eyebrowTemplate, tokens)}
    title={fill(t.h1Template, tokens)}
    subtitle={st?.definition}
    primaryCta={{
      label: t.cta.quote,
      href: waLinkFor('quoteSpecs'),
      ariaLabel: fill(t.cta.quoteAria, tokens),
      target: '_blank',
      rel: 'noopener',
      dataEvent: 'whatsapp_click',
      dataSourceComponent: 'category-hero-quote',
    }}
    secondaryCta={{
      label: t.cta.sample,
      href: waLinkFor('samplesHero'),
      ariaLabel: fill(t.cta.sampleAria, tokens),
      target: '_blank',
      rel: 'noopener',
      dataEvent: 'sample_request,whatsapp_click',
      dataSourceComponent: 'category-hero-sample',
    }}
  >
    <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-3">
      {atGlance.filter((i) => i.value).map((item) => (
        <div class="border-s-2 border-brand-accent ps-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-neutral-600">{item.label}</dt>
          <dd class="mt-1 text-sm font-semibold text-neutral-900">{item.value}</dd>
        </div>
      ))}
    </dl>
  </HeroSection>

  {/* About the format */}
  <section id="about-the-format" aria-labelledby="about-heading" class="scroll-mt-24 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <h2 id="about-heading" class={sectionH2}>{fill(t.sections.about, tokens)}</h2>
      <p class={proseP}>{st?.aboutBody}</p>
    </div>
  </section>

  {/* Sizes available — each size links to its 3 grade pages */}
  <section id="sizes-available" aria-labelledby="sizes-heading" class="scroll-mt-24 bg-neutral-50">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <h2 id="sizes-heading" class={sectionH2}>{fill(t.sections.sizes, tokens)}</h2>
      <p class={proseP}>{fill(t.sizes.intro, tokens)}</p>
      <ul class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {shape.sizes.map((size) => (
          <li class="rounded-2xl border border-neutral-200 bg-white p-5">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="text-lg font-semibold text-neutral-900">{shape.name} {size.label}</h3>
              <span class="shrink-0 text-sm text-neutral-600">
                {size.pcsPerKg ? fill(t.sizes.pcsTemplate, { pcsPerKg: size.pcsPerKg }) : t.sizes.pcsPending} {t.sizes.pcsHeader}
              </span>
            </div>
            <ul class="mt-4 flex flex-wrap gap-2" role="list">
              {gradesForSize(size).map((entry) => (
                <li>
                  <MaybeLink
                    href={entry.href}
                    class="inline-block rounded-md border border-neutral-200 bg-white px-3 py-2 text-sm font-medium"
                    mutedClass="inline-block rounded-md border border-dashed border-neutral-300 bg-white px-3 py-2 text-sm"
                    data-source-component={`category-grade-${entry.slug}`}
                  >
                    {entry.grade.name}
                  </MaybeLink>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* Grades explained */}
  <section id="grades-explained" aria-labelledby="grades-heading" class="scroll-mt-24 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <h2 id="grades-heading" class={sectionH2}>{fill(t.sections.grades, tokens)}</h2>
      <p class={proseP}>{fill(t.grades.body, tokens)}</p>
      <p class={linkP}>
        <MaybeLink href="/quality/specifications-explained" class="font-semibold" data-source-component="category-specs-explained">
          {t.grades.linkSpecs} <span aria-hidden="true">→</span>
        </MaybeLink>
        <span class="mx-2 text-neutral-300" aria-hidden="true">·</span>
        <MaybeLink href="/products" data-source-component="category-hub">{t.grades.linkHub}</MaybeLink>
      </p>
    </div>
  </section>

  {/* Best markets & use cases */}
  <section id="best-markets" aria-labelledby="markets-heading" class="scroll-mt-24 bg-neutral-50">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <h2 id="markets-heading" class={sectionH2}>{fill(t.sections.markets, tokens)}</h2>
      <p class={proseP}>{st?.marketsBody}</p>
      <p class={linkP}>
        <MaybeLink href={cafe.href} class="font-semibold" data-source-component="category-market-cafe">
          {t.markets.linkCafe} <span aria-hidden="true">→</span>
        </MaybeLink>
        <span class="mx-2 text-neutral-300" aria-hidden="true">·</span>
        <MaybeLink href={shop.href} class="font-semibold" data-source-component="category-market-shop">
          {t.markets.linkShop} <span aria-hidden="true">→</span>
        </MaybeLink>
      </p>
      <p class="mt-3 text-sm leading-relaxed text-neutral-700">
        <span class="font-semibold">{en.products.choose.market.h3}:</span>{' '}
        {en.products.choose.market.items.map((m, i) => (
          <Fragment>
            {i > 0 && <span class="text-neutral-300" aria-hidden="true"> · </span>}
            <MaybeLink href={m.href} data-source-component={`category-country-${m.key}`}>{m.label}</MaybeLink>
          </Fragment>
        ))}
      </p>
    </div>
  </section>

  {/* Packaging & logistics */}
  <section id="packaging-logistics" aria-labelledby="packaging-heading" class="scroll-mt-24 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
      <h2 id="packaging-heading" class={sectionH2}>{fill(t.sections.packaging, tokens)}</h2>
      <p class={proseP}>{fill(t.packaging.body, tokens)}</p>
      <p class={linkP}>
        <MaybeLink href="/packaging" class="font-semibold" data-source-component="category-packaging">
          {t.packaging.linkPackaging} <span aria-hidden="true">→</span>
        </MaybeLink>
        <span class="mx-2 text-neutral-300" aria-hidden="true">·</span>
        <MaybeLink href="/logistics" class="font-semibold" data-source-component="category-logistics">
          {t.packaging.linkLogistics} <span aria-hidden="true">→</span>
        </MaybeLink>
      </p>
    </div>
  </section>

  {/* Related topics */}
  <section aria-labelledby="related-heading" class="border-t border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-5xl px-4 py-12 md:px-8">
      <h2 id="related-heading" class={sectionH2}>{t.related.heading}</h2>
      <ul class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink
              href={item.href}
              class="block rounded-lg border border-neutral-200 bg-white px-4 py-3 text-sm font-medium"
              mutedClass="block rounded-lg border border-dashed border-neutral-300 bg-white px-4 py-3 text-sm font-medium"
              data-source-component={`category-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}
            >
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
