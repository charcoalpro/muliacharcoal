---
/**
 * TrustBadge — single trust signal as an icon + stacked label/value pair.
 *
 * Used on the Contact-page Block 2 strip and the homepage Hero. The
 * `variant` prop switches between the default light card style and a
 * dark-friendly translucent style for use over dark hero backgrounds.
 * `tooltip` shows a native `title` attribute (zero JS) — sufficient
 * for short transport-class explanations.
 */

import en from '~/i18n/en';

interface Props {
  /** Top-line short label (e.g. "ISO 9001"). */
  label: string;
  /** Optional second-line value (e.g. "Certified since 2022"). */
  value?: string;
  /** Optional verifiable URL — when set, the badge becomes an external link. */
  href?: string;
  /** Optional one-letter / short string used as a glyph in the icon slot. */
  iconText?: string;
  /** Render style — `light` for white-card; `dark` for translucent on dark backgrounds. */
  variant?: 'light' | 'dark';
  /** Native `title` tooltip — kept short, surfaces on hover and via screen readers. */
  tooltip?: string;
  class?: string;
}

const {
  label,
  value,
  href,
  iconText,
  variant = 'light',
  tooltip,
  class: className,
} = Astro.props;

const isLink = Boolean(href);
const Tag = isLink ? 'a' : 'div';

const isDark = variant === 'dark';
---
<Tag
  href={href}
  target={isLink ? '_blank' : undefined}
  rel={isLink ? 'noopener noreferrer' : undefined}
  title={tooltip}
  class:list={[
    'flex shrink-0 items-center gap-3 rounded-xl border px-4 py-3',
    isDark
      ? 'border-white/15 bg-white/5 text-white'
      : 'border-neutral-200 bg-white text-neutral-900',
    isLink &&
      (isDark
        ? 'transition-colors hover:border-brand-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-accent'
        : 'transition-colors hover:border-brand-primary hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary'),
    className,
  ]}
>
  <span
    aria-hidden="true"
    class:list={[
      'grid h-9 w-9 shrink-0 place-items-center rounded-md text-sm font-semibold',
      isDark
        ? 'bg-brand-accent/20 text-brand-accent'
        : 'bg-brand-primary/10 text-brand-primary',
    ]}
  >
    {iconText ?? '✓'}
  </span>
  <span class="flex flex-col leading-tight">
    <span
      class:list={[
        'text-xs font-medium uppercase tracking-wide',
        isDark ? 'text-white/70' : 'text-neutral-600',
      ]}
    >
      {label}
    </span>
    {value && (
      <span
        class:list={[
          'text-sm font-semibold',
          isDark ? 'text-white' : 'text-neutral-900',
        ]}
      >
        {value}
      </span>
    )}
  </span>
  {isLink && (
    <span class="sr-only">{en.contact.newTabSr}</span>
  )}
</Tag>
