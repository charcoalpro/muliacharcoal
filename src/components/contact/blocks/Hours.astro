---
/**
 * Contact Block 8 — weekly hours, 2026 holidays, Lebaran callout.
 */
import en from '~/i18n/en';
import { fill } from '~/lib/interpolate';
import { company } from '~/config/company';
import DataTable from '~/components/content/DataTable.astro';
import Section from '~/components/layout/Section.astro';
import SectionHeading from '~/components/content/SectionHeading.astro';

const t = en.contact;
const lebaran = company.lebaranShutdown;
const lebaranBody = fill(t.hours.lebaranBodyTemplate, {
  from: lebaran.from,
  to: lebaran.to,
  cutoff: lebaran.orderCutoff,
});

const weeklyRows = [
  { label: t.hours.monSat, values: ['08:00 – 16:00'] },
  { label: t.hours.sun, values: [t.hours.closed] },
];

const holidayRows = company.holidays2026.map((h) => ({
  label: h.date,
  values: [h.day, h.name],
}));
---
<Section labelledBy="hours-heading" class="bg-neutral-50">
  <SectionHeading id="hours-heading" title={t.hours.heading} subtitle={t.hours.lead} />

  <div class="mt-10 grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h3 class="text-base font-semibold text-neutral-900">{t.hours.weeklyHeading}</h3>
        <DataTable
          class="mt-3"
          headers={[t.hours.tableDay, t.hours.tableHours]}
          rows={weeklyRows}
        />
      </div>

      <div class="lg:col-span-7">
        <h3 class="text-base font-semibold text-neutral-900">{t.hours.holidaysHeading}</h3>
        <DataTable
          class="mt-3"
          headers={[t.hours.tableDate, t.hours.tableDayName, t.hours.tableHolidayName]}
          rows={holidayRows}
        />
      </div>
    </div>

  <div role="note" class="mt-8 rounded-xl border-l-4 border-warning bg-warning/10 p-5">
    <p class="text-sm font-semibold text-neutral-900">{t.hours.lebaranHeading}</p>
    <p class="mt-1 text-sm text-neutral-800">{lebaranBody}</p>
  </div>
</Section>
