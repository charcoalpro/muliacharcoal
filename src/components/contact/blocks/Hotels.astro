---
/**
 * Contact Block 10 — hotels split by star tier. Tiers with zero entries
 * are hidden so the section never renders an empty group heading.
 */
import en from '~/i18n/en';
import { company } from '~/config/company';
import HotelCard from '~/components/contact/HotelCard.astro';
import Section from '~/components/layout/Section.astro';
import SectionHeading from '~/components/content/SectionHeading.astro';

const t = en.contact.hotels;
const fiveStar = company.hotels.filter((h) => h.stars === 5);
const fourStar = company.hotels.filter((h) => h.stars === 4);
const threeStar = company.hotels.filter((h) => h.stars === 3);

const tiers = [
  { tier: fiveStar, heading: t.fiveStarHeading },
  { tier: fourStar, heading: t.fourStarHeading },
  { tier: threeStar, heading: t.threeStarHeading },
].filter((g) => g.tier.length > 0);
---
<Section labelledBy="hotels-heading" class="bg-neutral-50">
  <SectionHeading id="hotels-heading" title={t.heading} subtitle={t.lead} />

  {tiers.map((g) => (
    <div class="mt-10">
      <h3 class="text-base font-semibold text-neutral-900">{g.heading}</h3>
      <ul class="mt-4 grid items-start gap-6 md:grid-cols-2 lg:grid-cols-3">
        {g.tier.map((h) => (
          <li><HotelCard hotel={h} /></li>
        ))}
      </ul>
    </div>
  ))}
</Section>
