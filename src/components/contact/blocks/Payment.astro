---
/**
 * Contact Block 11 — accepted terms / currencies, public banking table,
 * and Proforma Invoice CTA. Banking details are always public per
 * product decision; the BankDetailsTable component owns the table markup.
 */
import en from '~/i18n/en';
import { fill } from '~/lib/interpolate';
import { company, getOwner, waLinkFor } from '~/config/company';
import BankDetailsTable from '~/components/payment/BankDetailsTable.astro';
import Section from '~/components/layout/Section.astro';
import SectionHeading from '~/components/content/SectionHeading.astro';
import Button from '~/components/cta/Button.astro';

const t = en.contact;
const isBankPublic = company.payment.mode === 'public';
const bank = company.bank;
const piHref = waLinkFor('piRequest');
const paymentWarningBody = fill(t.payment.warningBodyTemplate, {
  director: getOwner()?.name ?? company.legalName,
});
---
<Section labelledBy="payment-heading" class="bg-white">
  <SectionHeading id="payment-heading" title={t.payment.heading} />

  <div role="alert" class="mt-6 rounded-xl border-s-4 border-error bg-error/10 p-5">
      <p class="font-semibold text-neutral-900">⚠ {t.payment.warningHeading}</p>
      <p class="mt-2 text-sm text-neutral-800">{paymentWarningBody}</p>
    </div>

    <div class="mt-8 grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h3 class="text-base font-semibold text-neutral-900">{t.payment.termsHeading}</h3>
        <ul class="mt-3 space-y-2 text-sm text-neutral-700">
          {company.payment.terms.map((term) => (
            <li class="flex gap-2"><span aria-hidden="true" class="text-brand-primary">•</span><span>{term}</span></li>
          ))}
        </ul>
        <h3 class="mt-6 text-base font-semibold text-neutral-900">{t.payment.currenciesHeading}</h3>
        <p class="mt-2 text-sm text-neutral-700">{company.payment.currencies.join(', ')}</p>
        <p class="mt-4 text-sm text-neutral-700">
          <span class="font-medium text-neutral-700">{t.payment.bankCountryLabel}: </span>
          {company.payment.bankCountry}
        </p>
      </div>

      {isBankPublic && (
        <div class="lg:col-span-7">
          <BankDetailsTable
            headers={[t.payment.tableField, t.payment.tableValue]}
            labels={{
              bankName: t.payment.fields.bankName,
              accountName: t.payment.fields.beneficiary,
              accountNumber: t.payment.fields.accountNumber,
              swift: t.payment.fields.swift,
              branch: t.payment.fields.branch,
              bankAddress: t.payment.fields.bankAddress,
              iban: t.payment.fields.iban,
              currency: t.payment.fields.currency,
            }}
          />
          <p class="mt-3 text-sm text-neutral-600">
            {fill(t.payment.lastVerifiedTemplate, { date: bank.lastVerified })}
          </p>
          <Button
            href={piHref}
            variant="whatsapp"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t.payment.piButtonAria}
            data-event="whatsapp_click"
            data-source-component="payment-pi"
            class="mt-5"
          >
            {t.payment.piButton}
            <span class="sr-only">{t.newTabSr}</span>
          </Button>
        </div>
      )}
    </div>
</Section>
