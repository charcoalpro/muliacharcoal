---
/**
 * TeamCard — single team member in the Contact-page Block 4 grid.
 */

import ImagePlaceholder from '~/components/ImagePlaceholder.astro';
import en from '~/i18n/en.json';
import { fill } from '~/lib/interpolate';
import type { TeamMember } from '~/config/company';

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;

const t = en.contact.team;
const photoLabel = fill(t.photoOfTemplate, { name: member.name });

const waHref = `https://wa.me/${member.whatsappE164Digits}?text=${encodeURIComponent(member.whatsappPreset)}`;
const telHref = `tel:${member.phoneE164}`;
const mailHref = `mailto:${member.email}`;
---
<article class="flex h-full flex-col rounded-xl border border-neutral-200 bg-white p-6">
  <ImagePlaceholder label={photoLabel} ratio="square" class="mb-4" />
  <h3 class="text-xl font-semibold text-neutral-900">{member.name}</h3>
  <p class="mt-1 text-sm text-neutral-600">{member.role}</p>
  <p class="mt-3 text-sm text-neutral-600">
    <span class="font-medium text-neutral-700">{t.languagesLabel}:</span>{' '}
    {member.languages.join(', ')}
  </p>
  <dl class="mt-4 space-y-1 text-sm">
    <div class="flex flex-wrap gap-x-2">
      <dt class="font-medium text-neutral-700">Phone:</dt>
      <dd>
        <a
          href={telHref}
          class="text-brand-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary rounded-sm"
        >
          {member.phoneDisplay}
        </a>
      </dd>
    </div>
    <div class="flex flex-wrap gap-x-2">
      <dt class="font-medium text-neutral-700">Email:</dt>
      <dd>
        <a
          href={mailHref}
          class="break-all text-brand-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary rounded-sm"
        >
          {member.email}
        </a>
      </dd>
    </div>
  </dl>
  <div class="mt-auto pt-5 flex flex-wrap gap-2">
    <a
      href={waHref}
      target="_blank"
      rel="noopener noreferrer"
      data-event="whatsapp_click"
      data-source-component="team-card"
      class="inline-flex flex-1 items-center justify-center gap-2 rounded-md bg-success px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-success"
    >
      {t.buttonWhatsapp}
      <span class="sr-only">{en.contact.newTabSr}</span>
    </a>
    <a
      href={telHref}
      class="inline-flex items-center justify-center rounded-md border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-800 transition-colors hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
      aria-label={fill(en.contact.whatsappPrimary.buttonAriaCallTemplate, { name: member.name, phone: member.phoneDisplay })}
    >
      {t.buttonCall}
    </a>
    <a
      href={mailHref}
      class="inline-flex items-center justify-center rounded-md border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-800 transition-colors hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
    >
      {t.buttonEmail}
    </a>
  </div>
</article>
