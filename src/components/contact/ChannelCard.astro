---
/**
 * ChannelCard — single contact channel in Block 5 grid.
 *
 * `href` may be an external URL (`https://...`, `tel:`, `mailto:`,
 * `sms:`, on-page anchor `#…`). External (http/https) links open in a
 * new tab with the standard sr-only "(opens in new tab)" affordance.
 */

import en from '~/i18n/en.json';
import { fill } from '~/lib/interpolate';

interface Props {
  channel: string;
  /** Visible handle line (e.g. `+62 821 287 68 545` or `@mulia_charcoal`). */
  handle: string;
  /** Where the button leads. */
  href: string;
  /** Optional one-letter glyph used in the icon slot. */
  iconText?: string;
  /** Override the default "Open in {channel}" CTA label. */
  ctaLabel?: string;
}

const { channel, handle, href, iconText, ctaLabel } = Astro.props;

const isExternal = /^https?:\/\//.test(href);
const label = ctaLabel ?? fill(en.contact.channels.openIn, { channel });
---
<article class="flex h-full flex-col rounded-xl border border-neutral-200 bg-white p-5">
  <div class="flex items-center gap-3">
    <span
      aria-hidden="true"
      class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-brand-primary/10 text-base font-semibold text-brand-primary"
    >
      {iconText ?? channel.slice(0, 1)}
    </span>
    <h3 class="text-base font-semibold text-neutral-900">{channel}</h3>
  </div>
  <p class="mt-3 break-words text-sm text-neutral-700">{handle}</p>
  <a
    href={href}
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'noopener noreferrer' : undefined}
    class="mt-auto inline-flex items-center justify-center rounded-md border border-neutral-300 px-4 py-2 pt-3 text-sm font-semibold text-neutral-800 transition-colors hover:border-brand-primary hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
  >
    {label}
    {isExternal && <span class="sr-only">{en.contact.newTabSr}</span>}
  </a>
</article>
