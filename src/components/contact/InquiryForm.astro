---
/**
 * InquiryForm — Block 6 wholesale inquiry form.
 *
 * Posts to Web3Forms (`company.form.web3formsEndpoint`). Honeypot + Web3Forms'
 * built-in spam filter cover anti-spam; an optional hCaptcha widget can be
 * enabled via `company.form.captcha.provider = 'hcaptcha'`.
 *
 * Vanilla JS only — validation/submission logic lives in `~/lib/forms/inquiry.ts`,
 * static dropdown data lives in `~/config/inquiryForm.ts`. This component is
 * the markup + i18n binding only.
 */

import en from '~/i18n/en.json';
import { company, waLinkFor } from '~/config/company';
import {
  inquiryCountries,
  inquiryProducts,
  inquiryHoneypotName,
  inquiryAttachment,
} from '~/config/inquiryForm';
import FormField from '~/components/contact/FormField.astro';
import type { InquiryFormConfig } from '~/lib/forms/inquiry';

const t = en.contact.form;
const f = t.fields;
const errs = t.errors;

const sidebarWaHref = waLinkFor('salesGeneral');

const useHCaptcha =
  company.form.captcha.provider === 'hcaptcha' &&
  company.form.captcha.hcaptchaSiteKey &&
  !company.form.captcha.hcaptchaSiteKey.startsWith('TODO_');

const inputClass =
  'w-full rounded-md border border-neutral-300 bg-white px-4 py-3 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-brand-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary aria-[invalid=true]:border-error mt-1';

// Runtime config consumed by `setupInquiryForm()`. Embedded as a JSON script
// tag (`#ih-config`) so the bundled <script> can read it without `define:vars`.
const formConfig: InquiryFormConfig = {
  endpoint: company.form.web3formsEndpoint,
  honeypotName: inquiryHoneypotName,
  attachmentMaxBytes: inquiryAttachment.maxBytes,
  attachmentAcceptedTypes: inquiryAttachment.acceptedTypes,
  errors: errs,
  success: {
    heading: t.successHeading,
    bodyTemplate: t.successBodyTemplate,
    waLabel: t.successWhatsapp,
    waHref: sidebarWaHref,
  },
};
---
<div class="grid gap-10 lg:grid-cols-12">
  <div class="lg:col-span-8">
    <form
      id="inquiry-form"
      class="space-y-6"
      method="POST"
      action={company.form.web3formsEndpoint}
      enctype="multipart/form-data"
      novalidate
      data-web3forms-key={company.form.web3formsKey}
    >
      <input type="hidden" name="access_key" value={company.form.web3formsKey} />
      <input type="hidden" name="subject" value={company.form.subject} />
      <input type="hidden" name="from_name" value={company.brand} />
      <input type="hidden" name="redirect" value="false" />

      <!-- Honeypot — bots fill any visible-named field; humans never see this. -->
      <div class="hidden" aria-hidden="true">
        <label for="ih-website-url">{f.honeypot}</label>
        <input
          id="ih-website-url"
          type="text"
          name={inquiryHoneypotName}
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      <div
        id="inquiry-status-error"
        role="alert"
        aria-live="assertive"
        class="hidden rounded-md border border-error/40 bg-error/10 px-4 py-3 text-sm text-error"
      ></div>

      <div class="grid gap-6 md:grid-cols-2">
        <FormField id="ih-fullname" label={f.fullName} required>
          <input
            id="ih-fullname"
            name="full_name"
            type="text"
            required
            minlength="2"
            maxlength="80"
            autocomplete="name"
            aria-describedby="ih-fullname-err"
            class={inputClass}
          />
        </FormField>

        <FormField id="ih-company" label={f.company} required>
          <input
            id="ih-company"
            name="company_name"
            type="text"
            required
            minlength="2"
            maxlength="120"
            autocomplete="organization"
            aria-describedby="ih-company-err"
            class={inputClass}
          />
        </FormField>

        <FormField id="ih-country" label={f.country} required>
          <select
            id="ih-country"
            name="country"
            required
            aria-describedby="ih-country-err"
            class={inputClass}
          >
            <option value="">{f.countryPlaceholder}</option>
            {inquiryCountries.map((c) => <option value={c}>{c}</option>)}
          </select>
        </FormField>

        <FormField id="ih-whatsapp" label={f.whatsapp} required hint={f.whatsappHint}>
          <input
            id="ih-whatsapp"
            name="whatsapp"
            type="tel"
            required
            inputmode="tel"
            placeholder="+1 555 0100"
            autocomplete="tel"
            aria-describedby="ih-whatsapp-hint ih-whatsapp-err"
            class={inputClass}
          />
        </FormField>

        <FormField id="ih-email" label={f.email} required span="md:col-span-2">
          <input
            id="ih-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            aria-describedby="ih-email-err"
            class={inputClass}
          />
        </FormField>
      </div>

      <fieldset aria-describedby="ih-products-hint ih-products-err">
        <legend class="block text-sm font-medium text-neutral-800">
          {f.products}<span aria-hidden="true" class="text-error"> *</span>
        </legend>
        <p id="ih-products-hint" class="mt-1 text-xs text-neutral-500">
          {f.productsHint}
        </p>
        <div class="mt-3 grid gap-2 sm:grid-cols-2 md:grid-cols-3">
          {inquiryProducts.map((p) => (
            <label class="flex items-center gap-2 rounded-md border border-neutral-200 px-3 py-2 text-sm text-neutral-800 hover:border-brand-primary">
              <input
                type="checkbox"
                name="products[]"
                value={p.id}
                class="h-4 w-4 rounded border-neutral-300 text-brand-primary focus:ring-brand-primary"
              />
              {p.label}
            </label>
          ))}
        </div>
        <p id="ih-products-err" class="mt-1 text-sm text-error hidden"></p>
      </fieldset>

      <div class="grid gap-6 md:grid-cols-2">
        <FormField id="ih-volume" label={f.volume} required>
          <select
            id="ih-volume"
            name="volume"
            required
            aria-describedby="ih-volume-err"
            class={inputClass}
          >
            <option value="">{f.volumePlaceholder}</option>
            {company.form.volumeOptions.map((v) => <option value={v}>{v}</option>)}
          </select>
        </FormField>

        <FormField id="ih-packing" label={f.packing}>
          <input
            id="ih-packing"
            name="packing"
            type="text"
            maxlength="200"
            placeholder={f.packingPlaceholder}
            class={inputClass}
          />
        </FormField>

        <FormField id="ih-port" label={f.destinationPort}>
          <input
            id="ih-port"
            name="destination_port"
            type="text"
            maxlength="80"
            placeholder={f.destinationPortPlaceholder}
            class={inputClass}
          />
        </FormField>

        <FormField id="ih-attachment" label={f.attachment}>
          <input
            id="ih-attachment"
            name="attachment"
            type="file"
            accept="application/pdf,image/jpeg,image/png"
            aria-describedby="ih-attachment-err"
            class="mt-1 w-full text-sm text-neutral-700 file:mr-3 file:rounded-md file:border-0 file:bg-brand-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-brand-primary-hover"
          />
        </FormField>
      </div>

      <div>
        <label for="ih-additional" class="block text-sm font-medium text-neutral-800">
          {f.additional}
        </label>
        <textarea
          id="ih-additional"
          name="additional"
          rows="5"
          maxlength="2000"
          placeholder={f.additionalPlaceholder}
          class={`${inputClass} min-h-[120px]`}
        ></textarea>
      </div>

      <label class="flex items-start gap-3 text-sm text-neutral-700">
        <input
          id="ih-consent"
          name="consent"
          type="checkbox"
          required
          aria-describedby="ih-consent-err"
          class="mt-1 h-4 w-4 rounded border-neutral-300 text-brand-primary focus:ring-brand-primary"
        />
        <span>
          {f.consent}{' '}
          <a
            href="/privacy-policy"
            class="text-brand-primary underline hover:no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary rounded-sm"
          >
            {f.consentLink}
          </a>.
          <span aria-hidden="true" class="text-error"> *</span>
        </span>
      </label>
      <p id="ih-consent-err" class="mt-1 text-sm text-error hidden"></p>

      {useHCaptcha && (
        <div class="h-captcha" data-sitekey={company.form.captcha.hcaptchaSiteKey}></div>
      )}

      <div class="flex flex-wrap items-center gap-4">
        <button
          id="ih-submit"
          type="submit"
          class="inline-flex items-center gap-2 rounded-md bg-brand-primary px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-50"
        >
          <span data-submit-label>{t.submit}</span>
          <span data-submitting-label class="hidden">{t.submitting}</span>
        </button>
      </div>
    </form>

    <div
      id="inquiry-success"
      role="status"
      aria-live="polite"
      class="hidden rounded-xl border border-success/40 bg-success/10 p-6"
    ></div>
  </div>

  <aside class="lg:col-span-4">
    <div class="sticky top-6 space-y-4 rounded-xl border border-neutral-200 bg-neutral-50 p-6">
      <h3 class="text-lg font-semibold text-neutral-900">{t.sidebarHeading}</h3>
      <p class="text-sm text-neutral-700">{t.sidebarLead}</p>
      <a
        href={sidebarWaHref}
        target="_blank"
        rel="noopener noreferrer"
        data-event="whatsapp_click"
        data-source-component="form-sidebar"
        class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-success px-6 py-3 text-base font-semibold text-white transition-colors hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-success"
      >
        {t.sidebarCtaWhatsapp}
        <span class="sr-only">{en.contact.newTabSr}</span>
      </a>
    </div>
  </aside>
</div>

<!-- Runtime config consumed by setupInquiryForm() in lib/forms/inquiry.ts -->
<script type="application/json" id="ih-config" set:html={JSON.stringify(formConfig)} />

{useHCaptcha && (
  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
)}

<script>
  import { setupInquiryForm } from '~/lib/forms/inquiry';
  setupInquiryForm();
</script>
