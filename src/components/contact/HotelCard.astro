---
/**
 * HotelCard — single hotel recommendation in Block 10.
 */

import en from '~/i18n/en.json';
import { fill } from '~/lib/interpolate';
import type { Hotel } from '~/config/company';

interface Props {
  hotel: Hotel;
}

const { hotel } = Astro.props;
const t = en.contact.hotels;

const stars = '★'.repeat(hotel.stars) + '☆'.repeat(5 - hotel.stars);
const distance = fill(t.kmTemplate, { km: String(hotel.distanceKm) });
const drive = fill(t.minTemplate, { min: String(hotel.driveTimeMinutes) });
---
<article class="flex h-full flex-col rounded-xl border border-neutral-200 bg-white p-6">
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="text-lg font-semibold text-neutral-900">{hotel.name}</h3>
    <span aria-label={`${hotel.stars} star`} class="text-sm text-brand-accent">
      {stars}
    </span>
  </div>
  <dl class="mt-3 grid grid-cols-2 gap-2 text-sm text-neutral-700">
    <div>
      <dt class="font-medium text-neutral-700">{t.distanceLabel}</dt>
      <dd>{distance}</dd>
    </div>
    <div>
      <dt class="font-medium text-neutral-700">{t.driveLabel}</dt>
      <dd>{drive}</dd>
    </div>
  </dl>
  <p class="mt-3 text-sm text-neutral-600">{hotel.description}</p>
  <div class="mt-auto pt-5 flex flex-wrap gap-2">
    {hotel.website && (
      <a
        href={hotel.website}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex flex-1 items-center justify-center rounded-md border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-800 transition-colors hover:border-brand-primary hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
      >
        {t.websiteButton}
        <span class="sr-only">{en.contact.newTabSr}</span>
      </a>
    )}
    <a
      href={hotel.mapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex flex-1 items-center justify-center rounded-md border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-800 transition-colors hover:border-brand-primary hover:text-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
    >
      {t.mapsButton}
      <span class="sr-only">{en.contact.newTabSr}</span>
    </a>
  </div>
</article>
