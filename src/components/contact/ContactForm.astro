---
/**
 * ContactForm — homepage Web3Forms inquiry form (progressive enhancement).
 *
 * Renders as a standard `<form action method="POST">` that works with JS
 * disabled: Web3Forms stores + emails the lead and redirects back to
 * `/?contact=sent#contact-success`, surfacing the page-level success block
 * (Tailwind `target:` modifier). So a no-JS submit is never lost.
 *
 * With JS, a small inline script enhances it:
 *   1. Pre-fills the hidden `intent` input from `?intent=` in the URL.
 *   2. Disables the native `redirect`, intercepts submit, and POSTs via
 *      `fetch` — showing the success state IN PLACE (CLAUDE.md UX: no
 *      thank-you redirect) and firing the `inquiry_submit` conversion
 *      ONLY on true success (`res.ok && payload.success !== false`), with
 *      product_category (grade), estimated_quantity_tons (numeric, from
 *      container choice), and destination_country.
 *   3. Fires `contact_form_field_focus` on each focused input.
 *
 * Honeypot: a hidden checkbox `botcheck` Web3Forms recognises and silently
 * drops on submit when ticked.
 */

import en from '~/i18n/en';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import { inquiryCountries } from '~/lib/data/countries';

const t = en.home.contact;
const tokens = companyTokens(company);

const formId = 'home-contact-form';
const successHash = 'contact-success';
const redirectUrl = `${company.siteUrl}/?contact=sent#${successHash}`;

const containerOptions = [
  { value: '20ft', label: t.fields.containerOptions['20ft'] },
  { value: '40ft', label: t.fields.containerOptions['40ft'] },
  { value: 'multi', label: t.fields.containerOptions.multi },
  { value: 'unsure', label: t.fields.containerOptions.unsure },
];

const gradeOptions = [
  { value: 'premium', label: t.fields.gradeOptions.premium },
  { value: 'super-premium', label: t.fields.gradeOptions['super-premium'] },
  { value: 'platinum', label: t.fields.gradeOptions.platinum },
  { value: 'mixed', label: t.fields.gradeOptions.mixed },
];

const privacyConsent = fill(t.fields.privacyConsentTemplate, tokens);
const submissionSubject = fill(t.submission.subjectTemplate, tokens);
const submissionFromName = fill(t.submission.fromNameTemplate, tokens);
const successBody = fill(t.successBody, tokens);

// Numeric tonnage per container choice for the inquiry_submit GA4 param
// (sourced from containerCapacity, never hardcoded). "2+ containers" /
// "Not sure yet" have no single tonnage, so the script omits the param.
const tons20 = Math.round(company.commercial.containerCapacity.ft20.fullKg / 1000);
const tons40 = Math.round(company.commercial.containerCapacity.ft40.fullKg / 1000);
---
<form
  id={formId}
  action={company.form.web3formsEndpoint}
  method="POST"
  data-contact-form
  class="grid gap-5"
>
  <input type="hidden" name="access_key" value={company.form.web3formsKey} />
  <input type="hidden" name="subject" value={submissionSubject} />
  <input type="hidden" name="from_name" value={submissionFromName} />
  <input type="hidden" name="redirect" value={redirectUrl} />
  <input type="hidden" name="intent" value="" data-intent-input />
  {/* Web3Forms honeypot — real users leave it unchecked. */}
  <input
    type="checkbox"
    name="botcheck"
    tabindex="-1"
    autocomplete="off"
    class="hidden"
    aria-hidden="true"
  />

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label for={`${formId}-name`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.name} <span aria-hidden="true" class="text-error">*</span>
      </label>
      <input
        id={`${formId}-name`}
        name="name"
        type="text"
        required
        autocomplete="name"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
    </div>
    <div>
      <label for={`${formId}-company`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.company} <span aria-hidden="true" class="text-error">*</span>
      </label>
      <input
        id={`${formId}-company`}
        name="company"
        type="text"
        required
        autocomplete="organization"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label for={`${formId}-email`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.email} <span aria-hidden="true" class="text-error">*</span>
      </label>
      <input
        id={`${formId}-email`}
        name="email"
        type="email"
        required
        autocomplete="email"
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      />
    </div>
    <div>
      <label for={`${formId}-country`} class="block text-sm font-semibold text-neutral-800">
        {t.fields.country} <span aria-hidden="true" class="text-error">*</span>
      </label>
      <select
        id={`${formId}-country`}
        name="country"
        required
        class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
      >
        <option value="">{t.fields.countryPlaceholder}</option>
        {inquiryCountries.map((c) => <option value={c}>{c}</option>)}
      </select>
    </div>
  </div>

  <div>
    <label for={`${formId}-whatsapp`} class="block text-sm font-semibold text-neutral-800">
      {t.fields.whatsapp}
    </label>
    <input
      id={`${formId}-whatsapp`}
      name="whatsapp"
      type="tel"
      autocomplete="tel"
      placeholder="+1 555 123 4567"
      class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
    />
  </div>

  <fieldset>
    <legend class="block text-sm font-semibold text-neutral-800">
      {t.fields.containers} <span aria-hidden="true" class="text-error">*</span>
    </legend>
    <div class="mt-2 grid grid-cols-2 gap-2 md:grid-cols-4">
      {containerOptions.map((opt, i) => (
        <label class="cursor-pointer">
          <input
            type="radio"
            name="containers"
            value={opt.value}
            required={i === 0}
            class="peer sr-only"
          />
          <span class="flex h-full items-center justify-center rounded-md border border-neutral-300 bg-white px-3 py-2 text-center text-sm font-medium text-neutral-700 transition-colors peer-checked:border-brand-primary peer-checked:bg-brand-primary/5 peer-checked:text-brand-primary peer-focus-visible:outline-none peer-focus-visible:ring-2 peer-focus-visible:ring-brand-primary peer-focus-visible:ring-offset-2">
            {opt.label}
          </span>
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset>
    <legend class="block text-sm font-semibold text-neutral-800">
      {t.fields.grade} <span aria-hidden="true" class="text-error">*</span>
    </legend>
    <div class="mt-2 grid grid-cols-2 gap-2 md:grid-cols-4">
      {gradeOptions.map((opt, i) => (
        <label class="cursor-pointer">
          <input
            type="radio"
            name="grade"
            value={opt.value}
            required={i === 0}
            class="peer sr-only"
          />
          <span class="flex h-full items-center justify-center rounded-md border border-neutral-300 bg-white px-3 py-2 text-center text-sm font-medium text-neutral-700 transition-colors peer-checked:border-brand-primary peer-checked:bg-brand-primary/5 peer-checked:text-brand-primary peer-focus-visible:outline-none peer-focus-visible:ring-2 peer-focus-visible:ring-brand-primary peer-focus-visible:ring-offset-2">
            {opt.label}
          </span>
        </label>
      ))}
    </div>
  </fieldset>

  <div>
    <label for={`${formId}-message`} class="block text-sm font-semibold text-neutral-800">
      {t.fields.message}
    </label>
    <textarea
      id={`${formId}-message`}
      name="message"
      rows="4"
      placeholder={t.fields.messagePlaceholder}
      class="mt-1 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm focus:border-brand-primary focus:outline-none focus:ring-1 focus:ring-brand-primary"
    ></textarea>
  </div>

  <div class="flex items-start gap-3">
    <input
      id={`${formId}-privacy`}
      name="privacy_consent"
      type="checkbox"
      value="yes"
      required
      class="mt-1 h-4 w-4 rounded border-neutral-300 text-brand-primary focus:ring-brand-primary"
    />
    <label for={`${formId}-privacy`} class="text-sm text-neutral-700">
      {privacyConsent}
    </label>
  </div>

  <div>
    <button
      id={`${formId}-submit`}
      type="submit"
      class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md bg-brand-primary px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-primary-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
    >
      <span data-submit-label>{t.fields.submit}</span>
      <span data-submitting-label class="hidden">{t.fields.submitting}</span>
    </button>
    <p
      id={`${formId}-error`}
      role="alert"
      aria-live="assertive"
      class="mt-3 hidden text-sm text-error"
    ></p>
  </div>
</form>

<div
  id={`${formId}-success`}
  role="status"
  aria-live="polite"
  tabindex="-1"
  class="mt-4 hidden rounded-xl border border-success bg-success/5 p-6 focus:outline-none"
>
  <h3 class="text-lg font-semibold text-neutral-900">{t.successHeading}</h3>
  <p class="mt-2 text-base text-neutral-700">{successBody}</p>
</div>

<script
  is:inline
  define:vars={{ formId, tons20, tons40, submitErrorMsg: t.fields.submitError }}
>
  (function () {
    var form = document.getElementById(formId);
    if (!form) return;

    // 1. Pre-fill the hidden `intent` input from URL ?intent=…
    try {
      var params = new URLSearchParams(location.search);
      var intent = params.get('intent') || '';
      if (intent) {
        var intentInput = form.querySelector('[data-intent-input]');
        if (intentInput) intentInput.value = intent;
      }
    } catch (_) {}

    // 2. Progressive enhancement: disable the native redirect and submit via
    //    fetch so success shows IN PLACE (CLAUDE.md UX — no thank-you redirect)
    //    and the inquiry_submit conversion fires ONLY on true success. With JS
    //    off this block never runs, the form keeps its `redirect` value, and
    //    Web3Forms redirects to #contact-success — so the lead is never lost.
    var redirectInput = form.querySelector('input[name="redirect"]');
    if (redirectInput) redirectInput.value = 'false';

    var submitBtn = document.getElementById(formId + '-submit');
    var submitLabel = submitBtn && submitBtn.querySelector('[data-submit-label]');
    var submittingLabel = submitBtn && submitBtn.querySelector('[data-submitting-label]');
    var errEl = document.getElementById(formId + '-error');
    var successEl = document.getElementById(formId + '-success');

    var setSubmitting = function (on) {
      if (submitBtn) submitBtn.disabled = on;
      if (submitLabel) submitLabel.classList.toggle('hidden', on);
      if (submittingLabel) submittingLabel.classList.toggle('hidden', !on);
    };

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (errEl) errEl.classList.add('hidden');
      if (!form.reportValidity()) return; // native validation messages

      setSubmitting(true);
      fetch(form.action, { method: 'POST', body: new FormData(form) })
        .then(function (res) {
          // fetch does NOT reject on 4xx/5xx — inspect the parsed body.
          return res.json().catch(function () { return {}; }).then(function (json) {
            if (!res.ok || (json && json.success === false)) throw new Error('submit_failed');
            return json;
          });
        })
        .then(function () {
          if (successEl) {
            successEl.classList.remove('hidden');
            try { successEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (_) {}
            try { successEl.focus(); } catch (_) {}
          }
          form.classList.add('hidden');

          // inquiry_submit conversion — fires ONLY here, on true success
          // (CLAUDE.md § Conversion Tracking). product_category = grade;
          // estimated_quantity_tons = numeric tons (omitted for 2+/unsure);
          // destination_country = full country name (kept readable site-wide).
          var grade = form.elements['grade'] ? form.elements['grade'].value : '';
          var containers = form.elements['containers'] ? form.elements['containers'].value : '';
          var country = form.elements['country'] ? form.elements['country'].value : '';
          var payload = {
            product_category: grade,
            destination_country: country,
            source_component: 'home-contact-form',
          };
          var tons = containers === '20ft' ? tons20 : containers === '40ft' ? tons40 : null;
          if (tons != null) payload.estimated_quantity_tons = tons;
          try { window.gtag && window.gtag('event', 'inquiry_submit', payload); } catch (_) {}
          try { window.fbq && window.fbq('trackCustom', 'inquiry_submit', payload); } catch (_) {}
          try { if (window.dataLayer) window.dataLayer.push(Object.assign({ event: 'inquiry_submit' }, payload)); } catch (_) {}
        })
        .catch(function () {
          setSubmitting(false);
          if (errEl) { errEl.textContent = submitErrorMsg; errEl.classList.remove('hidden'); }
        });
    });

    // 3. contact_form_field_focus event on each focused input.
    form.addEventListener('focusin', function (e) {
      var target = e.target;
      if (!target || !target.name) return;
      // Skip hidden Web3Forms fields and the honeypot.
      if (target.type === 'hidden' || target.name === 'botcheck' || target.name === 'access_key' || target.name === 'subject' || target.name === 'from_name' || target.name === 'redirect' || target.name === 'intent') return;
      var payload = { field: target.name, section: 'contact', source: 'home-contact-form', locale: document.documentElement.lang || 'en', viewport: window.innerWidth + 'x' + window.innerHeight, url: location.pathname };
      try { window.gtag && window.gtag('event', 'contact_form_field_focus', payload); } catch (_) {}
      try { window.fbq && window.fbq('trackCustom', 'contact_form_field_focus', payload); } catch (_) {}
    }, true);
  })();
</script>
