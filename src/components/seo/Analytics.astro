---
/**
 * Analytics — GA4 + Meta Pixel + sitewide click dispatcher.
 *
 * Both SDKs are gated to production builds. Pixel is additionally gated
 * on a real numeric ID so dev/preview ship zero Pixel traffic until the
 * production ID lands in `company.analytics.pixelId`.
 *
 * The delegated click listener fires once per click on any element with
 * a `[data-event]` attribute, dispatching the same event name to BOTH
 * gtag and fbq with a normalised payload. Comma-separated names dispatch
 * as multiple events (used when one click is meaningful in two analytics
 * dimensions, e.g. samples_request + whatsapp_click).
 *
 * Total wire weight when active: ~0.6 KB gz (excluding the GA4 + Pixel
 * SDK loads, which are async).
 */

import { company } from '~/config/company';
import { hasFact } from '~/config/company';

const { gaId, gscVerification, pixelId } = company.analytics;
const isProd = import.meta.env.PROD;
const pixelActive = isProd && hasFact(pixelId);
---
<meta name="google-site-verification" content={gscVerification} />

{isProd && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

{pixelActive && (
  <script is:inline define:vars={{ pixelId }}>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', pixelId);
    fbq('track', 'PageView');
  </script>
)}

<script is:inline define:vars={{ debug: !isProd }}>
  /* Sitewide [data-event] click dispatcher + scroll/engaged observers.
     Registered on EVERY build (not just prod) so event wiring is verifiable
     on preview deploys: the gtag/fbq calls no-op when the SDKs are absent
     (they are prod-only), and `debug` console-logs each event off-prod.
     Comma-separated data-event names dispatch as multiple events; any
     data-param-* on the clicked element is forwarded onto the payload.
     Payload keys follow CLAUDE.md § Conversion Tracking (source_page,
     source_component). */
  var emit = function (name, payload) {
    if (debug && window.console) console.debug('[analytics]', name, payload);
    try { window.gtag && window.gtag('event', name, payload); } catch (_) {}
    try { window.fbq && window.fbq('trackCustom', name, payload); } catch (_) {}
  };

  document.addEventListener('click', function (e) {
    var el = e.target instanceof Element ? e.target.closest('[data-event]') : null;
    if (!el) return;
    var raw = el.getAttribute('data-event');
    if (!raw) return;
    var payload = {
      source_component: el.getAttribute('data-source-component') || '',
      source_page: location.pathname,
      locale: document.documentElement.lang || 'en',
      viewport: window.innerWidth + 'x' + window.innerHeight,
    };
    for (var i = 0; i < el.attributes.length; i++) {
      var attr = el.attributes[i];
      if (attr.name.indexOf('data-param-') === 0) {
        var key = attr.name.slice('data-param-'.length).replace(/-/g, '_');
        payload[key] = attr.value;
      }
    }
    raw.split(',').forEach(function (name) {
      name = name.trim();
      if (name) emit(name, payload);
    });
  }, { passive: true });

  /* scroll_75 — fires once when the user passes 75% of the document.
     engaged_time — fires once after 60s of active (visible) page time.
     Both are CLAUDE.md § Conversion Tracking events. */
  (function () {
    var basePayload = function () {
      return {
        source_page: location.pathname,
        locale: document.documentElement.lang || 'en',
        viewport: window.innerWidth + 'x' + window.innerHeight,
      };
    };
    var dispatch = function (name, extra) {
      var payload = basePayload();
      if (extra) for (var k in extra) payload[k] = extra[k];
      emit(name, payload);
    };

    var scrollFired = false;
    var onScroll = function () {
      if (scrollFired) return;
      var doc = document.documentElement;
      var total = doc.scrollHeight - doc.clientHeight;
      if (total <= 0) return;
      if (window.scrollY / total >= 0.75) {
        scrollFired = true;
        dispatch('scroll_75');
        window.removeEventListener('scroll', onScroll);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    var activeMs = 0;
    var lastTick = performance.now();
    var engagedFired = false;
    var interval = window.setInterval(function () {
      if (engagedFired) return;
      if (document.visibilityState === 'visible') {
        var now = performance.now();
        activeMs += now - lastTick;
        lastTick = now;
        if (activeMs >= 60000) {
          engagedFired = true;
          dispatch('engaged_time', { seconds: 60 });
          window.clearInterval(interval);
        }
      } else {
        lastTick = performance.now();
      }
    }, 1000);
  })();
</script>
