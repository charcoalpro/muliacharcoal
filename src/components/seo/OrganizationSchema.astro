---
import JsonLd from './JsonLd.astro';
import { company } from '~/config/company';

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

// schema.org `sameAs` expects only live URLs — drop nulls from social profiles.
const sameAs = Object.values(company.social).filter(
  (url): url is string => typeof url === 'string' && url.length > 0,
);

const data = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteBase}/#organization`,
      name: company.brand,
      legalName: company.legalName,
      url: siteBase,
      foundingDate: String(company.foundingYear),
      logo: {
        '@type': 'ImageObject',
        url: `${siteBase}/logo.png`,
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: `${company.address.street}, ${company.address.district}`,
        addressLocality: company.address.city,
        addressRegion: company.address.region,
        postalCode: company.address.postalCode,
        addressCountry: company.address.countryCode,
      },
      email: company.email,
      telephone: company.phone.display,
      sameAs,
    },
    {
      '@type': 'WebSite',
      '@id': `${siteBase}/#website`,
      url: siteBase,
      name: company.brand,
      publisher: { '@id': `${siteBase}/#organization` },
      inLanguage: 'en',
    },
  ],
};
---
<JsonLd data={data} />
