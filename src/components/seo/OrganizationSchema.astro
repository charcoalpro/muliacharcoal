---
/**
 * OrganizationSchema — emits the sitewide Organization + WebSite graph.
 *
 * Pulls the canonical Organization node from `src/lib/schema/organization.ts`
 * so the same fields populate the homepage, About page, and LocalBusiness
 * `sameAs` filter. The About page passes its own richer Organization node
 * via `BaseLayout.schema={...}` and sets `includeOrgSchema={false}` to
 * avoid emitting two Organization graphs on one page.
 */
import JsonLd from './JsonLd.astro';
import { buildOrganization, buildWebSite } from '~/lib/schema/organization';

const data = {
  '@context': 'https://schema.org',
  '@graph': [buildOrganization({ mode: 'slim' }), buildWebSite()],
};
---
<JsonLd data={data} />
