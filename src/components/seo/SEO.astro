---
import { company } from '~/config/company';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  locale?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  locale = 'en_US',
  noIndex = false,
} = Astro.props;

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

const canonical = `${siteBase}${normalizePath(path)}` || siteBase;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteBase}${image}`)
  : null;

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

// Strip any active language prefix from the current path so we can
// re-prepend each active language's prefix for hreflang. Lets pages
// pass either the neutral path ("/contact") or a localized one
// ("/ar/contact") and still get correct alternate URLs for every
// active language.
const normalizedPath = normalizePath(path);
const stripPrefix = company.activeLanguages.reduce<string>((acc, lang) => {
  if (lang.pathPrefix && (normalizedPath === lang.pathPrefix || normalizedPath.startsWith(lang.pathPrefix + '/'))) {
    return normalizedPath.slice(lang.pathPrefix.length);
  }
  return acc;
}, normalizedPath);
const neutralPath = stripPrefix || '';

const defaultLang = company.activeLanguages.find((l) => l.pathPrefix === '') ?? company.activeLanguages[0];
const xDefaultHref = `${siteBase}${defaultLang.pathPrefix}${neutralPath}` || siteBase;
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={company.brand} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{company.activeLanguages.map((lang) => (
  <link rel="alternate" hreflang={lang.code} href={`${siteBase}${lang.pathPrefix}${neutralPath}` || siteBase} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />
