---
import { company } from '~/config/company';
import { activeLanguages, defaultLanguage } from '~/config/site';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  locale?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image = company.brandAssets.ogImage,
  type = 'website',
  locale = defaultLanguage.locale,
  noIndex = false,
} = Astro.props;

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

const canonical = `${siteBase}${normalizePath(path)}` || siteBase;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteBase}${image}`)
  : null;

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

// Dev-only length guard. CLAUDE.md § SEO Requirements caps title at 60
// chars and meta description at 160 chars to avoid SERP truncation. We
// warn during `astro dev` instead of failing the build so authors see
// the issue without breaking iteration.
if (import.meta.env.DEV) {
  if (fullTitle.length > 60) {
    console.warn(
      `[SEO] Title exceeds 60 chars (${fullTitle.length}) on ${canonical}: "${fullTitle}"`,
    );
  }
  if (description.length > 160) {
    console.warn(
      `[SEO] Description exceeds 160 chars (${description.length}) on ${canonical}: "${description}"`,
    );
  }
}

// Build a hreflang entry per currently active site language. `path` is
// the language-agnostic path (e.g. "/contact") — each language's
// pathPrefix is prepended to produce the localized URL.
const normalizedPath = normalizePath(path);
const hreflangs = activeLanguages.map((lang) => ({
  code: lang.code,
  href: `${siteBase}${lang.pathPrefix}${normalizedPath}`,
}));
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={company.brand} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{hreflangs.map((lang) => (
  <link rel="alternate" hreflang={lang.code} href={lang.href} />
))}
<link rel="alternate" hreflang="x-default" href={canonical} />
