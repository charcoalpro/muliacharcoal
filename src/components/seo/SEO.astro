---
import { company } from '~/config/company';
import {
  DEFAULT_LOCALE,
  LOCALES,
  getActiveLocales,
  localizePath,
  type LocaleCode,
} from '~/i18n/locales';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  /** Locale of the current page. Drives `og:locale` and the hreflang loop. */
  lang?: LocaleCode;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  lang = DEFAULT_LOCALE,
  noIndex = false,
} = Astro.props;

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

const canonical = `${siteBase}${normalizePath(path)}` || siteBase;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteBase}${image}`)
  : null;

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

// hreflang: emit one alternate per active locale, plus x-default pointing at
// the English canonical. The English path is used as the source path for
// every locale because translated pages live at the same logical path
// under their language prefix (e.g. /de/about).
const englishPath = normalizePath(path);
const activeLocales = getActiveLocales();
const ogLocale = LOCALES[lang].ogLocale;
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={company.brand} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{activeLocales.map((locale) => (
  <link
    rel="alternate"
    hreflang={locale.bcp47}
    href={`${siteBase}${localizePath(englishPath, locale.code)}`}
  />
))}
<link rel="alternate" hreflang="x-default" href={`${siteBase}${englishPath}`} />
