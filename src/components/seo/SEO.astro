---
import { company } from '~/config/company';
import {
  languages,
  defaultLang,
  getLanguage,
  pathWithLang,
  pathWithoutLang,
  type LangCode,
} from '~/i18n/languages';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  lang?: LangCode | string;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  lang = defaultLang,
  noIndex = false,
} = Astro.props;

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

// Path stripped of any language prefix — the canonical "logical" path
// each locale maps onto. We rebuild per-locale URLs from this.
const logicalPath = pathWithoutLang(path);

const canonical = `${siteBase}${normalizePath(path)}` || siteBase;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteBase}${image}`)
  : null;

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

const ogLocale = getLanguage(lang).ogLocale;

// hreflang URLs for every configured locale plus an x-default that points
// to the default-language version. Adding a locale to the registry
// automatically adds it here.
const xDefaultHref = `${siteBase}${normalizePath(pathWithLang(logicalPath, defaultLang))}` || siteBase;
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={company.brand} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{languages.map((l) => {
  const href = `${siteBase}${normalizePath(pathWithLang(logicalPath, l.code))}` || siteBase;
  return <link rel="alternate" hreflang={l.code} href={href} />;
})}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />
