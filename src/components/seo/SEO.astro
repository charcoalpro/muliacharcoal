---
import type { ImageMetadata } from 'astro';
import { company } from '~/config/company';
import {
  ACTIVE_LOCALES,
  DEFAULT_LOCALE,
  localeOgMap,
  localePath,
  type Locale,
} from '~/config/i18n';
import { resolveOgImage } from '~/lib/images/ogImage';

interface Props {
  title: string;
  description: string;
  path?: string;
  /**
   * Page social card. Pass an Astro `import` for processed assets, a
   * public-folder string (e.g. `/og/products.jpg`), or omit to fall
   * back to `company.brandAssets.images.ogDefault`.
   */
  image?: ImageMetadata | string;
  type?: 'website' | 'article' | 'product';
  locale?: Locale;
  noIndex?: boolean;
  /**
   * Robots directive override. Defaults to deriving from `noIndex`
   * (`noindex, nofollow` for 404 / dev). Pass `'noindex-follow'` for a
   * thin-content page (substance floor) that should be de-indexed but still
   * pass internal-link equity onward.
   */
  robots?: 'index' | 'noindex' | 'noindex-follow';
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  locale = DEFAULT_LOCALE,
  noIndex = false,
  robots,
} = Astro.props;

// Effective robots directive — explicit `robots` wins; otherwise derive from
// `noIndex` so existing callers (404, dev) keep their `noindex, nofollow`.
const robotsDirective = robots ?? (noIndex ? 'noindex' : 'index');
const isIndexable = robotsDirective === 'index';

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

const canonical = `${siteBase}${normalizePath(path)}`;
// resolveOgImage always returns an absolute URL — falls back to
// brandAssets.images.ogDefault so every page ships a non-empty card.
const ogImage = resolveOgImage(image, Astro.site);

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;
const ogLocale = localeOgMap[locale];
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
{/* Canonical + hreflang only matter for indexable URLs — a noindex page
    (404, dev) should not advertise itself as a canonical target. */}
{isIndexable && <link rel="canonical" href={canonical} />}
{robotsDirective === 'index'
  ? <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  : robotsDirective === 'noindex-follow'
    ? <meta name="robots" content="noindex, follow" />
    : <meta name="robots" content="noindex, nofollow" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={company.brand} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={fullTitle} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={fullTitle} />

{isIndexable && (
  <Fragment>
    {ACTIVE_LOCALES.map((code) => (
      <link
        rel="alternate"
        hreflang={code}
        href={`${siteBase}${normalizePath(localePath(code, path))}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={canonical} />
  </Fragment>
)}
