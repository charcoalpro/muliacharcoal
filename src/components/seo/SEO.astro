---
import type { ImageMetadata } from 'astro';
import { company } from '~/config/company';
import { absoluteUrl } from '~/lib/url';
import {
  locales,
  defaultLocale,
  stripLocalePrefix,
  withLocalePrefix,
} from '~/i18n/locales';
import { resolveOgImage } from '~/lib/images/ogImage';

interface Props {
  title: string;
  description: string;
  path?: string;
  /**
   * Page-specific social card. Pass an Astro `import` for processed
   * assets, a public-folder string (e.g. `/og/products.jpg`), or omit
   * to fall back to `company.brandAssets.images.ogDefault`.
   */
  image?: ImageMetadata | string;
  type?: 'website' | 'article' | 'product';
  /** Override Open Graph locale (defaults to the default locale's `ogLocale`). */
  locale?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  locale = defaultLocale.ogLocale,
  noIndex = false,
} = Astro.props;

const canonical = absoluteUrl(path, Astro.site);
// `resolveOgImage` always returns an absolute URL — the brand-default
// fallback guarantees every page emits a non-empty og:image even
// before per-page social cards are designed.
const ogImage = resolveOgImage(image, Astro.site);

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

// Hreflang alternates — one per shipped locale + an `x-default` pointing at
// the default-locale URL. `stripLocalePrefix` first to recover the locale-
// agnostic path, then prepend each locale's prefix to build the alternate.
const basePath = stripLocalePrefix(path);
const defaultLocaleUrl = absoluteUrl(withLocalePrefix(basePath, defaultLocale), Astro.site);
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={company.brand} />
<meta property="og:image" content={ogImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{locales.map((l) => (
  <link
    rel="alternate"
    hreflang={l.code}
    href={absoluteUrl(withLocalePrefix(basePath, l), Astro.site)}
  />
))}
<link rel="alternate" hreflang="x-default" href={defaultLocaleUrl} />
