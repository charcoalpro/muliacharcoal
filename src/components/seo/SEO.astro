---
import { company } from '~/config/company';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  locale?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  image,
  type = 'website',
  locale = 'en_US',
  noIndex = false,
} = Astro.props;

const siteBase = (Astro.site?.toString() ?? company.siteUrl).replace(/\/$/, '');

const normalizePath = (p: string) => {
  if (p === '/' || p === '') return '';
  return '/' + p.replace(/^\/+/, '').replace(/\/+$/, '');
};

const canonical = `${siteBase}${normalizePath(path)}` || siteBase;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteBase}${image}`)
  : null;

const fullTitle = title.includes(company.brand) ? title : `${title} | ${company.brand}`;

// One <link rel="alternate" hreflang="…"> per active site locale.
// English versions live at the root (`/about`); other languages are
// URL-prefixed (`/ar/about`, `/de/about`, …) per CLAUDE.md.
const localizedPath = (locale: string, basePath: string): string => {
  if (locale === company.languages.defaultLocale) return basePath;
  const clean = basePath.replace(/^\/+/, '').replace(/\/+$/, '');
  return clean ? `/${locale}/${clean}` : `/${locale}`;
};

const languages = company.languages.siteLocales.map((code) => ({
  code,
  path: localizedPath(code, path),
}));
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={company.brand} />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{languages.map((lang) => (
  <link rel="alternate" hreflang={lang.code} href={`${siteBase}${normalizePath(lang.path)}`} />
))}
<link rel="alternate" hreflang="x-default" href={canonical} />
