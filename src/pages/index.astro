---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import en from '~/i18n/en.json';
import { company, moqLabel, portOfLoadingLabel, leadTimeLabel } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';

const tokens = companyTokens(company);
const title = `${company.brand} — ${company.tagline}`;
const description = fill(en.hero.descriptionTemplate, tokens);
const heroSubtitle = fill(en.hero.subtitleTemplate, tokens);
---
<BaseLayout
  title={title}
  description={description}
  path="/"
  type="website"
  includeOrgSchema
>
  <HeroSection
    eyebrow={en.hero.eyebrow}
    title={en.hero.title}
    subtitle={heroSubtitle}
    variant="dark"
    align="start"
    primaryCta={{
      label: en.cta.inquire,
      href: '/contact',
      dataEvent: 'inquiry_cta_click',
      dataSourceComponent: 'home-hero',
    }}
    secondaryCta={{
      label: en.cta.viewProducts,
      href: '/products',
      dataSourceComponent: 'home-hero',
    }}
  />

  <section aria-label="Trust signals" class="border-b border-neutral-200 bg-neutral-50">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-8 sm:grid-cols-3 md:px-8">
      <div class="text-sm">
        <p class="text-xs uppercase tracking-wide text-neutral-500">{en.hero.trust.moqLabel}</p>
        <p class="mt-1 font-semibold text-neutral-900">{moqLabel()}</p>
      </div>
      <div class="text-sm">
        <p class="text-xs uppercase tracking-wide text-neutral-500">{en.hero.trust.portLabel}</p>
        <p class="mt-1 font-semibold text-neutral-900">{portOfLoadingLabel()}</p>
      </div>
      <div class="text-sm">
        <p class="text-xs uppercase tracking-wide text-neutral-500">{en.hero.trust.leadLabel}</p>
        <p class="mt-1 font-semibold text-neutral-900">{leadTimeLabel()}</p>
      </div>
    </div>
  </section>
</BaseLayout>
