---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import TrustStrip from '~/components/sections/TrustStrip.astro';
import Products from '~/components/sections/Products.astro';
import Specifications from '~/components/sections/Specifications.astro';
import AboutUs from '~/components/sections/About.astro';
import OEMPackaging from '~/components/sections/OemPackaging.astro';
import Gallery from '~/components/home/blocks/Gallery.astro';
import Contact from '~/components/home/blocks/Contact.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import en from '~/i18n/en.json';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import { buildHomepageGraph } from '~/lib/schema/homepage';

const tokens = companyTokens(company);
const title = fill(en.home.meta.titleTemplate, tokens);
const description = fill(en.home.meta.descriptionTemplate, tokens);
const schema = buildHomepageGraph();

// Resolve FAQ items with token interpolation so {{moqLabel}}, {{port}}
// etc. expand at build time. The schema graph already runs the same
// substitution against the raw strings.
const faqItems = en.home.faq.items.map((item) => ({
  q: fill(item.q, tokens),
  a: fill(item.a, tokens),
}));
---
<BaseLayout
  title={title}
  description={description}
  path="/"
  type="website"
  schema={schema}
  prefetch={['/products', '/contact', '/about']}
>
  <Hero />
  <TrustStrip />
  <Products />
  <Specifications />
  <AboutUs />
  <OEMPackaging />
  <Gallery />
  <Contact />
  <section aria-labelledby="home-faq-title" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
      <FAQSection heading={en.home.faq.heading} items={faqItems} id="home-faq-title" />
    </div>
  </section>
  <CTABanner />
</BaseLayout>
