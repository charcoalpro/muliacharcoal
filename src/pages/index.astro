---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomeHero from '~/components/home/blocks/HomeHero.astro';
import TrustStrip from '~/components/home/blocks/TrustStrip.astro';
import Products from '~/components/home/blocks/Products.astro';
import Specifications from '~/components/home/blocks/Specifications.astro';
import AboutUs from '~/components/home/blocks/About.astro';
import OEMPackaging from '~/components/home/blocks/OemPackaging.astro';
import Gallery from '~/components/home/blocks/Gallery.astro';
import MarketsServed from '~/components/home/blocks/MarketsServed.astro';
import Contact from '~/components/home/blocks/Contact.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import HomeFinalCta from '~/components/home/blocks/HomeFinalCta.astro';
import en from '~/i18n/en';
import { company } from '~/config/company';
import { fill, companyTokens } from '~/lib/interpolate';
import { buildHomepageGraph } from '~/lib/schema/homepage';

const tokens = companyTokens(company);
const title = fill(en.home.meta.titleTemplate, tokens);
const description = fill(en.home.meta.descriptionTemplate, tokens);
const schema = buildHomepageGraph();

// Resolve FAQ items with token interpolation so {{moqLabel}}, {{port}}
// etc. expand at build time. The schema graph already runs the same
// substitution against the raw strings.
const faqItems = en.home.faq.items.map((item) => ({
  q: fill(item.q, tokens),
  a: fill(item.a, tokens),
}));
---
<BaseLayout
  title={title}
  description={description}
  path="/"
  type="website"
  schema={schema}
  prefetch={['/products', '/contact', '/about']}
>
  <HomeHero />
  <TrustStrip />
  <Products />
  <Specifications />
  <AboutUs />
  <OEMPackaging />
  <Gallery />
  <MarketsServed />
  <Contact />
  <section aria-labelledby="home-faq-title" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-20">
      <FAQSection heading={en.home.faq.heading} items={faqItems} id="home-faq-title" />
      <p class="mx-auto mt-6 max-w-3xl text-sm">
        <a
          href={en.home.faqTeaser.href}
          class="font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
          data-source-component="home-faq-teaser"
        >
          {en.home.faqTeaser.label} <span aria-hidden="true">→</span>
        </a>
      </p>
      <p class="mx-auto mt-3 max-w-3xl text-sm">
        <a
          href={en.home.guideTeaser.href}
          class="font-semibold text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
          data-source-component="home-guide-teaser"
        >
          {en.home.guideTeaser.label} <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </section>
  <HomeFinalCta />
</BaseLayout>
