---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/cta/Button.astro';
import en from '~/i18n/en.json';
---
<BaseLayout
  title={en.notFound.title}
  description={en.notFound.description}
  path="/404"
  noIndex
>
  <section class="mx-auto max-w-4xl px-4 py-24 text-center md:px-8 md:py-32">
    <p class="text-sm font-medium uppercase tracking-wide text-neutral-500">
      {en.notFound.code}
    </p>
    <h1 class="mt-3 text-3xl font-bold text-neutral-900 md:text-4xl">
      {en.notFound.title}
    </h1>
    <p class="mt-4 text-lg text-neutral-600">
      {en.notFound.description}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="/" variant="primary">
        {en.cta.backHome}
      </Button>
      <Button href="/products" variant="secondary">
        {en.cta.viewProducts}
      </Button>
    </div>
  </section>
</BaseLayout>
