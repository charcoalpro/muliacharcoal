---
import BaseLayout from '~/layouts/BaseLayout.astro';
import en from '~/i18n/en.json';
---
<BaseLayout
  title={en.notFound.title}
  description={en.notFound.description}
  path="/404"
  noIndex
>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center">
    <p class="text-sm font-medium uppercase tracking-wide text-slate-500">
      {en.notFound.code}
    </p>
    <h1 class="mt-3 text-3xl font-semibold text-slate-900 md:text-4xl">
      {en.notFound.title}
    </h1>
    <p class="mt-4 text-lg text-slate-600">
      {en.notFound.description}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white hover:bg-brand/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        {en.cta.backHome}
      </a>
      <a
        href="/products"
        class="inline-flex items-center rounded-md border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        {en.cta.viewProducts}
      </a>
    </div>
  </section>
</BaseLayout>
