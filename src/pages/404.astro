---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/cta/Button.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import { footerOperationsNav } from '~/config/nav';
import en from '~/i18n/en';
---
<BaseLayout
  title={en.notFound.title}
  description={en.notFound.description}
  path="/404"
  noIndex
>
  <section class="mx-auto max-w-4xl px-4 py-24 text-center md:px-8 md:py-32">
    <p class="text-sm font-medium uppercase tracking-wide text-neutral-600">
      {en.notFound.code}
    </p>
    <h1 class="mt-3 text-3xl font-bold text-neutral-900 md:text-4xl">
      {en.notFound.title}
    </h1>
    <p class="mt-4 text-lg text-neutral-600">
      {en.notFound.description}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="/" variant="primary">
        {en.cta.backHome}
      </Button>
      <Button href="/products" variant="secondary">
        {en.cta.viewProducts}
      </Button>
    </div>

    <nav aria-label={en.notFound.popularHeading} class="mt-12">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-600">
        {en.notFound.popularHeading}
      </h2>
      <ul class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        {footerOperationsNav.map((item) => (
          <li>
            <a
              href={item.href}
              class="font-medium text-brand-primary underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="mt-10 flex justify-center">
      <WhatsAppButton context="contact" />
    </div>
  </section>
</BaseLayout>
