---
/**
 * /contact — eleven-block contact page.
 *
 * Each block lives in its own component under `src/components/contact/blocks/`.
 * This file is purely composition: SEO meta + LocalBusiness schema + the
 * eleven blocks in display order. Block-level data assembly (channel
 * filtering, hotel tiering, trust-strip building, etc.) happens inside
 * each block component.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ExternalLink from '~/components/content/ExternalLink.astro';
import InquiryForm from '~/components/contact/InquiryForm.astro';
import MapEmbed from '~/components/contact/MapEmbed.astro';
import Section from '~/components/layout/Section.astro';
import SectionHeading from '~/components/content/SectionHeading.astro';
import TrustStrip from '~/components/contact/blocks/TrustStrip.astro';
import WhatsAppPrimary from '~/components/contact/blocks/WhatsAppPrimary.astro';
import SalesTeam from '~/components/contact/blocks/SalesTeam.astro';
import ChannelGrid from '~/components/contact/blocks/ChannelGrid.astro';
import FindUs from '~/components/contact/blocks/FindUs.astro';
import Hours from '~/components/contact/blocks/Hours.astro';
import Hotels from '~/components/contact/blocks/Hotels.astro';
import Payment from '~/components/contact/blocks/Payment.astro';
import en from '~/i18n/en';
import { fill } from '~/lib/interpolate';
import { company, mailto, waLinkFor } from '~/config/company';
import { localBusinessSchema } from '~/lib/schema/localBusiness';

const t = en.contact;

const heroWaHref = waLinkFor('heroCta');
const heroEmailHref = mailto('Wholesale inquiry');

const addr = company.address;
---
<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
  path="/contact"
  type="website"
  includeOrgSchema={true}
  schema={localBusinessSchema}
>
  <!-- Breadcrumbs (also emits BreadcrumbList JSON-LD) -->
  <div class="border-b border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-7xl px-4 py-4 md:px-8">
      <Breadcrumbs items={[{ label: t.breadcrumb }]} />
    </div>
  </div>

  <!-- Block 1 — Hero -->
  <HeroSection
    title={t.hero.title}
    subtitle={t.hero.subtitle}
    primaryCta={{
      label: t.hero.ctaWhatsapp,
      href: heroWaHref,
      ariaLabel: t.hero.ctaWhatsappAria,
      target: '_blank',
      rel: 'noopener noreferrer',
      dataEvent: 'whatsapp_click',
      dataSourceComponent: 'hero',
    }}
    secondaryCta={{
      label: t.hero.ctaEmail,
      href: heroEmailHref,
      ariaLabel: t.hero.ctaEmailAria,
    }}
  >
    <p class="mt-6 text-sm text-neutral-600">{t.hero.microcopy}</p>
  </HeroSection>

  <!-- Block 2 — Trust strip -->
  <TrustStrip />

  <!-- Block 3 — WhatsApp primary -->
  <WhatsAppPrimary />

  <!-- Block 4 — Sales team -->
  <SalesTeam />

  <!-- Block 5 — All contact channels -->
  <ChannelGrid />

  <!-- Block 6 — Inquiry form -->
  <Section id="inquiry" labelledBy="form-heading" class="bg-neutral-50">
    <SectionHeading id="form-heading" title={t.form.heading} subtitle={t.form.lead} />
    <div class="mt-10">
      <InquiryForm />
    </div>
  </Section>

  <!-- Block 7 — Find us -->
  <FindUs />

  <!-- Block 8 — Hours & holidays -->
  <Hours />

  <!-- Block 9 — Map -->
  <Section labelledBy="map-heading" class="bg-white">
    <SectionHeading id="map-heading" title={t.map.heading} />
    <div class="mt-6">
      <MapEmbed
        latitude={addr.latitude}
        longitude={addr.longitude}
        title={t.map.iframeTitle}
      />
    </div>
    <p class="mt-3 text-sm text-neutral-600">
      {fill(t.map.captionTemplate, { addressShort: addr.short })}{' '}
      <ExternalLink href={company.googleMapsUrl}>
        {t.map.openInGoogleMaps}
      </ExternalLink>
    </p>
  </Section>

  <!-- Block 10 — Hotels -->
  <Hotels />

  <!-- Block 11 — Banking (public) -->
  <Payment />
</BaseLayout>
