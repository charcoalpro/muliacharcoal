---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import TrustBadge from '~/components/contact/TrustBadge.astro';
import TeamCard from '~/components/contact/TeamCard.astro';
import ChannelCard from '~/components/contact/ChannelCard.astro';
import InquiryForm from '~/components/contact/InquiryForm.astro';
import FindUsBlock from '~/components/contact/FindUsBlock.astro';
import HoursBlock from '~/components/contact/HoursBlock.astro';
import MapBlock from '~/components/contact/MapBlock.astro';
import HotelsBlock from '~/components/contact/HotelsBlock.astro';
import PaymentBlock from '~/components/contact/PaymentBlock.astro';
import en from '~/i18n/en.json';
import { fill } from '~/lib/interpolate';
import {
  company,
  waLinkFor,
  mailto,
  yearsInBusiness,
} from '~/config/company';
import { localBusinessSchema } from '~/lib/schema/localBusiness';

const t = en.contact;

// Token dictionary for `fill()` substitutions on this page. Keep in sync with
// the {{tokens}} that appear in `t.*Template` strings used here. Per-block
// templates resolve their own tokens inside the extracted block components.
const tokens = {
  legalName: company.legalName,
  city: company.address.city,
  country: company.address.country,
};

// ---------------------------------------------------------------------------
// Block 1 — Hero CTAs
// ---------------------------------------------------------------------------
const heroWaHref = waLinkFor('heroCta');
const heroEmailHref = mailto('Wholesale inquiry');

// ---------------------------------------------------------------------------
// Block 2 — Trust strip data (only render badges with verified facts)
// ---------------------------------------------------------------------------
const years = yearsInBusiness();
const trustItems = [
  {
    iconText: '★',
    label: t.trust.exportingSinceTemplate.replace('{{year}}', String(company.foundingYear)),
    value: fill(t.trust.yearsLabelTemplate, { years: String(years) }),
  },
  {
    iconText: '§',
    label: t.trust.legalLabel,
    value: company.legalName,
  },
  {
    iconText: 'N',
    label: t.trust.nibLabel,
    value: company.registration.nib,
  },
  {
    iconText: 'T',
    label: t.trust.npwpLabel,
    value: company.registration.taxId,
  },
  {
    iconText: '✓',
    label: t.trust.isoLabel,
    value: `Audited by ${company.certifications.iso9001.auditors.join(' & ')}`,
  },
  {
    iconText: '⚓',
    label: t.trust.imdgLabel,
    value: company.certifications.imdg.classDescription,
  },
  {
    iconText: '◉',
    label: t.trust.directorLabel,
    value: company.people.owner.name,
  },
];

// ---------------------------------------------------------------------------
// Block 5 — Channels (only render those with real handles set)
// ---------------------------------------------------------------------------
const phoneE164 = company.phone.e164;
const phoneDisplay = company.phone.display;
const baseChannels: Array<{ channel: string; handle: string; href: string; iconText?: string; ctaLabel?: string }> = [
  {
    channel: 'WhatsApp chat',
    handle: phoneDisplay,
    href: waLinkFor('salesGeneral'),
    iconText: '💬',
  },
  {
    channel: 'WhatsApp voice call',
    handle: phoneDisplay,
    href: waLinkFor('salesGeneral'),
    iconText: '📞',
  },
  {
    channel: 'WhatsApp video call',
    handle: phoneDisplay,
    href: waLinkFor('videoCallRequest'),
    iconText: '🎥',
  },
  {
    channel: 'Direct phone call',
    handle: phoneDisplay,
    href: `tel:${phoneE164}`,
    iconText: '☎',
  },
  {
    channel: 'SMS',
    handle: phoneDisplay,
    href: `sms:${phoneE164}`,
    iconText: '✉',
  },
  {
    channel: 'Email',
    handle: company.email,
    href: mailto('Wholesale inquiry'),
    iconText: '@',
  },
  {
    channel: 'Inquiry form',
    handle: t.channels.anchorButton,
    href: '#inquiry',
    iconText: '📝',
    ctaLabel: t.channels.anchorButton,
  },
];

const c = company.channels;
const optionalChannels: Array<{ channel: string; handle: string; href: string; iconText?: string }> = [];
if (c.zoom?.schedulingUrl) {
  optionalChannels.push({
    channel: 'Zoom / Google Meet',
    handle: t.channels.videoMeetingLabel,
    href: c.zoom.schedulingUrl,
    iconText: '🎦',
  });
}
if (c.wechat?.id) {
  optionalChannels.push({
    channel: 'WeChat',
    handle: c.wechat.id,
    href: `weixin://dl/chat?${c.wechat.id}`,
    iconText: '微',
  });
}
if (c.telegram?.url) {
  optionalChannels.push({
    channel: 'Telegram',
    handle: c.telegram.handle,
    href: c.telegram.url,
    iconText: 'T',
  });
}
if (c.messenger?.url) {
  optionalChannels.push({
    channel: 'Messenger',
    handle: c.messenger.handle,
    href: c.messenger.url,
    iconText: 'M',
  });
}
if (c.botim) {
  optionalChannels.push({
    channel: 'Botim',
    handle: c.botim,
    href: `tel:${c.botim}`,
    iconText: 'B',
  });
}
if (c.max) {
  optionalChannels.push({
    channel: 'Max',
    handle: c.max,
    href: `https://max.ru/${c.max}`,
    iconText: 'X',
  });
}
if (c.line) {
  optionalChannels.push({
    channel: 'Line',
    handle: c.line,
    href: `https://line.me/ti/p/~${c.line}`,
    iconText: 'L',
  });
}
if (c.viber) {
  optionalChannels.push({
    channel: 'Viber',
    handle: c.viber,
    href: `viber://chat?number=${encodeURIComponent(c.viber)}`,
    iconText: 'V',
  });
}
const channels = [...baseChannels, ...optionalChannels];
---
<BaseLayout
  title={fill(t.meta.titleTemplate, tokens)}
  description={fill(t.meta.descriptionTemplate, tokens)}
  path="/contact"
  type="website"
  includeOrgSchema={true}
  schema={localBusinessSchema}
>
  <!-- Breadcrumbs (also emits BreadcrumbList JSON-LD) -->
  <div class="border-b border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-7xl px-4 py-4 md:px-8">
      <Breadcrumbs items={[{ label: t.breadcrumb }]} />
    </div>
  </div>

  <!-- Block 1 — Hero -->
  <HeroSection
    title={t.hero.title}
    subtitle={t.hero.subtitle}
    primaryCta={{
      label: t.hero.ctaWhatsapp,
      href: heroWaHref,
      ariaLabel: t.hero.ctaWhatsappAria,
      target: '_blank',
      rel: 'noopener noreferrer',
      dataEvent: 'whatsapp_click',
      dataSourceComponent: 'hero',
    }}
    secondaryCta={{
      label: t.hero.ctaEmail,
      href: heroEmailHref,
      ariaLabel: t.hero.ctaEmailAria,
    }}
  >
    <p class="mt-6 text-sm text-neutral-600">{t.hero.microcopy}</p>
  </HeroSection>

  <!-- Block 2 — Trust strip -->
  <section aria-labelledby="trust-heading" class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-7xl px-4 py-6 md:px-8">
      <h2 id="trust-heading" class="sr-only">{t.trust.heading}</h2>
      <ul class="-mx-1 flex snap-x gap-3 overflow-x-auto px-1 pb-2">
        {trustItems.map((item) => (
          <li class="snap-start">
            <TrustBadge label={item.label} value={item.value} iconText={item.iconText} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Block 3 — WhatsApp primary -->
  <section aria-labelledby="whatsapp-heading" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <h2 id="whatsapp-heading" class="text-xl font-bold text-neutral-900 md:text-2xl lg:text-3xl">
            {t.whatsappPrimary.heading}
          </h2>
          <p class="mt-4 max-w-prose text-lg text-neutral-700">{t.whatsappPrimary.lead}</p>
          <h3 class="mt-8 text-base font-semibold text-neutral-900">
            {t.whatsappPrimary.includeHeading}
          </h3>
          <ul class="mt-3 space-y-2 text-sm text-neutral-700">
            {t.whatsappPrimary.includeItems.map((item) => (
              <li class="flex gap-2">
                <span aria-hidden="true" class="text-brand-primary">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-sm text-neutral-600">{t.whatsappPrimary.voiceVideoNote}</p>
        </div>
        <div class="grid gap-4 lg:col-span-6 sm:grid-cols-2">
          {[company.whatsapp.sales, company.whatsapp.director].map((person, idx) => {
            const presetKey = idx === 0 ? 'salesGeneral' : 'directorIntro';
            const waHref = waLinkFor(presetKey, person.e164Digits);
            const heading = idx === 0 ? t.whatsappPrimary.salesCardHeading : t.whatsappPrimary.directorCardHeading;
            return (
              <article class="flex flex-col rounded-xl border border-neutral-200 bg-white p-6">
                <p class="text-xs font-medium uppercase tracking-wide text-neutral-500">{heading}</p>
                <h3 class="mt-2 text-lg font-semibold text-neutral-900">{person.name}</h3>
                <p class="text-sm text-neutral-600">{person.role}</p>
                <a
                  href={`tel:${person.e164Digits.startsWith('+') ? person.e164Digits : '+' + person.e164Digits}`}
                  class="mt-4 text-sm text-brand-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary rounded-sm"
                >
                  {person.display}
                </a>
                <div class="mt-auto flex flex-wrap gap-2 pt-4">
                  <a
                    href={waHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-event="whatsapp_click"
                    data-source-component="whatsapp-primary"
                    class="inline-flex flex-1 items-center justify-center gap-2 rounded-md bg-success px-4 py-2 text-sm font-semibold text-white hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-success"
                  >
                    {t.whatsappPrimary.buttonOpenWhatsapp}
                    <span class="sr-only">{t.newTabSr}</span>
                  </a>
                  <a
                    href={`tel:${person.e164Digits.startsWith('+') ? person.e164Digits : '+' + person.e164Digits}`}
                    class="inline-flex items-center justify-center rounded-md border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-800 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
                  >
                    {t.whatsappPrimary.buttonCall}
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Block 4 — Sales team -->
  <section aria-labelledby="team-heading" class="bg-neutral-50">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <h2 id="team-heading" class="text-xl font-bold text-neutral-900 md:text-2xl lg:text-3xl">
        {t.team.heading}
      </h2>
      <p class="mt-4 max-w-prose text-lg text-neutral-700">{t.team.lead}</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {company.team.map((member) => <TeamCard member={member} />)}
      </div>
    </div>
  </section>

  <!-- Block 5 — All contact channels -->
  <section aria-labelledby="channels-heading" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <h2 id="channels-heading" class="text-xl font-bold text-neutral-900 md:text-2xl lg:text-3xl">
        {t.channels.heading}
      </h2>
      <p class="mt-4 max-w-prose text-lg text-neutral-700">{t.channels.lead}</p>
      <ul class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {channels.map((ch) => (
          <li class="h-full">
            <ChannelCard
              channel={ch.channel}
              handle={ch.handle}
              href={ch.href}
              iconText={ch.iconText}
              ctaLabel={ch.ctaLabel}
            />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Block 6 — Inquiry form -->
  <section id="inquiry" aria-labelledby="form-heading" class="bg-neutral-50">
    <div class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
      <h2 id="form-heading" class="text-xl font-bold text-neutral-900 md:text-2xl lg:text-3xl">
        {t.form.heading}
      </h2>
      <p class="mt-4 max-w-prose text-lg text-neutral-700">{t.form.lead}</p>
      <div class="mt-10">
        <InquiryForm />
      </div>
    </div>
  </section>

  <!-- Block 7 — Find us -->
  <FindUsBlock />

  <!-- Block 8 — Hours & holidays -->
  <HoursBlock />

  <!-- Block 9 — Map -->
  <MapBlock />

  <!-- Block 10 — Hotels -->
  <HotelsBlock />

  <!-- Block 11 — Banking (public) -->
  <PaymentBlock />
</BaseLayout>
