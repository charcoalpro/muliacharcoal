---
/**
 * /logistics/import-guides — the "country import guides" hub (import cocoon v1).
 *
 * A Mixed-level node between the Logistics pillar and the per-country
 * import-to-{country} Support pages: it lists every published guide as a card
 * and gives the country set a single parent (breadcrumb Home > Logistics >
 * Import guides > Import to {X}). Schema: CollectionPage + ItemList over the
 * published set from `company.logistics.imports`. Adding a country is data-only.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { readingTime } from '~/lib/readingTime';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ArticleMeta from '~/components/content/ArticleMeta.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import en from '~/i18n/en';
import { pillarCrumb } from '~/lib/breadcrumb';
import { company, waLinkFor } from '~/config/company';
import { fill, companyTokens, logisticsTokens } from '~/lib/interpolate';
import { collectionPageSchema } from '~/lib/schema/collectionPage';
import { importCountryLinks } from '~/lib/importCountries';

const t = en.logisticsImportGuides;
const tc = en.logisticsCommon;
const tokens = { ...companyTokens(company), ...logisticsTokens(company) };

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

const guides = importCountryLinks();

// CollectionPage + ItemList of the published country guides (hub → children).
const schema = collectionPageSchema({
  pageTitle,
  pageDescription,
  path: '/logistics/import-guides',
  skus: guides.map((g) => ({ href: g.href, name: fill(t.cardTitleTemplate, { country: g.country }) })),
});

const proseForReadTime = fill(
  [t.heroSubtitle, t.intro.p1, t.listHeading, t.listIntro, ...guides.map((g) => fill(t.cardBlurbTemplate, { country: g.country }))].join(' '),
  tokens,
);
const readMinutes = readingTime(proseForReadTime);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path="/logistics/import-guides"
  type="website"
  includeOrgSchema={false}
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[pillarCrumb('logistics'), { label: t.breadcrumb }]} />
  </div>

  <HeroSection
    eyebrow={t.eyebrow}
    title={fill(t.h1, tokens)}
    subtitle={fill(t.heroSubtitle, tokens)}
    primaryCta={{ label: t.hero.ctaQuote, href: waLinkFor('salesGeneral'), ariaLabel: t.hero.ctaQuoteAria, target: '_blank', rel: 'noopener', dataEvent: 'whatsapp_click', dataSourceComponent: 'import-guides-hero-quote' }}
    secondaryCta={{ label: t.hero.ctaContact, href: '/contact', ariaLabel: t.hero.ctaContactAria, dataSourceComponent: 'import-guides-hero-inquiry' }}
  />

  <div class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-3xl px-4 py-6 md:px-8">
      <ArticleMeta
        labels={{ authoredBy: tc.metaBlock.authorRole, reviewedBy: tc.metaBlock.reviewerRole, factCheckedBy: tc.metaBlock.factCheckerRole, lastUpdated: tc.metaBlock.lastUpdatedLabel, readTime: tc.metaBlock.readTimeLabel }}
        lastUpdated={company.logistics.editorial.dateModified}
        readTimeValue={fill(tc.metaBlock.readTimeValueTemplate, { minutes: readMinutes })}
      />
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-10 md:px-8">
    <p class="max-w-prose text-base leading-relaxed text-neutral-700">
      {fill(t.intro.p1, tokens)}{' '}
      <MaybeLink href="/logistics" class="font-semibold" data-source-component="import-guides-up-hub">{t.intro.hubLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
    </p>

    <section aria-labelledby="guides-heading" class="mt-10">
      <h2 id="guides-heading" class="text-2xl font-bold text-neutral-900">{t.listHeading}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.listIntro}</p>
      <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {guides.map((g) => (
          <li>
            <a
              href={g.href}
              class="flex min-h-11 flex-col rounded-2xl border border-neutral-200 bg-white p-5 transition-colors hover:border-brand-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary"
              data-source-component={`import-guides-card-${g.slug}`}
            >
              <span class="text-lg font-semibold text-neutral-900">{fill(t.cardTitleTemplate, { country: g.country })}</span>
              <span class="mt-1 text-sm text-neutral-600">{fill(t.cardBlurbTemplate, { country: g.country })}</span>
              <span class="mt-3 text-sm font-semibold text-brand-primary">{t.cardCta} <span aria-hidden="true">→</span></span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="import-guides-related" class="mt-14 border-t border-neutral-200 pt-8">
      <h2 id="import-guides-related" class="text-xl font-bold text-neutral-900">{t.related.heading}</h2>
      <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink href={item.href} class="font-medium" mutedClass="font-medium text-neutral-400" data-source-component={`import-guides-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}>
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </section>
  </article>

  <CTABanner whatsappMessage={company.whatsapp.presetMessages.salesGeneral} />
</BaseLayout>
