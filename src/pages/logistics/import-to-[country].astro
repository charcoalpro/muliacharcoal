---
/**
 * /logistics/import-to-[country] — the reusable import-to-{country} template
 * (cocoon v3.3 §5.8 + import cocoon v1). One dynamic route over
 * `company.logistics.imports`: USA migrated in, UK / Germany / Saudi Arabia /
 * Russia added. WebPage + FAQPage + TechArticle + optional HowTo. Every
 * regulatory cell reads from `imports[country].*` (verified, source-linked);
 * duty is a dated layer-stack with legal-status flags; the VAT layer and the
 * origin-preference note render only when present (USA omits both). The
 * landed-cost example labels FOB illustrative and never publishes a per-ton
 * price. The USA FDA block generalises to a `countryAgency` section with a
 * standalone disclaimer. Three buyer-content blocks (lead time, trade-term
 * row, responsibility split) render on every page including USA.
 *
 * Adding a country later is DATA-ONLY: one object in `logistics.imports`
 * + one `logisticsImport{Country}` i18n namespace — no edits to this file.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { readingTime } from '~/lib/readingTime';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ArticleMeta from '~/components/content/ArticleMeta.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import ExternalLink from '~/components/content/ExternalLink.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import KeyFactsBox from '~/components/packaging/KeyFactsBox.astro';
import en from '~/i18n/en';
import { pillarCrumb } from '~/lib/breadcrumb';
import { company, waLinkFor, hasFact, type ImportCountry, type ImportCountryKey } from '~/config/company';
import { fill, companyTokens, logisticsTokens } from '~/lib/interpolate';
import { logisticsClusterPageSchema } from '~/lib/schema/logisticsClusterPage';

// Config key → URL slug (kebab). Only countries present in
// `logistics.imports` are built; the rest of the map is inert.
const SLUGS: Record<ImportCountryKey, string> = {
  usa: 'usa',
  uk: 'uk',
  germany: 'germany',
  saudiArabia: 'saudi-arabia',
  russia: 'russia',
};

export function getStaticPaths() {
  const slugs: Record<string, string> = {
    usa: 'usa',
    uk: 'uk',
    germany: 'germany',
    saudiArabia: 'saudi-arabia',
    russia: 'russia',
  };
  return Object.entries(company.logistics.imports)
    .filter((entry): entry is [string, ImportCountry] => Boolean(entry[1]))
    .map(([key, data]) => ({
      params: { country: slugs[key] },
      props: { key: key as ImportCountryKey, data },
    }));
}

const { key, data } = Astro.props as { key: ImportCountryKey; data: ImportCountry };
const slug = SLUGS[key];
const path = `/logistics/import-to-${slug}`;
// data-source-component prefix; `importusa` keeps the USA page byte-stable.
const prefix = `import${key}`;

// Per-country i18n namespace (typed map → TypeScript verifies every country's
// namespace carries the full shape; a missing key is a build error, not a
// silent undefined render). Adding a country = one line here + the JSON files.
const I18N = {
  usa: en.logisticsImportUsa,
  uk: en.logisticsImportUk,
  germany: en.logisticsImportGermany,
  saudiArabia: en.logisticsImportSaudiArabia,
  russia: en.logisticsImportRussia,
};
const t = I18N[key];
const ti = en.logisticsImportCommon;
const tc = en.logisticsCommon;

const tokens = { ...companyTokens(company), ...logisticsTokens(company) };

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

// Ports + lead time both read the country's transit rows.
const ports = company.commercial.transitTimes.filter((r) => r.country === data.country);
const portRows = ports.map((r) => ({ destPort: r.destination, unlocode: r.portCode, min: r.minDays, max: r.maxDays }));
const transitMin = ports.length ? Math.min(...ports.map((r) => r.minDays)) : 0;
const transitMax = ports.length ? Math.max(...ports.map((r) => r.maxDays)) : 0;
const lt = company.commercial.leadTime;
const portCities = ports.map((r) => r.destination.split(',')[0]);
const destPorts =
  portCities.length <= 1
    ? portCities[0] ?? ''
    : `${portCities.slice(0, -1).join(', ')} and ${portCities[portCities.length - 1]}`;

// One token set for the new blocks (lead time + responsibility split + FAQ).
const allTokens = {
  ...tokens,
  destLine: t.responsibilityDestLine,
  destPorts,
  transitDays: `${transitMin}–${transitMax}`,
  totalDays: `${lt.minDays + transitMin}–${lt.maxDays + transitMax}`,
};

// Trade term: FOB named place + CIF/CFR when offered (incoterms includes CIF).
const offersCif = company.logistics.incoterms.includes('CIF');
const pol = company.commercial.portOfLoading;
const tradeTermValue = `FOB ${pol.fullName} (${pol.name})${offersCif ? ' · CIF/CFR on request' : ''}`;

// Optional standalone feasibility caveat (Russia: carrier/banking constraints
// → route to /contact before committing). Present only where the namespace
// declares it, so it renders nowhere else.
const feasibility = (t as { feasibilityCaveat?: { heading: string; body: string } }).feasibilityCaveat;

const keyFacts = [
  { label: t.keyFacts.htsLabel, value: t.keyFacts.htsValue },
  { label: t.keyFacts.dutyLabel, value: t.keyFacts.dutyValue },
  ...(data.vat ? [{ label: ti.vat.h3, value: data.vat.ratePct }] : []),
  { label: t.keyFacts.docsLabel, value: t.keyFacts.docsValue },
  { label: t.keyFacts.customsLabel, value: t.keyFacts.customsValue },
  { label: t.keyFacts.agencyLabel, value: t.keyFacts.agencyValue },
  { label: ti.tradeTerm.label, value: tradeTermValue },
];

// Entry steps → HowTo (text from config entryNotes).
const entryNotes: Record<string, string> = data.entryNotes;
const entrySteps = t.entry.steps.map((s) => ({ name: s.name, text: entryNotes[s.field] })).filter((s) => hasFact(s.text));

// Responsibility split — shared lists; the destination-side line is per-country.
const factoryItems = ti.responsibility.factoryItems.map((s) => fill(s, allTokens));
const buyerItems = ti.responsibility.buyerItems.map((s) => fill(s, allTokens));

const faqItems = t.faq.items.map((item) => ({ q: fill(item.q, allTokens), a: fill(item.a, allTokens) }));

const schema = logisticsClusterPageSchema({
  pageTitle,
  pageDescription,
  path,
  faq: faqItems,
  techArticle: { headline: fill(t.h1, tokens), description: pageDescription },
  howTo: entrySteps.length ? { name: t.entry.h2, steps: entrySteps } : undefined,
  dateModified: data.lastVerified,
});

const proseForReadTime = fill(
  [
    t.heroSubtitle,
    t.intro.p1,
    t.hts.body,
    t.duty.body,
    data.dutyHistory,
    t.landed.body,
    t.entry.body,
    ti.responsibility.intro,
    ...ti.responsibility.factoryItems,
    ...ti.responsibility.buyerItems,
    ti.leadTime.sentenceTemplate,
    ti.leadTime.dgNote,
    ...data.countryAgency.items.map((x) => x.value),
    ...t.faq.items.flatMap((f) => [f.q, f.a]),
  ].join(' '),
  allTokens,
);
const readMinutes = readingTime(proseForReadTime);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path={path}
  type="article"
  includeOrgSchema={false}
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[pillarCrumb('logistics'), { label: t.breadcrumb }]} />
  </div>

  <HeroSection
    eyebrow={t.eyebrow}
    title={fill(t.h1, tokens)}
    subtitle={fill(t.heroSubtitle, tokens)}
    primaryCta={{ label: t.hero.ctaQuote, href: waLinkFor('salesGeneral'), ariaLabel: t.hero.ctaQuoteAria, target: '_blank', rel: 'noopener', dataEvent: 'whatsapp_click', dataSourceComponent: `${prefix}-hero-quote` }}
    secondaryCta={{ label: t.hero.ctaContact, href: '/contact', ariaLabel: t.hero.ctaContactAria, dataSourceComponent: `${prefix}-hero-inquiry` }}
  />

  <div class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-3xl px-4 py-6 md:px-8">
      <ArticleMeta
        labels={{ authoredBy: tc.metaBlock.authorRole, reviewedBy: tc.metaBlock.reviewerRole, factCheckedBy: tc.metaBlock.factCheckerRole, lastUpdated: tc.metaBlock.lastUpdatedLabel, readTime: tc.metaBlock.readTimeLabel }}
        lastUpdated={data.lastVerified}
        readTimeValue={fill(tc.metaBlock.readTimeValueTemplate, { minutes: readMinutes })}
      />
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-10 md:px-8">
    <p class="max-w-prose text-base leading-relaxed text-neutral-700">
      {fill(t.intro.p1, tokens)}{' '}
      <MaybeLink href="/logistics" class="font-semibold" data-source-component={`${prefix}-up-hub`}>{t.intro.hubLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
      <span class="mx-1 text-neutral-300" aria-hidden="true">·</span>
      <MaybeLink href={`/markets/${slug}`} class="font-semibold" data-source-component={`${prefix}-markets`}>{t.intro.marketsLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
    </p>

    {feasibility && (
      <aside class="mt-6 rounded-xl border-2 border-amber-400 bg-amber-50 p-5" role="note" aria-labelledby="feasibility-h">
        <h2 id="feasibility-h" class="text-base font-bold text-amber-900">{feasibility.heading}</h2>
        <p class="mt-2 text-sm leading-relaxed text-amber-900">{feasibility.body}</p>
        <p class="mt-3 text-sm"><MaybeLink href="/contact" class="font-semibold text-amber-900 underline" data-source-component={`${prefix}-feasibility-contact`}>{t.hero.ctaContact} <span aria-hidden="true">→</span></MaybeLink></p>
      </aside>
    )}

    <KeyFactsBox class="mt-8" id={`${prefix}-at-a-glance`} heading={t.keyFacts.heading} definition={t.keyFacts.definition} facts={keyFacts} />

    <section id="responsibility" aria-labelledby="responsibility-h" class="mt-12 scroll-mt-24">
      <h2 id="responsibility-h" class="text-2xl font-bold text-neutral-900">{ti.responsibility.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(ti.responsibility.intro, allTokens)}</p>
      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-neutral-200 bg-white p-5">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-900">{ti.responsibility.factoryHeader}</h3>
          <ul class="mt-3 space-y-2 text-sm text-neutral-700" role="list">
            {factoryItems.map((item) => (
              <li class="flex gap-2"><span aria-hidden="true" class="text-brand-primary">✓</span><span>{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border border-neutral-200 bg-white p-5">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-900">{ti.responsibility.buyerHeader}</h3>
          <ul class="mt-3 space-y-2 text-sm text-neutral-700" role="list">
            {buyerItems.map((item) => (
              <li class="flex gap-2"><span aria-hidden="true" class="text-neutral-400">→</span><span>{item}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section id="hts" aria-labelledby="hts-h" class="mt-12 scroll-mt-24">
      <h2 id="hts-h" class="text-2xl font-bold text-neutral-900">{t.hts.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.hts.body, tokens)}</p>
      <p class="mt-4 text-base font-medium text-neutral-800">{t.hts.candidatesIntro}</p>
      <ul class="mt-2 space-y-3" role="list">
        {data.htsCandidates.map((c) => (
          <li class="rounded-lg border border-neutral-200 bg-white p-4">
            <p class="font-mono text-base font-semibold text-neutral-900">{c.code}</p>
            <p class="mt-1 text-sm text-neutral-700">{c.note}</p>
            {hasFact(c.sourceUrl) && (
              <p class="mt-1 text-sm"><ExternalLink href={c.sourceUrl} data-event="outbound_click" data-source-component={`${prefix}-hts-source`}>{t.duty.sourceLabel}</ExternalLink></p>
            )}
          </li>
        ))}
      </ul>
      {hasFact(data.htsNotes) && <p class="mt-3 max-w-prose text-sm text-neutral-600"><span class="font-medium">{t.hts.notesLabel}:</span> {data.htsNotes}</p>}
    </section>

    <section id="duty" aria-labelledby="duty-h" class="mt-12 scroll-mt-24">
      <h2 id="duty-h" class="text-2xl font-bold text-neutral-900">{t.duty.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.duty.body, tokens)}</p>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-start text-sm">
          <thead>
            <tr class="border-b border-neutral-300">
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.layerHeader}</th>
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.rateHeader}</th>
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.asOfHeader}</th>
              <th scope="col" class="py-2 font-semibold text-neutral-900">{t.duty.statusHeader}</th>
            </tr>
          </thead>
          <tbody>
            {data.dutyLayers.map((d) => (
              <tr class="border-b border-neutral-200 align-top">
                <th scope="row" class="py-2 pe-4 font-medium text-neutral-800">
                  {d.label}
                  <span class="block font-normal text-neutral-600">{d.basis}</span>
                  {hasFact(d.sourceUrl) && (
                    <span class="block"><ExternalLink href={d.sourceUrl} class="text-xs" data-event="outbound_click" data-source-component={`${prefix}-duty-${d.id}`}>{t.duty.sourceLabel}</ExternalLink></span>
                  )}
                </th>
                <td class="py-2 pe-4 font-semibold text-neutral-900">{d.rate}</td>
                <td class="py-2 pe-4 text-neutral-700">{d.asOf}</td>
                <td class="py-2 text-neutral-700">{hasFact(d.legalStatus) ? d.legalStatus : tc.labels.dash}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-sm text-neutral-600">{fill(tc.caveats.duty, tokens)}</p>
      {data.vat && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{ti.vat.h3}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700"><span class="font-semibold text-neutral-900">{data.vat.name}: {data.vat.ratePct}</span> — {data.vat.recoverableNote}</p>
          <p class="mt-1 text-sm text-neutral-600">{ti.vat.asOfLabel} {data.vat.asOf}</p>
          {hasFact(data.vat.sourceUrl) && (
            <p class="mt-1 text-sm"><ExternalLink href={data.vat.sourceUrl} class="text-xs" data-event="outbound_click" data-source-component={`${prefix}-vat-source`}>{ti.vat.sourceLabel}</ExternalLink></p>
          )}
        </div>
      )}
      {data.preference && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{ti.preference.h3}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">{data.preference.note}</p>
          {hasFact(data.preference.originDoc) && (
            <p class="mt-1 text-sm text-neutral-600"><span class="font-medium">{ti.preference.originDocLabel}:</span> {data.preference.originDoc}</p>
          )}
          {hasFact(data.preference.sourceUrl) && (
            <p class="mt-1 text-sm"><ExternalLink href={data.preference.sourceUrl} class="text-xs" data-event="outbound_click" data-source-component={`${prefix}-preference-source`}>{ti.preference.sourceLabel}</ExternalLink></p>
          )}
        </div>
      )}
      {hasFact(data.dutyHistory) && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{t.duty.historyHeading}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">{data.dutyHistory}</p>
        </div>
      )}
      {hasFact(data.adcvd) && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{t.duty.adcvdHeading}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">{data.adcvd}</p>
        </div>
      )}
    </section>

    <section id="landed-cost" aria-labelledby="landed-h" class="mt-12 scroll-mt-24">
      <h2 id="landed-h" class="text-2xl font-bold text-neutral-900">{t.landed.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.landed.body}</p>
      <dl class="mt-5 max-w-xl space-y-2 rounded-xl border border-neutral-200 bg-white p-5 text-sm">
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.fobLabel}</dt><dd class="text-end text-neutral-600">{t.landed.fobValue}</dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.freightLabel}</dt><dd class="text-end text-neutral-600">{t.landed.freightValue}</dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.dutyLabel}</dt><dd class="text-end text-neutral-600">{t.landed.dutyValue}</dd></div>
        <div class="flex justify-between gap-4 border-t border-neutral-200 pt-2"><dt class="font-semibold text-neutral-900">{t.landed.totalLabel}</dt><dd class="text-end font-semibold text-neutral-900">{t.landed.totalValue}</dd></div>
      </dl>
      <p class="mt-3 max-w-prose text-sm text-neutral-600">{t.landed.note}</p>
      <p class="mt-3 text-sm"><MaybeLink href="/logistics/rules" class="font-semibold" data-source-component={`${prefix}-landed-rules`}>{t.landed.rulesLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
    </section>

    <section id="entry" aria-labelledby="entry-h" class="mt-12 scroll-mt-24">
      <h2 id="entry-h" class="text-2xl font-bold text-neutral-900">{t.entry.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.entry.body}</p>
      <p class="mt-3 text-base text-neutral-700">{t.entry.stepsIntro}</p>
      <ol class="mt-3 max-w-prose space-y-3 text-base text-neutral-700" role="list">
        {entrySteps.map((s, i) => (
          <li class="flex gap-3">
            <span aria-hidden="true" class="font-semibold text-brand-primary">{i + 1}.</span>
            <span><strong class="font-semibold text-neutral-900">{s.name}.</strong> {s.text}</span>
          </li>
        ))}
      </ol>
      <p class="mt-4 text-sm"><MaybeLink href="/logistics/documents" class="font-semibold" data-source-component={`${prefix}-entry-documents`}>{t.entry.documentsLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
    </section>

    <section id="dg-handling" aria-labelledby="dg-h" class="mt-12 scroll-mt-24">
      <h2 id="dg-h" class="text-2xl font-bold text-neutral-900">{fill(t.dgHandling.h2, tokens)}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.dgHandling.body, tokens)}</p>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
        <MaybeLink href="/logistics/un-1361" class="font-semibold" data-source-component={`${prefix}-dg-un1361`}>{t.dgHandling.un1361LinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/charcoal-dg-regulation" class="font-semibold" data-source-component={`${prefix}-dg-regulation`}>{t.dgHandling.regulationLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/cargo-protection-and-insurance" class="font-semibold" data-source-component={`${prefix}-dg-cargo`}>{t.dgHandling.cargoLinkLabel}</MaybeLink>
      </p>
    </section>

    <section id="agency" aria-labelledby="agency-h" class="mt-12 scroll-mt-24">
      <h2 id="agency-h" class="text-2xl font-bold text-neutral-900">{t.countryAgency.h2}</h2>
      <p class="mt-3 max-w-prose text-base italic leading-relaxed text-neutral-600">{t.countryAgency.intro}</p>
      <dl class="mt-4 space-y-4">
        {data.countryAgency.items.map((x) => (
          <div>
            <dt class="font-semibold text-neutral-900">{x.label}</dt>
            <dd class="mt-1 max-w-prose text-base leading-relaxed text-neutral-700">
              {x.value}
              {hasFact(x.sourceUrl) && (
                <span class="block"><ExternalLink href={x.sourceUrl} class="text-xs" data-event="outbound_click" data-source-component={`${prefix}-agency-${x.label.replace(/[^a-z0-9]+/gi, '-').toLowerCase().replace(/^-|-$/g, '')}`}>{t.duty.sourceLabel}</ExternalLink></span>
              )}
            </dd>
          </div>
        ))}
      </dl>
      <aside class="mt-6 rounded-xl border border-neutral-300 bg-neutral-50 p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-900">{t.countryAgency.disclaimer.heading}</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">{t.countryAgency.disclaimer.body}</p>
      </aside>
    </section>

    {ports.length > 0 && (
      <section id="lead-time" aria-labelledby="lead-time-h" class="mt-12 scroll-mt-24">
        <h2 id="lead-time-h" class="text-2xl font-bold text-neutral-900">{ti.leadTime.h2}</h2>
        <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(ti.leadTime.sentenceTemplate, allTokens)}</p>
        <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(ti.leadTime.dgNote, allTokens)}</p>
        <p class="mt-3 text-sm text-neutral-600">{ti.leadTime.indicativeNote}</p>
      </section>
    )}

    {portRows.length > 0 && (
      <section id="ports" aria-labelledby="ports-h" class="mt-12 scroll-mt-24">
        <h2 id="ports-h" class="text-2xl font-bold text-neutral-900">{t.ports.h2}</h2>
        <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.ports.body, tokens)}</p>
        <ul class="mt-4 max-w-prose space-y-1.5 text-base text-neutral-700" role="list">
          {portRows.map((r) => (
            <li>{fill(t.ports.sentenceTemplate, { destPort: r.destPort, unlocode: r.unlocode, min: r.min, max: r.max })}</li>
          ))}
        </ul>
        <p class="mt-3 text-sm text-neutral-600">{fill(tc.caveats.transit, tokens)}</p>
      </section>
    )}

    <section aria-labelledby={`${prefix}-faq`} class="mt-14">
      <FAQSection id={`${prefix}-faq`} heading={t.faq.heading} items={faqItems} />
    </section>

    <section aria-labelledby={`${prefix}-related`} class="mt-14 border-t border-neutral-200 pt-8">
      <h2 id={`${prefix}-related`} class="text-xl font-bold text-neutral-900">{t.related.heading}</h2>
      <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink href={item.href} class="font-medium" mutedClass="font-medium text-neutral-400" data-source-component={`${prefix}-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}>
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </section>
  </article>

  <CTABanner whatsappMessage={company.whatsapp.presetMessages.salesGeneral} />
</BaseLayout>
