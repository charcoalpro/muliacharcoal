---
/**
 * /logistics/un-1361 — the timeless UN 1361 classification entity
 * (cocoon v3.3 §5.4). WebPage + FAQPage + TechArticle (about → glossary
 * #un-1361). Carries the cargo-details table (canonical here) and the
 * honest safety reframe. Holds NO SP 978 *requirements* — those live on
 * the regulation page; cross-linked.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { readingTime } from '~/lib/readingTime';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ArticleMeta from '~/components/content/ArticleMeta.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import KeyFactsBox from '~/components/packaging/KeyFactsBox.astro';
import Figure from '~/components/packaging/Figure.astro';
import en from '~/i18n/en';
import { pillarCrumb } from '~/lib/breadcrumb';
import { company, waLinkFor, hasFact } from '~/config/company';
import { fill, companyTokens, logisticsTokens } from '~/lib/interpolate';
import { logisticsClusterPageSchema } from '~/lib/schema/logisticsClusterPage';

const t = en.logisticsUn1361;
const tc = en.logisticsCommon;
const L = company.logistics;
const tokens = { ...companyTokens(company), ...logisticsTokens(company) };

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

const keyFacts = [
  { label: t.keyFacts.unLabel, value: tokens.unNumber },
  { label: t.keyFacts.classLabel, value: fill(t.keyFacts.classValueTemplate, tokens) },
  { label: t.keyFacts.psnLabel, value: tokens.properShippingName },
  { label: t.keyFacts.pgLabel, value: tokens.packingGroup },
  { label: t.keyFacts.governsLabel, value: t.keyFacts.governsValue },
  { label: t.keyFacts.shtLabel, value: t.keyFacts.shtValue },
];

// Cargo-details table — every cell from config; EMS drops if unverified.
const cargoRows = [
  { label: t.cargoTable.rows.substance, value: t.cargoTable.rows.substanceValue },
  { label: t.cargoTable.rows.un, value: tokens.unNumber },
  { label: t.cargoTable.rows.class, value: fill(t.keyFacts.classValueTemplate, tokens) },
  { label: t.cargoTable.rows.pg, value: tokens.packingGroup },
  { label: t.cargoTable.rows.psn, value: tokens.properShippingName },
  { label: t.cargoTable.rows.ems, value: L.dg.ems },
  { label: t.cargoTable.rows.flash, value: t.cargoTable.rows.flashValue },
  { label: t.cargoTable.rows.hs, value: tokens.hsCode6 },
].filter((r) => hasFact(r.value));

const faqItems = t.faq.items.map((item) => ({ q: fill(item.q, tokens), a: fill(item.a, tokens) }));

const schema = logisticsClusterPageSchema({
  pageTitle,
  pageDescription,
  path: '/logistics/un-1361',
  faq: faqItems,
  aboutAnchor: 'un-1361',
  techArticle: { headline: fill(t.h1, tokens), description: pageDescription },
});

const proseForReadTime = fill(
  [t.heroSubtitle, t.intro.p1, t.whatIs.body, t.selfHeating.body1, t.selfHeating.body2, t.sht.body, t.whyRefuse.body, ...t.faq.items.flatMap((f) => [f.q, f.a])].join(' '),
  tokens,
);
const readMinutes = readingTime(proseForReadTime);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path="/logistics/un-1361"
  type="article"
  includeOrgSchema={false}
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[pillarCrumb('logistics'), { label: t.breadcrumb }]} />
  </div>

  <HeroSection
    eyebrow={t.eyebrow}
    title={fill(t.h1, tokens)}
    subtitle={fill(t.heroSubtitle, tokens)}
    primaryCta={{ label: t.hero.ctaQuote, href: waLinkFor('salesGeneral'), ariaLabel: t.hero.ctaQuoteAria, target: '_blank', rel: 'noopener', dataEvent: 'whatsapp_click', dataSourceComponent: 'un1361-hero-quote' }}
    secondaryCta={{ label: t.hero.ctaContact, href: '/contact', ariaLabel: t.hero.ctaContactAria, dataSourceComponent: 'un1361-hero-inquiry' }}
  />

  <div class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-3xl px-4 py-6 md:px-8">
      <ArticleMeta
        labels={{ authoredBy: tc.metaBlock.authorRole, reviewedBy: tc.metaBlock.reviewerRole, factCheckedBy: tc.metaBlock.factCheckerRole, lastUpdated: tc.metaBlock.lastUpdatedLabel, readTime: tc.metaBlock.readTimeLabel }}
        lastUpdated={L.editorial.dateModified}
        readTimeValue={fill(tc.metaBlock.readTimeValueTemplate, { minutes: readMinutes })}
      />
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-10 md:px-8">
    <p class="max-w-prose text-base leading-relaxed text-neutral-700">
      {fill(t.intro.p1, tokens)}{' '}
      <MaybeLink href="/logistics" class="font-semibold" data-source-component="un1361-up-hub">{t.intro.hubLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
    </p>

    <KeyFactsBox class="mt-8" id="un1361-at-a-glance" heading={t.keyFacts.heading} definition={t.keyFacts.definition} facts={keyFacts} />

    <section id="what-is" aria-labelledby="what-is-h" class="mt-12 scroll-mt-24">
      <h2 id="what-is-h" class="text-2xl font-bold text-neutral-900">{t.whatIs.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.whatIs.body, tokens)}</p>
      <p class="mt-3 text-sm"><MaybeLink href="/glossary#un-1361" class="font-semibold" data-source-component="un1361-glossary">{t.whatIs.glossaryLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
    </section>

    <section id="cargo-details" aria-labelledby="cargo-h" class="mt-12 scroll-mt-24">
      <h2 id="cargo-h" class="text-2xl font-bold text-neutral-900">{t.cargoTable.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.cargoTable.intro}</p>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-start text-sm">
          <caption class="sr-only">{t.cargoTable.h2}</caption>
          <thead>
            <tr class="border-b border-neutral-300">
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.cargoTable.propertyHeader}</th>
              <th scope="col" class="py-2 font-semibold text-neutral-900">{t.cargoTable.valueHeader}</th>
            </tr>
          </thead>
          <tbody>
            {cargoRows.map((r) => (
              <tr class="border-b border-neutral-200">
                <th scope="row" class="py-2 pe-4 font-medium text-neutral-800">{r.label}</th>
                <td class="py-2 text-neutral-700">{r.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <figure class="mt-8">
        <Figure alt={fill(t.media.alt, tokens)} caption={fill(t.media.caption, tokens)} ratio="16/9" />
      </figure>
    </section>

    <section id="self-heating" aria-labelledby="self-heating-h" class="mt-12 scroll-mt-24">
      <h2 id="self-heating-h" class="text-2xl font-bold text-neutral-900">{t.selfHeating.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.selfHeating.body1, tokens)}</p>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.selfHeating.body2, tokens)}</p>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
        <MaybeLink href="/logistics/charcoal-dg-regulation" class="font-semibold" data-source-component="un1361-self-regulation">{t.selfHeating.regulationLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/cargo-protection-and-insurance" class="font-semibold" data-source-component="un1361-self-cargo">{t.selfHeating.cargoLinkLabel}</MaybeLink>
      </p>
    </section>

    <section id="self-heating-test" aria-labelledby="sht-h" class="mt-12 scroll-mt-24">
      <h2 id="sht-h" class="text-2xl font-bold text-neutral-900">{t.sht.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.sht.body, tokens)}</p>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
        <MaybeLink href="/logistics/documents" class="font-semibold" data-source-component="un1361-sht-documents">{t.sht.documentsLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/quality/certifications" class="font-semibold" data-source-component="un1361-sht-certifications">{t.sht.certificationsLinkLabel}</MaybeLink>
      </p>
    </section>

    <section id="why-refuse" aria-labelledby="refuse-h" class="mt-12 scroll-mt-24">
      <h2 id="refuse-h" class="text-2xl font-bold text-neutral-900">{t.whyRefuse.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.whyRefuse.body, tokens)}</p>
      <p class="mt-3 text-sm"><MaybeLink href="/logistics/charcoal-shipping-lines" class="font-semibold" data-source-component="un1361-refuse-lines">{t.whyRefuse.shippingLinesLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
      <p class="mt-6 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.markings.body, tokens)}{' '}
        <MaybeLink href="/packaging" class="font-semibold" data-source-component="un1361-markings-packaging">{t.markings.packagingLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
      </p>
    </section>

    <section aria-labelledby="un1361-faq" class="mt-14">
      <FAQSection id="un1361-faq" heading={t.faq.heading} items={faqItems} />
    </section>

    <section aria-labelledby="un1361-related" class="mt-14 border-t border-neutral-200 pt-8">
      <h2 id="un1361-related" class="text-xl font-bold text-neutral-900">{t.related.heading}</h2>
      <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink href={item.href} class="font-medium" mutedClass="font-medium text-neutral-400" data-source-component={`un1361-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}>
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </section>
  </article>

  <CTABanner whatsappMessage={company.whatsapp.presetMessages.salesGeneral} />
</BaseLayout>
