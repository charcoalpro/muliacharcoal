---
/**
 * /logistics/import-to-usa — US import mechanics + FDA (cocoon v3.3 §5.8).
 * The reusable import-to-{country} template. WebPage + FAQPage +
 * TechArticle + supplementary HowTo (entry process). Every regulatory cell
 * from usaImport.* (verified, source-linked). Duty is a dated layer-stack
 * with legal-status flags; the landed-cost example labels FOB illustrative
 * and never publishes a per-ton price. FDA section + standalone disclaimer.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { readingTime } from '~/lib/readingTime';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ArticleMeta from '~/components/content/ArticleMeta.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import ExternalLink from '~/components/content/ExternalLink.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import KeyFactsBox from '~/components/packaging/KeyFactsBox.astro';
import en from '~/i18n/en';
import { pillarCrumb } from '~/lib/breadcrumb';
import { company, waLinkFor, hasFact } from '~/config/company';
import { fill, companyTokens, logisticsTokens } from '~/lib/interpolate';
import { logisticsClusterPageSchema } from '~/lib/schema/logisticsClusterPage';

const t = en.logisticsImportUsa;
const tc = en.logisticsCommon;
const L = company.logistics;
const usa = L.usaImport;
const fda = usa.fda;
const tokens = { ...companyTokens(company), ...logisticsTokens(company) };

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

const keyFacts = [
  { label: t.keyFacts.htsLabel, value: t.keyFacts.htsValue },
  { label: t.keyFacts.dutyLabel, value: t.keyFacts.dutyValue },
  { label: t.keyFacts.docsLabel, value: t.keyFacts.docsValue },
  { label: t.keyFacts.customsLabel, value: t.keyFacts.customsValue },
  { label: t.keyFacts.fdaLabel, value: t.keyFacts.fdaValue },
];

// Entry steps → HowTo (text from config entryNotes).
const entryNotes: Record<string, string> = usa.entryNotes;
const entrySteps = t.entry.steps.map((s) => ({ name: s.name, text: entryNotes[s.field] })).filter((s) => hasFact(s.text));

// US ports filtered from the shared transit table (country === USA).
const usPorts = company.commercial.transitTimes
  .filter((r) => r.country === 'USA')
  .map((r) => ({ destPort: r.destination, unlocode: r.portCode, min: r.minDays, max: r.maxDays }));

// FDA paragraphs — labelled facts from config, dropping any unverified.
const fdaItems = [
  { label: t.fda.deemingLabel, value: fda.deemingRule },
  { label: t.fda.scopeLabel, value: fda.scope },
  { label: t.fda.requirementsLabel, value: fda.requirements },
  { label: t.fda.enforcementLabel, value: fda.enforcementDiscretionStatus },
  { label: t.fda.importAlertLabel, value: fda.importAlert },
  { label: t.fda.mislabelLabel, value: fda.mislabeling },
].filter((x) => hasFact(x.value));

const faqItems = t.faq.items.map((item) => ({ q: fill(item.q, tokens), a: fill(item.a, tokens) }));

const schema = logisticsClusterPageSchema({
  pageTitle,
  pageDescription,
  path: '/logistics/import-to-usa',
  faq: faqItems,
  techArticle: { headline: fill(t.h1, tokens), description: pageDescription },
  howTo: entrySteps.length ? { name: t.entry.h2, steps: entrySteps } : undefined,
});

const proseForReadTime = fill(
  [t.heroSubtitle, t.intro.p1, t.hts.body, t.duty.body, usa.dutyHistory, t.landed.body, t.entry.body, ...fdaItems.map((x) => x.value), ...t.faq.items.flatMap((f) => [f.q, f.a])].join(' '),
  tokens,
);
const readMinutes = readingTime(proseForReadTime);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path="/logistics/import-to-usa"
  type="article"
  includeOrgSchema={false}
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[pillarCrumb('logistics'), { label: t.breadcrumb }]} />
  </div>

  <HeroSection
    eyebrow={t.eyebrow}
    title={fill(t.h1, tokens)}
    subtitle={fill(t.heroSubtitle, tokens)}
    primaryCta={{ label: t.hero.ctaQuote, href: waLinkFor('salesGeneral'), ariaLabel: t.hero.ctaQuoteAria, target: '_blank', rel: 'noopener', dataEvent: 'whatsapp_click', dataSourceComponent: 'importusa-hero-quote' }}
    secondaryCta={{ label: t.hero.ctaContact, href: '/contact', ariaLabel: t.hero.ctaContactAria, dataSourceComponent: 'importusa-hero-inquiry' }}
  />

  <div class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-3xl px-4 py-6 md:px-8">
      <ArticleMeta
        labels={{ authoredBy: tc.metaBlock.authorRole, reviewedBy: tc.metaBlock.reviewerRole, factCheckedBy: tc.metaBlock.factCheckerRole, lastUpdated: tc.metaBlock.lastUpdatedLabel, readTime: tc.metaBlock.readTimeLabel }}
        lastUpdated={usa.lastVerified}
        readTimeValue={fill(tc.metaBlock.readTimeValueTemplate, { minutes: readMinutes })}
      />
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-10 md:px-8">
    <p class="max-w-prose text-base leading-relaxed text-neutral-700">
      {fill(t.intro.p1, tokens)}{' '}
      <MaybeLink href="/logistics" class="font-semibold" data-source-component="importusa-up-hub">{t.intro.hubLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
      <span class="mx-1 text-neutral-300" aria-hidden="true">·</span>
      <MaybeLink href="/markets/usa" class="font-semibold" data-source-component="importusa-markets">{t.intro.marketsLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
    </p>

    <KeyFactsBox class="mt-8" id="importusa-at-a-glance" heading={t.keyFacts.heading} definition={t.keyFacts.definition} facts={keyFacts} />

    <section id="hts" aria-labelledby="hts-h" class="mt-12 scroll-mt-24">
      <h2 id="hts-h" class="text-2xl font-bold text-neutral-900">{t.hts.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.hts.body, tokens)}</p>
      <p class="mt-4 text-base font-medium text-neutral-800">{t.hts.candidatesIntro}</p>
      <ul class="mt-2 space-y-3" role="list">
        {usa.htsCandidates.map((c) => (
          <li class="rounded-lg border border-neutral-200 bg-white p-4">
            <p class="font-mono text-base font-semibold text-neutral-900">{c.code}</p>
            <p class="mt-1 text-sm text-neutral-700">{c.note}</p>
            {hasFact(c.sourceUrl) && (
              <p class="mt-1 text-sm"><ExternalLink href={c.sourceUrl} data-event="outbound_click" data-source-component="importusa-hts-source">{t.duty.sourceLabel}</ExternalLink></p>
            )}
          </li>
        ))}
      </ul>
      {hasFact(usa.htsNotes) && <p class="mt-3 max-w-prose text-sm text-neutral-600"><span class="font-medium">{t.hts.notesLabel}:</span> {usa.htsNotes}</p>}
    </section>

    <section id="duty" aria-labelledby="duty-h" class="mt-12 scroll-mt-24">
      <h2 id="duty-h" class="text-2xl font-bold text-neutral-900">{t.duty.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.duty.body, tokens)}</p>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-start text-sm">
          <thead>
            <tr class="border-b border-neutral-300">
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.layerHeader}</th>
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.rateHeader}</th>
              <th scope="col" class="py-2 pe-4 font-semibold text-neutral-900">{t.duty.asOfHeader}</th>
              <th scope="col" class="py-2 font-semibold text-neutral-900">{t.duty.statusHeader}</th>
            </tr>
          </thead>
          <tbody>
            {usa.dutyLayers.map((d) => (
              <tr class="border-b border-neutral-200 align-top">
                <th scope="row" class="py-2 pe-4 font-medium text-neutral-800">
                  {d.label}
                  <span class="block font-normal text-neutral-600">{d.basis}</span>
                  {hasFact(d.sourceUrl) && (
                    <span class="block"><ExternalLink href={d.sourceUrl} class="text-xs" data-event="outbound_click" data-source-component={`importusa-duty-${d.id}`}>{t.duty.sourceLabel}</ExternalLink></span>
                  )}
                </th>
                <td class="py-2 pe-4 font-semibold text-neutral-900">{d.rate}</td>
                <td class="py-2 pe-4 text-neutral-700">{d.asOf}</td>
                <td class="py-2 text-neutral-700">{hasFact(d.legalStatus) ? d.legalStatus : tc.labels.dash}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-sm text-neutral-600">{fill(tc.caveats.duty, tokens)}</p>
      {hasFact(usa.dutyHistory) && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{t.duty.historyHeading}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">{usa.dutyHistory}</p>
        </div>
      )}
      {hasFact(usa.adcvd) && (
        <div class="mt-6">
          <h3 class="text-lg font-semibold text-neutral-900">{t.duty.adcvdHeading}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">{usa.adcvd}</p>
        </div>
      )}
    </section>

    <section id="landed-cost" aria-labelledby="landed-h" class="mt-12 scroll-mt-24">
      <h2 id="landed-h" class="text-2xl font-bold text-neutral-900">{t.landed.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.landed.body}</p>
      <dl class="mt-5 max-w-xl space-y-2 rounded-xl border border-neutral-200 bg-white p-5 text-sm">
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.fobLabel}</dt><dd class="text-end text-neutral-600">{t.landed.fobValue}</dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.freightLabel}</dt><dd class="text-end text-neutral-600">{t.landed.freightValue}</dd></div>
        <div class="flex justify-between gap-4"><dt class="font-medium text-neutral-800">{t.landed.dutyLabel}</dt><dd class="text-end text-neutral-600">{t.landed.dutyValue}</dd></div>
        <div class="flex justify-between gap-4 border-t border-neutral-200 pt-2"><dt class="font-semibold text-neutral-900">{t.landed.totalLabel}</dt><dd class="text-end font-semibold text-neutral-900">{t.landed.totalValue}</dd></div>
      </dl>
      <p class="mt-3 max-w-prose text-sm text-neutral-600">{t.landed.note}</p>
      <p class="mt-3 text-sm"><MaybeLink href="/logistics/rules" class="font-semibold" data-source-component="importusa-landed-rules">{t.landed.rulesLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
    </section>

    <section id="entry" aria-labelledby="entry-h" class="mt-12 scroll-mt-24">
      <h2 id="entry-h" class="text-2xl font-bold text-neutral-900">{t.entry.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.entry.body}</p>
      <p class="mt-3 text-base text-neutral-700">{t.entry.stepsIntro}</p>
      <ol class="mt-3 max-w-prose space-y-3 text-base text-neutral-700" role="list">
        {entrySteps.map((s, i) => (
          <li class="flex gap-3">
            <span aria-hidden="true" class="font-semibold text-brand-primary">{i + 1}.</span>
            <span><strong class="font-semibold text-neutral-900">{s.name}.</strong> {s.text}</span>
          </li>
        ))}
      </ol>
      <p class="mt-4 text-sm"><MaybeLink href="/logistics/documents" class="font-semibold" data-source-component="importusa-entry-documents">{t.entry.documentsLinkLabel} <span aria-hidden="true">→</span></MaybeLink></p>
    </section>

    <section id="dg-handling" aria-labelledby="dg-h" class="mt-12 scroll-mt-24">
      <h2 id="dg-h" class="text-2xl font-bold text-neutral-900">{fill(t.dgHandling.h2, tokens)}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.dgHandling.body, tokens)}</p>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
        <MaybeLink href="/logistics/un-1361" class="font-semibold" data-source-component="importusa-dg-un1361">{t.dgHandling.un1361LinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/charcoal-dg-regulation" class="font-semibold" data-source-component="importusa-dg-regulation">{t.dgHandling.regulationLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/cargo-protection-and-insurance" class="font-semibold" data-source-component="importusa-dg-cargo">{t.dgHandling.cargoLinkLabel}</MaybeLink>
      </p>
    </section>

    <section id="fda" aria-labelledby="fda-h" class="mt-12 scroll-mt-24">
      <h2 id="fda-h" class="text-2xl font-bold text-neutral-900">{t.fda.h2}</h2>
      <p class="mt-3 max-w-prose text-base italic leading-relaxed text-neutral-600">{t.fda.intro}</p>
      <dl class="mt-4 space-y-4">
        {fdaItems.map((x) => (
          <div>
            <dt class="font-semibold text-neutral-900">{x.label}</dt>
            <dd class="mt-1 max-w-prose text-base leading-relaxed text-neutral-700">{x.value}</dd>
          </div>
        ))}
        <div>
          <dt class="font-semibold text-neutral-900">{t.fda.practicalLabel}</dt>
          <dd class="mt-1 max-w-prose text-base leading-relaxed text-neutral-700">{t.fda.practicalBody}</dd>
        </div>
      </dl>
      <aside class="mt-6 rounded-xl border border-neutral-300 bg-neutral-50 p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-900">{tc.fdaDisclaimer.heading}</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">{tc.fdaDisclaimer.body}</p>
      </aside>
    </section>

    {usPorts.length > 0 && (
      <section id="ports" aria-labelledby="ports-h" class="mt-12 scroll-mt-24">
        <h2 id="ports-h" class="text-2xl font-bold text-neutral-900">{t.ports.h2}</h2>
        <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{fill(t.ports.body, tokens)}</p>
        <ul class="mt-4 max-w-prose space-y-1.5 text-base text-neutral-700" role="list">
          {usPorts.map((r) => (
            <li>{fill(t.ports.sentenceTemplate, { destPort: r.destPort, unlocode: r.unlocode, min: r.min, max: r.max })}</li>
          ))}
        </ul>
        <p class="mt-3 text-sm text-neutral-600">{fill(tc.caveats.transit, tokens)}</p>
      </section>
    )}

    <section aria-labelledby="importusa-faq" class="mt-14">
      <FAQSection id="importusa-faq" heading={t.faq.heading} items={faqItems} />
    </section>

    <section aria-labelledby="importusa-related" class="mt-14 border-t border-neutral-200 pt-8">
      <h2 id="importusa-related" class="text-xl font-bold text-neutral-900">{t.related.heading}</h2>
      <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink href={item.href} class="font-medium" mutedClass="font-medium text-neutral-400" data-source-component={`importusa-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}>
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </section>
  </article>

  <CTABanner whatsappMessage={company.whatsapp.presetMessages.salesGeneral} />
</BaseLayout>
