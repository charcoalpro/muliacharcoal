---
/**
 * /logistics/documents — export-document pack (cocoon v3.3 §5.3).
 * One section per document from logistics.documentsStandard[] then
 * documentsAdditional[], each self-anchored with the config `id` and
 * linking to its canonical /glossary anchor (operational prose only — no
 * DefinedTerm schema here). WebPage + FAQPage. Empty list would STOP, but
 * the config list is populated (seeded — owner to confirm).
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import ArticleMeta from '~/components/content/ArticleMeta.astro';
import MaybeLink from '~/components/content/MaybeLink.astro';
import FAQSection from '~/components/content/FAQSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';
import KeyFactsBox from '~/components/packaging/KeyFactsBox.astro';
import en from '~/i18n/en';
import { company, waLinkFor, hasFact } from '~/config/company';
import { fill, companyTokens, logisticsTokens } from '~/lib/interpolate';
import { logisticsClusterPageSchema } from '~/lib/schema/logisticsClusterPage';

const t = en.logisticsDocuments;
const tc = en.logisticsCommon;
const L = company.logistics;
const tokens = { ...companyTokens(company), ...logisticsTokens(company) };
const anchors: Record<string, { anchor: string; label: string }> = t.glossaryAnchors;

const pageTitle = fill(t.meta.titleTemplate, tokens);
const pageDescription = fill(t.meta.descriptionTemplate, tokens);

const keyFacts = [
  { label: t.keyFacts.standardCountLabel, value: fill(t.keyFacts.standardCountTemplate, tokens) },
  { label: t.keyFacts.additionalCountLabel, value: fill(t.keyFacts.additionalCountTemplate, tokens) },
  { label: t.keyFacts.dgdLabel, value: t.keyFacts.dgdValue },
  { label: t.keyFacts.deliveryLabel, value: t.keyFacts.deliveryValue },
  { label: t.keyFacts.shtLabel, value: t.keyFacts.shtValue },
];

const faqItems = t.faq.items.map((item) => ({ q: fill(item.q, tokens), a: fill(item.a, tokens) }));

const schema = logisticsClusterPageSchema({
  pageTitle,
  pageDescription,
  path: '/logistics/documents',
  faq: faqItems,
});

const proseForReadTime = fill(
  [t.heroSubtitle, t.intro.p1, ...L.documentsStandard.map((d) => d.buyerUse), ...L.documentsAdditional.map((d) => d.buyerUse), t.countryReq.body, ...t.faq.items.flatMap((f) => [f.q, f.a])].join(' '),
  tokens,
);
const readMinutes = Math.max(1, Math.round(proseForReadTime.split(/\s+/).length / 200));
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path="/logistics/documents"
  type="article"
  includeOrgSchema={false}
  schema={schema}
  prefetch={['/contact']}
>
  <div class="mx-auto max-w-3xl px-4 pt-6 md:px-8">
    <Breadcrumbs items={[{ label: en.logistics.breadcrumb, href: '/logistics' }, { label: t.breadcrumb }]} />
  </div>

  <HeroSection
    eyebrow={t.eyebrow}
    title={t.h1}
    subtitle={fill(t.heroSubtitle, tokens)}
    primaryCta={{ label: t.hero.ctaQuote, href: waLinkFor('salesGeneral'), ariaLabel: t.hero.ctaQuoteAria, target: '_blank', rel: 'noopener', dataEvent: 'whatsapp_click', dataSourceComponent: 'documents-hero-quote' }}
    secondaryCta={{ label: t.hero.ctaContact, href: '/contact', ariaLabel: t.hero.ctaContactAria, dataSourceComponent: 'documents-hero-inquiry' }}
  />

  <div class="border-y border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-3xl px-4 py-6 md:px-8">
      <ArticleMeta
        labels={{ authoredBy: tc.metaBlock.authorRole, reviewedBy: tc.metaBlock.reviewerRole, factCheckedBy: tc.metaBlock.factCheckerRole, lastUpdated: tc.metaBlock.lastUpdatedLabel, readTime: tc.metaBlock.readTimeLabel }}
        lastUpdated={L.editorial.dateModified}
        readTimeValue={fill(tc.metaBlock.readTimeValueTemplate, { minutes: readMinutes })}
      />
    </div>
  </div>

  <article class="mx-auto max-w-3xl px-4 py-10 md:px-8">
    <p class="max-w-prose text-base leading-relaxed text-neutral-700">
      {fill(t.intro.p1, tokens)}{' '}
      <MaybeLink href="/logistics" class="font-semibold" data-source-component="documents-up-hub">{t.intro.hubLinkLabel} <span aria-hidden="true">→</span></MaybeLink>
    </p>

    <KeyFactsBox class="mt-8" id="documents-at-a-glance" heading={t.keyFacts.heading} definition={t.keyFacts.definition} facts={keyFacts} />

    <h2 class="mt-12 text-2xl font-bold text-neutral-900">{t.standardHeading}</h2>
    <div class="mt-4 space-y-8">
      {L.documentsStandard.map((doc) => (
        <section id={doc.id} aria-labelledby={`${doc.id}-h`} class="scroll-mt-24">
          <h3 id={`${doc.id}-h`} class="text-lg font-semibold text-neutral-900">{doc.name}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">
            <span class="font-medium">{t.doc.issuerLabel}:</span> {doc.issuer}. {doc.buyerUse}. <span class="font-medium">{t.doc.providedLabel}:</span> {doc.providedWhen}.
          </p>
          {doc.id === 'dangerous-goods-declaration' && (
            <p class="mt-2 max-w-prose text-sm text-neutral-700">{t.dgdNote.body}{' '}
              <MaybeLink href="/logistics/charcoal-dg-regulation" class="font-semibold" data-source-component="documents-dgd-regulation">{t.dgdNote.linkLabel} <span aria-hidden="true">→</span></MaybeLink>
            </p>
          )}
          {anchors[doc.id] && (
            <p class="mt-2 text-sm">
              <MaybeLink href={`/glossary#${anchors[doc.id].anchor}`} class="font-semibold" data-source-component={`documents-glossary-${doc.id}`}>
                {fill(t.doc.seeTemplate, { label: anchors[doc.id].label })} <span aria-hidden="true">→</span>
              </MaybeLink>
            </p>
          )}
        </section>
      ))}
    </div>

    <h2 class="mt-14 text-2xl font-bold text-neutral-900">{t.additionalHeading}</h2>
    <div class="mt-4 space-y-8">
      {L.documentsAdditional.map((doc) => (
        <section id={doc.id} aria-labelledby={`${doc.id}-h`} class="scroll-mt-24">
          <h3 id={`${doc.id}-h`} class="text-lg font-semibold text-neutral-900">{doc.name}</h3>
          <p class="mt-2 max-w-prose text-base leading-relaxed text-neutral-700">
            <span class="font-medium">{t.doc.issuerLabel}:</span> {doc.issuer}. {doc.buyerUse}. <span class="font-medium">{t.doc.providedLabel}:</span> {doc.providedWhen}.
          </p>
          {(hasFact(doc.cost) || hasFact(doc.processingTime)) && (
            <p class="mt-1 text-sm text-neutral-600">
              {hasFact(doc.cost) && <span>{t.doc.costLabel}: {doc.cost}</span>}
              {hasFact(doc.cost) && hasFact(doc.processingTime) && <span aria-hidden="true"> · </span>}
              {hasFact(doc.processingTime) && <span>{t.doc.processingLabel}: {doc.processingTime}</span>}
            </p>
          )}
          {doc.id === 'self-heating-test' && (
            <p class="mt-2 max-w-prose text-sm text-neutral-700">{t.shtNote.body}{' '}
              <MaybeLink href="/logistics/un-1361" class="font-semibold" data-source-component="documents-sht-un1361">{t.shtNote.linkLabel} <span aria-hidden="true">→</span></MaybeLink>
            </p>
          )}
          {doc.id === 'insurance-certificate' && (
            <p class="mt-2 max-w-prose text-sm text-neutral-700">{t.insuranceNote.body}{' '}
              <MaybeLink href="/logistics/cargo-protection-and-insurance" class="font-semibold" data-source-component="documents-insurance-cargo">{t.insuranceNote.linkLabel} <span aria-hidden="true">→</span></MaybeLink>
            </p>
          )}
          {anchors[doc.id] && (
            <p class="mt-2 text-sm">
              <MaybeLink href={`/glossary#${anchors[doc.id].anchor}`} class="font-semibold" data-source-component={`documents-glossary-${doc.id}`}>
                {fill(t.doc.seeTemplate, { label: anchors[doc.id].label })} <span aria-hidden="true">→</span>
              </MaybeLink>
            </p>
          )}
        </section>
      ))}
    </div>

    <section id="country-requirements" aria-labelledby="country-heading" class="mt-14 scroll-mt-24">
      <h2 id="country-heading" class="text-2xl font-bold text-neutral-900">{t.countryReq.h2}</h2>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-neutral-700">{t.countryReq.body}</p>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
        <MaybeLink href="/logistics/rules" class="font-semibold" data-source-component="documents-country-rules">{t.countryReq.rulesLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/import-to-usa" class="font-semibold" data-source-component="documents-country-import">{t.countryReq.importLinkLabel}</MaybeLink>
        <span aria-hidden="true" class="text-neutral-300">·</span>
        <MaybeLink href="/logistics/un-1361" class="font-semibold" data-source-component="documents-country-un1361">{t.countryReq.un1361LinkLabel}</MaybeLink>
      </p>
    </section>

    <section aria-labelledby="documents-faq" class="mt-14">
      <FAQSection id="documents-faq" heading={t.faq.heading} items={faqItems} />
    </section>

    <section aria-labelledby="documents-related" class="mt-14 border-t border-neutral-200 pt-8">
      <h2 id="documents-related" class="text-xl font-bold text-neutral-900">{t.related.heading}</h2>
      <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2" role="list">
        {t.related.items.map((item) => (
          <li>
            <MaybeLink href={item.href} class="font-medium" mutedClass="font-medium text-neutral-400" data-source-component={`documents-related-${item.href.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`}>
              {item.label} <span aria-hidden="true">→</span>
            </MaybeLink>
          </li>
        ))}
      </ul>
    </section>
  </article>

  <CTABanner whatsappMessage={company.whatsapp.presetMessages.salesGeneral} />
</BaseLayout>
