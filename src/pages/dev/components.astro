---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/cta/Button.astro';
import Logo from '~/components/layout/Logo.astro';
import Breadcrumbs from '~/components/layout/Breadcrumbs.astro';
import HeroSection from '~/components/content/HeroSection.astro';
import CTABanner from '~/components/cta/CTABanner.astro';

const variants = ['primary', 'secondary', 'ghost', 'danger'] as const;
const sizes = ['sm', 'md', 'lg'] as const;

const typeScale = [
  { role: 'Display / Hero H1', cls: 'text-3xl font-bold md:text-4xl lg:text-5xl', sample: 'Shisha charcoal briquettes' },
  { role: 'Page H1', cls: 'text-2xl font-bold md:text-3xl lg:text-4xl', sample: 'Products' },
  { role: 'Section H2', cls: 'text-xl font-bold md:text-2xl lg:text-3xl', sample: 'Production process' },
  { role: 'Subsection H3', cls: 'text-2xl font-semibold', sample: 'Cube 25mm' },
  { role: 'Minor heading H4', cls: 'text-xl font-semibold', sample: 'Burn specifications' },
  { role: 'Lead paragraph', cls: 'text-lg', sample: 'Factory-direct from Semarang, Indonesia.' },
  { role: 'Body', cls: 'text-base', sample: 'Standard body copy for articles, specs, and long-form content.' },
  { role: 'Caption / small', cls: 'text-sm text-neutral-600', sample: 'Last updated 2026-04-20' },
  { role: 'Fine print', cls: 'text-xs text-neutral-500', sample: 'Prices in USD, FOB Semarang.' },
];
---
<BaseLayout
  title="Component gallery"
  description="Visual QA gallery for design system components. Internal use only."
  path="/dev/components"
  noIndex
>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
    <header class="mb-12">
      <p class="text-sm font-medium uppercase tracking-wide text-brand-accent">Internal</p>
      <h1 class="mt-2 text-3xl font-bold text-neutral-900 md:text-4xl">Component gallery</h1>
      <p class="mt-4 max-w-2xl text-base text-neutral-600">
        Visual QA for every design system primitive. Not indexed, filtered from the sitemap.
        When a component changes, add every variant × size × state here first.
      </p>
      <p class="mt-3 max-w-2xl text-sm text-neutral-500">
        Tip: press <kbd class="rounded border border-neutral-300 bg-neutral-50 px-1.5 py-0.5 font-mono text-xs">Tab</kbd>
        to cycle through interactive elements and verify focus rings render on every one.
      </p>
    </header>

    <section aria-labelledby="logo-heading" class="mb-16">
      <h2 id="logo-heading" class="text-2xl font-bold text-neutral-900">Logo</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-neutral-200 bg-white p-6">
          <p class="mb-3 text-xs font-medium uppercase tracking-wide text-neutral-500">With wordmark</p>
          <Logo />
        </div>
        <div class="rounded-xl border border-neutral-200 bg-white p-6">
          <p class="mb-3 text-xs font-medium uppercase tracking-wide text-neutral-500">Mark only</p>
          <Logo showWordmark={false} />
        </div>
      </div>
    </section>

    <section aria-labelledby="buttons-heading" class="mb-16 space-y-12">
      <h2 id="buttons-heading" class="text-2xl font-bold text-neutral-900">Buttons</h2>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">Variants × sizes</h3>
        <div class="overflow-x-auto rounded-xl border border-neutral-200">
          <table class="w-full">
            <thead>
              <tr class="bg-neutral-50 text-left text-sm font-medium text-neutral-800">
                <th class="px-4 py-3">Variant</th>
                {sizes.map((s) => <th class="px-4 py-3 capitalize">{s}</th>)}
              </tr>
            </thead>
            <tbody>
              {variants.map((v) => (
                <tr class="border-t border-neutral-200">
                  <td class="px-4 py-4 font-medium capitalize text-neutral-800">{v}</td>
                  {sizes.map((s) => (
                    <td class="px-4 py-4">
                      <Button variant={v} size={s}>
                        Button
                      </Button>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-sm text-neutral-500">
          All buttons meet the 44×44px mobile touch target via <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">min-h-11</code>,
          which relaxes at <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">md</code> so desktop dense UI can use the
          smaller natural height.
        </p>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">Disabled state</h3>
        <div class="flex flex-wrap items-center gap-3">
          {variants.map((v) => (
            <Button variant={v} disabled>
              Disabled {v}
            </Button>
          ))}
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">With leading icon</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Button variant="primary">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Request a quote
          </Button>
          <Button variant="secondary">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Download spec sheet
          </Button>
          <Button variant="ghost">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 8v4l3 2" stroke-linecap="round" />
            </svg>
            Lead time details
          </Button>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">As link vs button</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Button href="/" variant="primary">Link (renders &lt;a&gt;)</Button>
          <Button variant="primary" type="button">Button (renders &lt;button&gt;)</Button>
        </div>
      </div>
    </section>

    <section aria-labelledby="breadcrumbs-heading" class="mb-16">
      <h2 id="breadcrumbs-heading" class="text-2xl font-bold text-neutral-900">Breadcrumbs</h2>
      <p class="mt-2 text-sm text-neutral-600">
        Auto-prepends Home and auto-emits <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">BreadcrumbList</code> JSON-LD.
        Last item has <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">aria-current="page"</code> and no link.
      </p>
      <div class="mt-6 space-y-4">
        <div class="rounded-xl border border-neutral-200 bg-white p-6">
          <p class="mb-3 text-xs font-medium uppercase tracking-wide text-neutral-500">Two-level (Products &rsaquo; Cube 25mm)</p>
          <Breadcrumbs
            items={[
              { label: 'Products', href: '/products' },
              { label: 'Cube 25mm' },
            ]}
          />
        </div>
        <div class="rounded-xl border border-neutral-200 bg-white p-6">
          <p class="mb-3 text-xs font-medium uppercase tracking-wide text-neutral-500">Three-level (Products &rsaquo; Cubes &rsaquo; Cube 25mm)</p>
          <Breadcrumbs
            items={[
              { label: 'Products', href: '/products' },
              { label: 'Cubes', href: '/products/cubes' },
              { label: 'Cube 25mm' },
            ]}
          />
        </div>
      </div>
    </section>

    <section aria-labelledby="hero-heading" class="mb-16">
      <h2 id="hero-heading" class="text-2xl font-bold text-neutral-900">Hero section</h2>
      <p class="mt-2 text-sm text-neutral-600">
        Renders <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">&lt;h1&gt;</code> — one per page. Dark variant uses the
        homepage gradient; light variant for interior pages.
      </p>
      <div class="mt-6 space-y-4">
        <div class="overflow-hidden rounded-xl border border-dashed border-neutral-300">
          <p class="bg-neutral-50 px-4 py-2 text-xs font-medium uppercase tracking-wide text-neutral-500">Dark variant, start-aligned</p>
          <HeroSection
            variant="dark"
            eyebrow="Factory-direct coconut shell charcoal"
            title="Shisha charcoal briquettes for importers who run the numbers"
            subtitle="18-ton container loads from our Semarang factory. Full export documentation, consistent burn specifications, and samples you can verify in the lab before you commit."
            primaryCta={{ label: 'WhatsApp us', href: '#', ariaLabel: 'Chat with us on WhatsApp' }}
            secondaryCta={{ label: 'View products', href: '#' }}
          />
        </div>
        <div class="overflow-hidden rounded-xl border border-dashed border-neutral-300">
          <p class="bg-neutral-50 px-4 py-2 text-xs font-medium uppercase tracking-wide text-neutral-500">Light variant, center-aligned</p>
          <HeroSection
            variant="light"
            align="center"
            eyebrow="Buyer's guide"
            title="How to choose a shisha charcoal factory"
            subtitle="What importers verify before placing the first 20ft container order — audit, testing, and documentation checklist."
            primaryCta={{ label: 'Request a sample', href: '#' }}
          />
        </div>
      </div>
    </section>

    <section aria-labelledby="cta-banner-heading" class="mb-16">
      <h2 id="cta-banner-heading" class="text-2xl font-bold text-neutral-900">CTA banner</h2>
      <p class="mt-2 text-sm text-neutral-600">
        Defaults to WhatsApp (primary) + inquiry form (secondary). WhatsApp link resolves through
        <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-xs">src/lib/contact.ts</code>.
      </p>
      <div class="mt-6 space-y-4">
        <div class="overflow-hidden rounded-xl border border-dashed border-neutral-300">
          <p class="bg-neutral-50 px-4 py-2 text-xs font-medium uppercase tracking-wide text-neutral-500">Dark variant, defaults</p>
          <CTABanner />
        </div>
        <div class="overflow-hidden rounded-xl border border-dashed border-neutral-300">
          <p class="bg-neutral-50 px-4 py-2 text-xs font-medium uppercase tracking-wide text-neutral-500">Light variant, custom copy</p>
          <CTABanner
            variant="light"
            title="Need matching private label packaging?"
            subtitle="OEM print runs from 500 master cartons. Your artwork on our briquettes, shipped under your brand."
            secondaryCta={{ label: 'Packaging options', href: '/packaging' }}
          />
        </div>
      </div>
    </section>

    <section aria-labelledby="type-heading" class="mb-16">
      <h2 id="type-heading" class="text-2xl font-bold text-neutral-900">Typography scale</h2>
      <p class="mt-2 text-sm text-neutral-600">
        Per DESIGN.md § Typography. Reference the role name when composing pages; never use
        arbitrary pixel sizes.
      </p>
      <div class="mt-6 overflow-hidden rounded-xl border border-neutral-200">
        <table class="w-full">
          <thead>
            <tr class="bg-neutral-50 text-left text-sm font-medium text-neutral-800">
              <th class="px-4 py-3 w-48">Role</th>
              <th class="px-4 py-3">Sample</th>
            </tr>
          </thead>
          <tbody>
            {typeScale.map((row) => (
              <tr class="border-t border-neutral-200">
                <td class="px-4 py-4 align-top text-sm text-neutral-600">{row.role}</td>
                <td class="px-4 py-4">
                  <div class={row.cls}>{row.sample}</div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section aria-labelledby="colors-heading" class="mb-16">
      <h2 id="colors-heading" class="text-2xl font-bold text-neutral-900">Brand tokens</h2>
      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-primary"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-primary</div>
            <div class="text-neutral-600">#0f3d2e</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-primary-hover"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-primary-hover</div>
            <div class="text-neutral-600">#0a2a1f</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-accent"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-accent</div>
            <div class="text-neutral-600">#c9a24b</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-dark"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-dark</div>
            <div class="text-neutral-600">#0a1f17</div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="semantic-heading">
      <h2 id="semantic-heading" class="text-2xl font-bold text-neutral-900">Semantic tokens</h2>
      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-success"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">success</div>
            <div class="text-neutral-600">#16a34a</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-error"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">error</div>
            <div class="text-neutral-600">#dc2626</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-warning"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">warning</div>
            <div class="text-neutral-600">#ea580c</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-info"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">info</div>
            <div class="text-neutral-600">#2563eb</div>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
