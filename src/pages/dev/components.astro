---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/cta/Button.astro';

const variants = ['primary', 'secondary', 'ghost', 'danger'] as const;
const sizes = ['sm', 'md', 'lg'] as const;
---
<BaseLayout
  title="Component gallery"
  description="Visual QA gallery for design system components. Internal use only."
  path="/dev/components"
  noIndex
>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8 md:py-24">
    <header class="mb-12">
      <p class="text-sm font-medium uppercase tracking-wide text-brand-accent">Internal</p>
      <h1 class="mt-2 text-3xl font-bold text-neutral-900 md:text-4xl">Component gallery</h1>
      <p class="mt-4 max-w-2xl text-base text-neutral-600">
        Visual QA for every design system primitive. Not indexed, not in the sitemap. When
        a component changes, add every variant × size × state here first.
      </p>
    </header>

    <section aria-labelledby="buttons-heading" class="space-y-12">
      <h2 id="buttons-heading" class="text-2xl font-bold text-neutral-900">Buttons</h2>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">Variants × sizes</h3>
        <div class="overflow-x-auto rounded-xl border border-neutral-200">
          <table class="w-full">
            <thead>
              <tr class="bg-neutral-50 text-left text-sm font-medium text-neutral-800">
                <th class="px-4 py-3">Variant</th>
                {sizes.map((s) => <th class="px-4 py-3 capitalize">{s}</th>)}
              </tr>
            </thead>
            <tbody>
              {variants.map((v) => (
                <tr class="border-t border-neutral-200">
                  <td class="px-4 py-4 font-medium capitalize text-neutral-800">{v}</td>
                  {sizes.map((s) => (
                    <td class="px-4 py-4">
                      <Button variant={v} size={s}>
                        Button
                      </Button>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">Disabled state</h3>
        <div class="flex flex-wrap items-center gap-3">
          {variants.map((v) => (
            <Button variant={v} disabled>
              Disabled {v}
            </Button>
          ))}
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">With leading icon</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Button variant="primary">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Request a quote
          </Button>
          <Button variant="secondary">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Download spec sheet
          </Button>
          <Button variant="ghost">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 8v4l3 2" stroke-linecap="round" />
            </svg>
            Lead time details
          </Button>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xl font-semibold text-neutral-900">As link vs button</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Button href="/" variant="primary">Link (renders &lt;a&gt;)</Button>
          <Button variant="primary" type="button">Button (renders &lt;button&gt;)</Button>
        </div>
      </div>
    </section>

    <section aria-labelledby="colors-heading" class="mt-16 space-y-6">
      <h2 id="colors-heading" class="text-2xl font-bold text-neutral-900">Brand tokens</h2>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-primary"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-primary</div>
            <div class="text-neutral-600">#0f3d2e</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-primary-hover"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-primary-hover</div>
            <div class="text-neutral-600">#0a2a1f</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-accent"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-accent</div>
            <div class="text-neutral-600">#c9a24b</div>
          </div>
        </div>
        <div class="overflow-hidden rounded-xl border border-neutral-200">
          <div class="h-20 bg-brand-dark"></div>
          <div class="p-3 text-xs">
            <div class="font-semibold text-neutral-900">brand-dark</div>
            <div class="text-neutral-600">#0a1f17</div>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
