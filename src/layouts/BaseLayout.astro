---
import SEO from '~/components/seo/SEO.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import SkipLink from '~/components/layout/SkipLink.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import { getLanguage, DEFAULT_LANGUAGE } from '~/config/i18n';

interface PreloadHint {
  href: string;
  as: 'image' | 'style' | 'script' | 'font';
  type?: string;
  crossorigin?: '' | 'anonymous' | 'use-credentials';
  imagesrcset?: string;
  imagesizes?: string;
}

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  noIndex?: boolean;
  lang?: string;
  /** Override the dir derived from the language config. Rarely needed. */
  dir?: 'ltr' | 'rtl';
  includeOrgSchema?: boolean;
  /** Resources to preload — use for the hero image and logo on pages where they matter for LCP. */
  preload?: PreloadHint[];
  /** URLs to prefetch — use for the primary next-page navigation target on each page. */
  prefetch?: string[];
  /** Page-specific JSON-LD schema. Pass an object (single graph) or array (multiple). */
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  path,
  image,
  type = 'website',
  noIndex = false,
  lang = DEFAULT_LANGUAGE,
  dir: dirOverride,
  includeOrgSchema = false,
  preload = [],
  prefetch = [],
  schema,
} = Astro.props;

const langConfig = getLanguage(lang) ?? getLanguage(DEFAULT_LANGUAGE)!;
const resolvedDir = dirOverride ?? langConfig.dir;
const resolvedLocale = langConfig.locale;

// CSP must also be updated in public/_headers to allow googletagmanager.com,
// google-analytics.com, and connect.facebook.net before these env vars are set
// in production. Until then both stay unset and no third-party script renders.
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID as string | undefined;
---
<!doctype html>
<html lang={lang} dir={resolvedDir} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f3d2e" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.web3forms.com" crossorigin />

    {preload.map((hint) => (
      <link
        rel="preload"
        href={hint.href}
        as={hint.as}
        type={hint.type}
        crossorigin={hint.crossorigin}
        imagesrcset={hint.imagesrcset}
        imagesizes={hint.imagesizes}
      />
    ))}
    {prefetch.map((href) => (
      <link rel="prefetch" href={href} />
    ))}

    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      locale={resolvedLocale}
      noIndex={noIndex}
    />
    {includeOrgSchema && <OrganizationSchema />}
    {schema && <JsonLd data={schema} />}

    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };
          window.gtag('js', new Date());
          window.gtag('config', gaId);
        </script>
      </>
    )}
    {pixelId && (
      <script is:inline define:vars={{ pixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
        window.fbq('init', pixelId);
        window.fbq('track', 'PageView');
      </script>
    )}
  </head>
  <body class="flex min-h-full flex-col bg-white font-sans text-base leading-relaxed text-neutral-800">
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1" class="flex-1 focus:outline-none">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton floating />
    <script>
      import { initAnalytics } from '~/lib/analytics';
      initAnalytics();
    </script>
  </body>
</html>
