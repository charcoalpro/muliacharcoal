---
import SEO from '~/components/seo/SEO.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import SkipLink from '~/components/layout/SkipLink.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  noIndex?: boolean;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  includeOrgSchema?: boolean;
}

const {
  title,
  description,
  path,
  image,
  type = 'website',
  noIndex = false,
  lang = 'en',
  dir = 'ltr',
  includeOrgSchema = false,
} = Astro.props;
---
<!doctype html>
<html lang={lang} dir={dir} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f3d2e" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.web3forms.com" crossorigin />

    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      noIndex={noIndex}
    />
    {includeOrgSchema && <OrganizationSchema />}
  </head>
  <body class="flex min-h-full flex-col bg-white font-sans text-base leading-relaxed text-neutral-800">
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1" class="flex-1 focus:outline-none">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton floating />
  </body>
</html>
