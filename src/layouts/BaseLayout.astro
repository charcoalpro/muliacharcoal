---
import SEO from '~/components/seo/SEO.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import SkipLink from '~/components/layout/SkipLink.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import Analytics from '~/components/Analytics.astro';
import { company } from '~/config/company';

interface PreloadHint {
  href: string;
  as: 'image' | 'style' | 'script' | 'font';
  type?: string;
  crossorigin?: '' | 'anonymous' | 'use-credentials';
  imagesrcset?: string;
  imagesizes?: string;
}

// Locales that need right-to-left layout. Add codes here as RTL
// translations (Arabic, Hebrew, …) launch.
const RTL_LOCALES = new Set(['ar', 'he', 'fa', 'ur']);

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  noIndex?: boolean;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  includeOrgSchema?: boolean;
  /** Resources to preload — use for the hero image and logo on pages where they matter for LCP. */
  preload?: PreloadHint[];
  /** URLs to prefetch — use for the primary next-page navigation target on each page. */
  prefetch?: string[];
  /** Page-specific JSON-LD schema. Pass an object (single graph) or array (multiple). */
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** Render the GA4 / Meta Pixel snippet. Default true; set false on dev / utility pages. */
  includeAnalytics?: boolean;
  /** Render the floating WhatsApp button. Default true; set false on print / embed pages. */
  includeWhatsAppButton?: boolean;
  /** Render Header + Footer + SkipLink. Set false for chrome-free utility renders. */
  includeChrome?: boolean;
}

const {
  title,
  description,
  path,
  image,
  type = 'website',
  noIndex = false,
  lang = 'en',
  // Default `dir` from the lang code so RTL locales just work without
  // every page having to remember to set it.
  dir = (RTL_LOCALES.has(lang) ? 'rtl' : 'ltr'),
  includeOrgSchema = false,
  preload = [],
  prefetch = [],
  schema,
  includeAnalytics = true,
  includeWhatsAppButton = true,
  includeChrome = true,
} = Astro.props;
---
<!doctype html>
<html lang={lang} dir={dir} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={company.brandAssets.colors.primary} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {includeAnalytics && <Analytics />}

    <link rel="preconnect" href="https://api.web3forms.com" crossorigin />

    {preload.map((hint) => (
      <link
        rel="preload"
        href={hint.href}
        as={hint.as}
        type={hint.type}
        crossorigin={hint.crossorigin}
        imagesrcset={hint.imagesrcset}
        imagesizes={hint.imagesizes}
      />
    ))}
    {prefetch.map((href) => (
      <link rel="prefetch" href={href} />
    ))}

    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      noIndex={noIndex}
    />
    {includeOrgSchema && <OrganizationSchema />}
    {schema && <JsonLd data={schema} />}
  </head>
  <body class="flex min-h-full flex-col bg-white font-sans text-base leading-relaxed text-neutral-800">
    {includeChrome && <SkipLink />}
    {includeChrome && <Header />}
    <main id="main" tabindex="-1" class="flex-1 focus:outline-none">
      <slot />
    </main>
    {includeChrome && <Footer />}
    {includeWhatsAppButton && <WhatsAppButton floating />}
  </body>
</html>
