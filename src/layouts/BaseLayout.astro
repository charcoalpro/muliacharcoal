---
import type { ImageMetadata } from 'astro';
import SEO from '~/components/seo/SEO.astro';
import JsonLd from '~/components/seo/JsonLd.astro';
import OrganizationSchema from '~/components/seo/OrganizationSchema.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import SkipLink from '~/components/layout/SkipLink.astro';
import WhatsAppButton from '~/components/cta/WhatsAppButton.astro';
import Toast from '~/components/feedback/Toast.astro';
import Analytics from '~/components/seo/Analytics.astro';
import { company } from '~/config/company';
import { DEFAULT_LOCALE, localeDir, type Locale } from '~/config/i18n';

interface PreloadHint {
  href: string;
  as: 'image' | 'style' | 'script' | 'font';
  type?: string;
  crossorigin?: '' | 'anonymous' | 'use-credentials';
  imagesrcset?: string;
  imagesizes?: string;
}

interface Props {
  title: string;
  description: string;
  path?: string;
  /**
   * Page social card. Pass an Astro `import` for processed assets, a
   * public-folder string (e.g. `/og/products.jpg`), or omit to fall
   * back to `company.brandAssets.images.ogDefault`.
   */
  image?: ImageMetadata | string;
  type?: 'website' | 'article' | 'product';
  noIndex?: boolean;
  /** Robots directive override forwarded to <SEO>. Use `'noindex-follow'`
   *  for a thin-content page (substance floor); defaults to deriving from noIndex. */
  robots?: 'index' | 'noindex' | 'noindex-follow';
  /** Page locale. Drives <html lang>, <html dir>, and og:locale. Defaults to DEFAULT_LOCALE. */
  lang?: Locale;
  includeOrgSchema?: boolean;
  /** Resources to preload — use for the hero image and logo on pages where they matter for LCP. */
  preload?: PreloadHint[];
  /** URLs to prefetch — use for the primary next-page navigation target on each page. */
  prefetch?: string[];
  /** Page-specific JSON-LD schema. Pass an object (single graph) or array (multiple). */
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  path,
  image,
  type = 'website',
  noIndex = false,
  robots,
  lang = DEFAULT_LOCALE,
  includeOrgSchema = false,
  preload = [],
  prefetch = [],
  schema,
} = Astro.props;

const dir = localeDir(lang);
---
<!doctype html>
<html lang={lang} dir={dir} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={company.brandAssets.colors.primary} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <Analytics />

    <link rel="preconnect" href="https://api.web3forms.com" crossorigin />

    {preload.map((hint) => (
      <link
        rel="preload"
        href={hint.href}
        as={hint.as}
        type={hint.type}
        crossorigin={hint.crossorigin}
        imagesrcset={hint.imagesrcset}
        imagesizes={hint.imagesizes}
      />
    ))}
    {prefetch.map((href) => (
      <link rel="prefetch" href={href} />
    ))}

    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      locale={lang}
      noIndex={noIndex}
      robots={robots}
    />
    {includeOrgSchema && <OrganizationSchema />}
    {schema && <JsonLd data={schema} />}
  </head>
  <body class="flex min-h-full flex-col bg-white font-sans text-base leading-relaxed text-neutral-800">
    <SkipLink />
    <Header />
    <main id="main" tabindex="-1" class="flex-1 focus:outline-none">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton floating />
    <Toast />
  </body>
</html>
